@@ -0,0 +1,44 @@
+#!/usr/bin/env bash
+# Install or verify local FVE line-shopper stack (consolidated VPS @ 127.0.0.1).
+#
+#   sudo bash /opt/hibs-bet/scripts/install_fve_lines_stack.sh
+#   sudo bash /opt/hibs-bet/scripts/install_fve_lines_stack.sh --verify
+set -euo pipefail
+
+APP="${DEPLOY_PATH:-/opt/hibs-bet}"
+FVE="${FVE_DEPLOY_PATH:-/opt/fve}"
+VERIFY=0
+
+for arg in "$@"; do
+  [[ "${arg}" == "--verify" ]] && VERIFY=1
+done
+
+[[ "$(id -u)" -eq 0 ]] || { echo "run as root" >&2; exit 1; }
+
+mkdir -p /etc/hibs-bet
+if [[ ! -f /etc/hibs-bet/stack.env ]]; then
+  cat >/etc/hibs-bet/stack.env <<EOF
+FVE_REMOTE_HOST=127.0.0.1
+HIBS_PUBLIC_HOST=${HIBS_PUBLIC_HOST:-hibs-bet.co.uk}
+HIBS_VPS_IP=${HIBS_VPS_IP:-127.0.0.1}
+EOF
+fi
+
+HIBS_UPSTREAM_BASE_URL=http://127.0.0.1:8000 DEPLOY_PATH="${APP}" FVE_DEPLOY_PATH="${FVE}" \
+  bash "${APP}/deploy/apply-vps-fve-line-trader.sh"
+
+if [[ -f "${APP}/scripts/run_fve_lines_collector.sh" ]]; then
+  HIBS_UPSTREAM_BASE_URL=http://127.0.0.1:8000 FVE_DEPLOY_PATH="${FVE}" \
+    bash "${APP}/scripts/run_fve_lines_collector.sh" || true
+fi
+
+if [[ -f "${APP}/scripts/lib_fve_local_repair.sh" ]]; then
+  bash "${APP}/scripts/lib_fve_local_repair.sh" || true
+fi
+
+if [[ "${VERIFY}" -eq 1 ]]; then
+  echo "==> FVE health"
+  curl -fsS --max-time 10 "http://127.0.0.1:8010/health" | python3 -m json.tool | head -24 || true
+  echo "==> hibs fixtures export"
+  curl -fsS --max-time 10 "http://127.0.0.1:8000/api/fve/fixtures" | python3 -m json.tool | head -16 || true
+fi
