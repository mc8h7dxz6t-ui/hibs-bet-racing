 scripts/install_four_stack_automation.sh      |   5 +-
 scripts/install_fve_lines_stack.sh            |  44 ++++
 scripts/lib_stack_host.sh                     |   8 +-
 5 files changed, 254 insertions(+), 3 deletions(-)
 create mode 100755 scripts/bootstrap_consolidated_vps_go_live.sh
 create mode 100755 scripts/install_fve_lines_stack.sh

