@@ -0,0 +1,26 @@
+"""Shared engine singleton — one quant stack per process."""
+
+from __future__ import annotations
+
+import threading
+from typing import Optional
+
+from hibs_predictor.inplay.engine import InplayQuantEngine, inplay_engine_from_env
+
+_LOCK = threading.Lock()
+_ENGINE: Optional[InplayQuantEngine] = None
+
+
+def get_shared_engine() -> InplayQuantEngine:
+    global _ENGINE
+    with _LOCK:
+        if _ENGINE is None:
+            _ENGINE = inplay_engine_from_env()
+        return _ENGINE
+
+
+def reset_shared_engine() -> None:
+    """Test helper — drop cached engine."""
+    global _ENGINE
+    with _LOCK:
+        _ENGINE = None
