new file mode 100644
index 0000000..a61eb76
--- /dev/null
+++ b/src/hibs_predictor/inplay/validate.py
@@ -0,0 +1,89 @@
+"""Input/output validation — probabilities, state, stale live data."""
+
+from __future__ import annotations
+
+import os
+import time
+from typing import Any, Dict, List, Tuple
+
+
+def _env_float(name: str, default: float) -> float:
+    try:
+        return float(os.getenv(name, str(default)))
+    except ValueError:
+        return default
+
+
+def normalize_probabilities(probs: Dict[str, float]) -> Dict[str, float]:
+    """Renormalise 1X2 to sum=1 after numeric drift."""
+    keys = ("home", "draw", "away")
+    vals = {k: max(0.0, float(probs.get(k) or 0.0)) for k in keys}
+    total = sum(vals.values())
+    if total <= 0:
+        return {"home": 1 / 3, "draw": 1 / 3, "away": 1 / 3}
+    return {k: vals[k] / total for k in keys}
+
+
+def validate_probabilities(probs: Dict[str, float], *, tol: float = 0.02) -> Tuple[bool, List[str]]:
+    issues: List[str] = []
+    if not probs:
+        return False, ["empty_probabilities"]
+    keys = ("home", "draw", "away")
+    for k in keys:
+        v = probs.get(k)
+        if v is None:
+            issues.append(f"missing_{k}")
+            continue
+        try:
+            fv = float(v)
+        except (TypeError, ValueError):
+            issues.append(f"invalid_{k}")
+            continue
+        if fv < 0.0 or fv > 1.0:
+            issues.append(f"out_of_range_{k}")
+    total = sum(float(probs.get(k) or 0) for k in keys)
+    if abs(total - 1.0) > tol:
+        issues.append(f"sum_not_one:{round(total, 4)}")
+    return len(issues) == 0, issues
+
+
+def validate_live_row(row: Dict[str, Any]) -> Tuple[bool, List[str]]:
+    """Reject ticks with impossible or stale live state."""
+    issues: List[str] = []
+    if not row.get("is_live"):
+        issues.append("not_live")
+    minute = row.get("live_minute")
+    try:
+        m = float(minute) if minute is not None else None
+    except (TypeError, ValueError):
+        m = None
+    if m is None:
+        issues.append("missing_minute")
+    elif m < 0 or m > 130:
+        issues.append("minute_out_of_range")
+    gh = row.get("live_score_home")
+    ga = row.get("live_score_away")
+    try:
+        if gh is not None and int(gh) < 0:
+            issues.append("negative_home_goals")
+        if ga is not None and int(ga) < 0:
+            issues.append("negative_away_goals")
+    except (TypeError, ValueError):
+        issues.append("invalid_score")
+    pred = row.get("prediction") if isinstance(row.get("prediction"), dict) else {}
+    if not pred.get("expected_goals_home") and not row.get("xg_home"):
+        issues.append("missing_prematch_lambda")
+    return len(issues) == 0, issues
+
+
+def live_row_stale(row: Dict[str, Any], *, max_age_sec: float | None = None) -> bool:
+    """True when live snapshot is too old to trade on."""
+    cap = max_age_sec if max_age_sec is not None else _env_float("HIBS_INPLAY_MAX_TICK_AGE_SEC", 45.0)
+    ts = row.get("inplay_prediction", {}).get("ts") if isinstance(row.get("inplay_prediction"), dict) else None
+    if ts is None:
+        ts = row.get("_live_poll_ts")
+    try:
+        age = time.time() - float(ts)
+    except (TypeError, ValueError):
+        return False
+    return age > cap
