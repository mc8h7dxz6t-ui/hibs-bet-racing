diff --git a/src/hibs_predictor/inplay/failsafe.py b/src/hibs_predictor/inplay/failsafe.py
new file mode 100644
index 0000000..2fd79b9
--- /dev/null
+++ b/src/hibs_predictor/inplay/failsafe.py
@@ -0,0 +1,152 @@
+"""Institutional++ failsafe — circuit breaker, safe ticks, never crash callers."""
+
+from __future__ import annotations
+
+import logging
+import os
+import time
+from typing import Any, Dict, Optional, Tuple
+
+from hibs_predictor.inplay.engine import InplayQuantEngine, ProbabilitySnapshot
+from hibs_predictor.inplay.telemetry import get_telemetry
+from hibs_predictor.inplay.validate import live_row_stale, normalize_probabilities, validate_live_row, validate_probabilities
+
+logger = logging.getLogger("hibs.inplay.failsafe")
+
+
+class CircuitBreaker:
+    """Open after N consecutive failures; half-open after cooldown."""
+
+    def __init__(self, *, fail_threshold: int = 5, cooldown_sec: float = 30.0):
+        self.fail_threshold = fail_threshold
+        self.cooldown_sec = cooldown_sec
+        self._failures = 0
+        self._opened_at: Optional[float] = None
+
+    @property
+    def is_open(self) -> bool:
+        if self._opened_at is None:
+            return False
+        if time.time() - self._opened_at >= self.cooldown_sec:
+            self._opened_at = None
+            self._failures = 0
+            return False
+        return True
+
+    def record_success(self) -> None:
+        self._failures = 0
+        self._opened_at = None
+
+    def record_failure(self) -> None:
+        self._failures += 1
+        if self._failures >= self.fail_threshold:
+            self._opened_at = time.time()
+            get_telemetry().record_circuit_open()
+
+
+_BREAKER = CircuitBreaker(
+    fail_threshold=int(os.getenv("HIBS_INPLAY_CIRCUIT_FAIL_THRESHOLD", "5")),
+    cooldown_sec=float(os.getenv("HIBS_INPLAY_CIRCUIT_COOLDOWN_SEC", "30")),
+)
+
+
+def circuit_breaker() -> CircuitBreaker:
+    return _BREAKER
+
+
+def reset_circuit_breaker() -> None:
+    _BREAKER._failures = 0
+    _BREAKER._opened_at = None
+
+
+def safe_tick_fixture(
+    engine: InplayQuantEngine,
+    row: Dict[str, Any],
+) -> Tuple[Optional[ProbabilitySnapshot], Dict[str, Any]]:
+    """
+    Tick with validation + circuit breaker. Never raises.
+    Returns (snapshot|None, meta with ok/reason/latency_ms).
+    """
+    meta: Dict[str, Any] = {"ok": False}
+    tel = get_telemetry()
+    started = time.perf_counter()
+
+    if _BREAKER.is_open:
+        meta["reason"] = "circuit_open"
+        tel.record_tick(ok=False, latency_ms=0, error="circuit_open")
+        return None, meta
+
+    ok_row, row_issues = validate_live_row(row)
+    if not ok_row and "not_live" not in row_issues:
+        meta["reason"] = "validation_reject"
+        meta["issues"] = row_issues
+        tel.record_validation_reject()
+        tel.record_tick(ok=False, latency_ms=(time.perf_counter() - started) * 1000, error="validation")
+        return None, meta
+
+    try:
+        snap = engine.tick_fixture(row)
+    except Exception as exc:
+        logger.exception("inplay tick failed fixture=%s", row.get("id"))
+        _BREAKER.record_failure()
+        meta["reason"] = "tick_exception"
+        meta["error"] = str(exc)[:200]
+        tel.record_tick(ok=False, latency_ms=(time.perf_counter() - started) * 1000, error=str(exc)[:80])
+        return None, meta
+
+    if not snap:
+        meta["reason"] = "not_live"
+        tel.record_tick(ok=False, latency_ms=(time.perf_counter() - started) * 1000)
+        return None, meta
+
+    probs = normalize_probabilities(snap.probabilities)
+    ok_probs, prob_issues = validate_probabilities(probs)
+    if not ok_probs:
+        probs = normalize_probabilities(probs)
+        snap.probabilities = probs
+        snap.probabilities_pct = {k: round(v * 100.0, 2) for k, v in probs.items()}
+        meta["prob_renormalised"] = prob_issues
+
+    _BREAKER.record_success()
+    latency = (time.perf_counter() - started) * 1000
+    tel.record_tick(ok=True, latency_ms=latency)
+    meta.update({"ok": True, "latency_ms": round(latency, 2), "fixture_id": snap.fixture_id})
+    return snap, meta
+
+
+def safe_attach_to_fixture(engine: InplayQuantEngine, row: Dict[str, Any]) -> bool:
+    """Attach inplay_prediction without raising; respects stale guard."""
+    tel = get_telemetry()
+    try:
+        if live_row_stale(row):
+            row["inplay_stale"] = True
+            tel.record_attach(ok=False)
+            return False
+        snap, meta = safe_tick_fixture(engine, row)
+        if not snap or not meta.get("ok"):
+            tel.record_attach(ok=False)
+            return False
+        row["inplay_prediction"] = snap.as_dict()
+        risk = engine.evaluate_execution(row, snap)
+        row["inplay_risk"] = {
+            "suspended": risk.suspended,
+            "suspend_reason": risk.suspend_reason,
+            "signals": [
+                {
+                    "outcome": s.outcome,
+                    "edge": s.edge,
+                    "approved": s.approved,
+                    "kelly": s.kelly,
+                    "decimal_odds": s.decimal_odds,
+                }
+                for s in risk.signals
+            ],
+        }
+        row["_inplay_meta"] = {"latency_ms": meta.get("latency_ms"), "failsafe": "ok"}
+        tel.record_attach(ok=True)
+        return True
+    except Exception as exc:
+        logger.exception("inplay attach failed fixture=%s", row.get("id"))
+        tel.record_attach(ok=False)
+        row["inplay_error"] = str(exc)[:120]
+        return False
