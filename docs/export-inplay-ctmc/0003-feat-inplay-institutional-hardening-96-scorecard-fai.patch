new file mode 100644
index 0000000..153e9b2
--- /dev/null
+++ b/src/hibs_predictor/inplay/readiness.py
@@ -0,0 +1,175 @@
+"""Institutional++ readiness scorecard for the in-play quant lane."""
+
+from __future__ import annotations
+
+import os
+from datetime import datetime, timezone
+from typing import Any, Dict, List, Tuple
+
+from dotenv import load_dotenv
+
+
+def _env_truthy(name: str) -> bool:
+    return (os.getenv(name) or "").strip().lower() in ("1", "true", "yes", "on")
+
+
+def _gate(name: str, ok: bool, *, weight: float = 1.0, detail: str = "") -> Dict[str, Any]:
+    return {"id": name, "pass": bool(ok), "weight": weight, "detail": detail}
+
+
+def collect_inplay_issues(*, production: bool | None = None) -> Tuple[List[str], List[str]]:
+    load_dotenv()
+    is_prod = _env_truthy("HIBS_PRODUCTION") if production is None else bool(production)
+    blocking: List[str] = []
+    warnings: List[str] = []
+
+    if not _env_truthy("HIBS_INPLAY_ENABLED"):
+        if is_prod and _env_truthy("HIBS_INPLAY_REQUIRED"):
+            blocking.append("HIBS_INPLAY_ENABLED=0 but HIBS_INPLAY_REQUIRED=1 on production.")
+        return blocking, warnings
+
+    if (os.getenv("HIBS_INPLAY_EXECUTE") or "").strip().lower() == "live":
+        if (os.getenv("HIBS_INPLAY_CONFIRM_LIVE") or "").strip().upper() != "YES":
+            blocking.append("HIBS_INPLAY_EXECUTE=live requires HIBS_INPLAY_CONFIRM_LIVE=YES.")
+
+    try:
+        kelly = float(os.getenv("HIBS_INPLAY_KELLY_FRACTION", "0.25"))
+        if kelly > 0.30:
+            warnings.append(f"HIBS_INPLAY_KELLY_FRACTION={kelly} > 0.30 — institutional cap is quarter-Kelly.")
+    except ValueError:
+        warnings.append("HIBS_INPLAY_KELLY_FRACTION is not numeric.")
+
+    from hibs_predictor.inplay.kernel_bridge import kernel_available
+
+    if _env_truthy("HIBS_INPLAY_KERNEL") and not kernel_available():
+        warnings.append("Rust kernel enabled but binary missing — run scripts/build_inplay_kernel.sh")
+
+    from hibs_predictor.inplay.telemetry import get_telemetry, read_worker_heartbeat_age_sec
+
+    tel = get_telemetry()
+    if tel.error_rate_pct() > 5.0 and (tel.ticks_ok + tel.ticks_fail) >= 20:
+        warnings.append(f"In-play error rate {tel.error_rate_pct()}% exceeds 5% budget.")
+
+    p95 = tel.p95_latency_ms()
+    if p95 is not None and p95 > 500:
+        warnings.append(f"In-play p95 tick latency {p95}ms exceeds 500ms SLO.")
+
+    from hibs_predictor.inplay.failsafe import circuit_breaker
+
+    if circuit_breaker().is_open:
+        blocking.append("In-play circuit breaker is OPEN — ticks suspended.")
+
+    hb_age = read_worker_heartbeat_age_sec()
+    if _env_truthy("HIBS_INPLAY_WORKER_REQUIRED") and (hb_age is None or hb_age > 60):
+        blocking.append("In-play worker heartbeat missing or stale (>60s).")
+
+    if is_prod and (os.getenv("HIBS_INPLAY_EXECUTE") or "").strip().lower() == "live" and not (os.getenv("HIBS_BETFAIR_MARKET_MAP_JSON") or "").strip():
+        warnings.append("Live execute enabled but HIBS_BETFAIR_MARKET_MAP_JSON unset.")
+
+    return blocking, warnings
+
+
+def inplay_scorecard(*, production: bool | None = None) -> Dict[str, Any]:
+    """Weighted gate score targeting 96% institutional++ grade."""
+    load_dotenv()
+    is_prod = _env_truthy("HIBS_PRODUCTION") if production is None else bool(production)
+    gates: List[Dict[str, Any]] = []
+
+    enabled = _env_truthy("HIBS_INPLAY_ENABLED")
+    gates.append(_gate("inplay_enabled", enabled, weight=2.0))
+
+    from hibs_predictor.inplay.kernel_bridge import kernel_available
+
+    gates.append(_gate("rust_kernel", kernel_available() or not _env_truthy("HIBS_INPLAY_KERNEL"), weight=1.5))
+
+    from hibs_predictor.inplay.failsafe import circuit_breaker
+
+    gates.append(_gate("circuit_closed", not circuit_breaker().is_open, weight=2.0))
+
+    from hibs_predictor.inplay.telemetry import get_telemetry, read_worker_heartbeat_age_sec
+
+    tel = get_telemetry()
+    err_ok = tel.error_rate_pct() <= 5.0 or (tel.ticks_ok + tel.ticks_fail) < 10
+    gates.append(_gate("error_budget", err_ok, weight=2.0, detail=f"error_rate={tel.error_rate_pct()}%"))
+
+    p95 = tel.p95_latency_ms()
+    lat_ok = p95 is None or p95 <= 500
+    gates.append(_gate("latency_slo", lat_ok, weight=1.5, detail=f"p95_ms={p95}"))
+
+    gates.append(_gate("archive_ticks", _env_truthy("HIBS_INPLAY_ARCHIVE_TICKS"), weight=1.0))
+
+    from hibs_predictor.inplay.weight_trainer import resolve_feature_weights
+
+    w = resolve_feature_weights()
+    gates.append(_gate("intensity_weights", len(w) >= 11, weight=1.0, detail=f"n={len(w)}"))
+
+    gates.append(_gate("kelly_cap", float(os.getenv("HIBS_INPLAY_KELLY_FRACTION", "0.25")) <= 0.30, weight=1.5))
+
+    live_ok = (os.getenv("HIBS_INPLAY_EXECUTE") or "dry").strip().lower() != "live" or (
+        (os.getenv("HIBS_INPLAY_CONFIRM_LIVE") or "").strip().upper() == "YES"
+    )
+    gates.append(_gate("live_confirm", live_ok, weight=2.0))
+
+    gates.append(_gate("var_suspend", _env_truthy("HIBS_INPLAY_SUSPEND_VAR") or os.getenv("HIBS_INPLAY_SUSPEND_VAR") is None, weight=1.0))
+
+    hb_age = read_worker_heartbeat_age_sec()
+    worker_ok = not _env_truthy("HIBS_INPLAY_WORKER_REQUIRED") or (hb_age is not None and hb_age <= 60)
+    gates.append(_gate("worker_heartbeat", worker_ok, weight=1.5, detail=f"age_sec={hb_age}"))
+
+    from pathlib import Path
+
+    root = Path(__file__).resolve().parents[3]
+    script_ok = (root / "scripts" / "preflight_inplay.sh").is_file()
+    gates.append(_gate("preflight_script", script_ok, weight=0.5))
+
+    blocking, warnings = collect_inplay_issues(production=is_prod)
+    gates.append(_gate("no_blocking_issues", len(blocking) == 0, weight=2.0))
+
+    total_w = sum(g["weight"] for g in gates)
+    passed_w = sum(g["weight"] for g in gates if g["pass"])
+    score_pct = round(100.0 * passed_w / total_w, 1) if total_w else 0.0
+
+    if score_pct >= 96.0 and not blocking:
+        grade = "A++"
+        buyer_ready = True
+    elif score_pct >= 90.0 and not blocking:
+        grade = "A"
+        buyer_ready = False
+    elif score_pct >= 80.0:
+        grade = "B"
+        buyer_ready = False
+    else:
+        grade = "C"
+        buyer_ready = False
+
+    return {
+        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
+        "enabled": enabled,
+        "score_pct": score_pct,
+        "institutional_grade": grade,
+        "buyer_ready": buyer_ready,
+        "target_pct": 96.0,
+        "gates": gates,
+        "gates_passed": sum(1 for g in gates if g["pass"]),
+        "gates_total": len(gates),
+        "blocking_issues": blocking,
+        "warnings": warnings,
+        "telemetry": tel.as_dict(),
+    }
+
+
+def inplay_readiness_dict(*, production: bool | None = None) -> Dict[str, Any]:
+    """Health / failsafe compatible summary."""
+    sc = inplay_scorecard(production=production)
+    return {
+        "score_pct": sc["score_pct"],
+        "institutional_grade": sc["institutional_grade"],
+        "buyer_ready": sc["buyer_ready"],
+        "target_pct": sc["target_pct"],
+        "enabled": sc["enabled"],
+        "blocking_issues": sc["blocking_issues"],
+        "warnings": sc["warnings"],
+        "telemetry": sc["telemetry"],
+        "gates_passed": sc["gates_passed"],
+        "gates_total": sc["gates_total"],
+    }
