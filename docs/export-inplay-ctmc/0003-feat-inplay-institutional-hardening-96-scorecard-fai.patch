new file mode 100644
index 0000000..5d5a2d7
--- /dev/null
+++ b/src/hibs_predictor/inplay/telemetry.py
@@ -0,0 +1,139 @@
+"""Operational telemetry — tick latency, error budget, circuit state."""
+
+from __future__ import annotations
+
+import os
+import threading
+import time
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Optional
+
+
+@dataclass
+class InplayTelemetry:
+    ticks_ok: int = 0
+    ticks_fail: int = 0
+    attach_ok: int = 0
+    attach_fail: int = 0
+    kernel_calls: int = 0
+    kernel_fallbacks: int = 0
+    validation_rejects: int = 0
+    circuit_opens: int = 0
+    last_tick_ts: float = 0.0
+    last_error: str = ""
+    latency_ms: List[float] = field(default_factory=list)
+    _lock: threading.Lock = field(default_factory=threading.Lock, repr=False)
+
+    def record_tick(self, *, ok: bool, latency_ms: float, error: str = "") -> None:
+        with self._lock:
+            if ok:
+                self.ticks_ok += 1
+                self.last_tick_ts = time.time()
+            else:
+                self.ticks_fail += 1
+                if error:
+                    self.last_error = error[:200]
+            self.latency_ms.append(latency_ms)
+            if len(self.latency_ms) > 500:
+                self.latency_ms = self.latency_ms[-500:]
+
+    def record_attach(self, *, ok: bool) -> None:
+        with self._lock:
+            if ok:
+                self.attach_ok += 1
+            else:
+                self.attach_fail += 1
+
+    def record_kernel_fallback(self) -> None:
+        with self._lock:
+            self.kernel_fallbacks += 1
+
+    def record_kernel_call(self) -> None:
+        with self._lock:
+            self.kernel_calls += 1
+
+    def record_validation_reject(self) -> None:
+        with self._lock:
+            self.validation_rejects += 1
+
+    def record_circuit_open(self) -> None:
+        with self._lock:
+            self.circuit_opens += 1
+
+    def p95_latency_ms(self) -> Optional[float]:
+        with self._lock:
+            if not self.latency_ms:
+                return None
+            ordered = sorted(self.latency_ms)
+            idx = min(len(ordered) - 1, int(0.95 * len(ordered)))
+            return round(ordered[idx], 2)
+
+    def error_rate_pct(self) -> float:
+        with self._lock:
+            total = self.ticks_ok + self.ticks_fail
+            if total <= 0:
+                return 0.0
+            return round(100.0 * self.ticks_fail / total, 2)
+
+    def _snapshot_unlocked(self) -> Dict[str, Any]:
+        return {
+            "ticks_ok": self.ticks_ok,
+            "ticks_fail": self.ticks_fail,
+            "attach_ok": self.attach_ok,
+            "attach_fail": self.attach_fail,
+            "kernel_calls": self.kernel_calls,
+            "kernel_fallbacks": self.kernel_fallbacks,
+            "validation_rejects": self.validation_rejects,
+            "circuit_opens": self.circuit_opens,
+            "last_tick_ts": self.last_tick_ts,
+            "last_error": self.last_error or None,
+            "p95_latency_ms": (
+                round(sorted(self.latency_ms)[min(len(self.latency_ms) - 1, int(0.95 * len(self.latency_ms)))], 2)
+                if self.latency_ms
+                else None
+            ),
+            "error_rate_pct": (
+                round(100.0 * self.ticks_fail / (self.ticks_ok + self.ticks_fail), 2)
+                if (self.ticks_ok + self.ticks_fail) > 0
+                else 0.0
+            ),
+        }
+
+    def as_dict(self) -> Dict[str, Any]:
+        with self._lock:
+            return self._snapshot_unlocked()
+
+
+_TELEMETRY = InplayTelemetry()
+
+
+def get_telemetry() -> InplayTelemetry:
+    return _TELEMETRY
+
+
+def worker_heartbeat_path() -> str:
+    root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(__file__))))
+    return os.path.join(root, "logs", "inplay_worker.heartbeat")
+
+
+def write_worker_heartbeat(meta: Optional[Dict[str, Any]] = None) -> None:
+    path = worker_heartbeat_path()
+    os.makedirs(os.path.dirname(path), exist_ok=True)
+    line = f"{time.time():.3f}"
+    if meta:
+        line += f" live={meta.get('live', 0)} priced={meta.get('priced', 0)}"
+    with open(path, "w", encoding="utf-8") as fh:
+        fh.write(line + "\n")
+
+
+def read_worker_heartbeat_age_sec() -> Optional[float]:
+    path = worker_heartbeat_path()
+    if not os.path.isfile(path):
+        return None
+    try:
+        with open(path, encoding="utf-8") as fh:
+            first = fh.readline().strip().split()[0]
+        ts = float(first)
+        return max(0.0, time.time() - ts)
+    except (OSError, ValueError, IndexError):
+        return None
