+"""Institutional++ grade tests — 96% scorecard, failsafe, validation."""
+
+from __future__ import annotations
+
+import time
+
+import pytest
+
+from hibs_predictor.inplay.failsafe import circuit_breaker, safe_attach_to_fixture, safe_tick_fixture
+from hibs_predictor.inplay.readiness import inplay_readiness_dict, inplay_scorecard
+from hibs_predictor.inplay.singleton import get_shared_engine, reset_shared_engine
+from hibs_predictor.inplay.telemetry import get_telemetry, write_worker_heartbeat
+from hibs_predictor.inplay.validate import normalize_probabilities, validate_live_row, validate_probabilities
+
+
+def _live_fixture(**overrides):
+    base = {
+        "id": "99001",
+        "is_live": True,
+        "live_minute": 67,
+        "live_score_home": 1,
+        "live_score_away": 0,
+        "live_status": "2H",
+        "live_xg_home": 1.45,
+        "live_xg_away": 0.82,
+        "home": "Hibs",
+        "away": "Hearts",
+        "league_code": "SCOTLAND",
+        "prediction": {"expected_goals_home": 1.55, "expected_goals_away": 1.05},
+        "best_odds_1x2": {"home": 1.72, "draw": 3.8, "away": 5.2},
+    }
+    base.update(overrides)
+    return base
+
+
+@pytest.fixture(autouse=True)
+def _reset_inplay_circuit():
+    from hibs_predictor.inplay.failsafe import reset_circuit_breaker
+
+    reset_circuit_breaker()
+    yield
+    reset_circuit_breaker()
+
+
+def test_validate_live_row_rejects_not_live():
+    ok, issues = validate_live_row({"is_live": False})
+    assert not ok
+    assert "not_live" in issues
+
+
+def test_failsafe_tick_never_raises(monkeypatch):
+    monkeypatch.setenv("HIBS_INPLAY_ENABLED", "1")
+    reset_shared_engine()
+    engine = get_shared_engine()
+    row = _live_fixture()
+    snap, meta = safe_tick_fixture(engine, row)
+    assert meta.get("ok") is True
+    assert snap is not None
+
+
+def test_circuit_breaker_opens_after_failures():
+    cb = circuit_breaker()
+    cb._failures = 0
+    cb._opened_at = None
+    for _ in range(cb.fail_threshold):
+        cb.record_failure()
+    assert cb.is_open
+
+
+def test_inplay_scorecard_structure(monkeypatch):
+    monkeypatch.setenv("HIBS_INPLAY_ENABLED", "1")
+    sc = inplay_scorecard()
+    assert "score_pct" in sc
+    assert "institutional_grade" in sc
+    assert sc["target_pct"] == 96.0
+    assert sc["gates_total"] >= 10
+
+
+def test_readiness_dict_for_health(monkeypatch):
+    monkeypatch.setenv("HIBS_INPLAY_ENABLED", "1")
+    rd = inplay_readiness_dict()
+    assert "telemetry" in rd
+    assert "score_pct" in rd
+
+
+def test_safe_attach_populates_row(monkeypatch):
+    from hibs_predictor.inplay.failsafe import reset_circuit_breaker
+
+    reset_circuit_breaker()
+    monkeypatch.setenv("HIBS_INPLAY_ENABLED", "1")
+    reset_shared_engine()
+    row = _live_fixture()
+    ok = safe_attach_to_fixture(get_shared_engine(), row)
+    assert ok is True
+    assert "inplay_prediction" in row
+    assert row["inplay_prediction"]["probabilities_pct"]["home"] > 50
+
+
+def test_worker_heartbeat(tmp_path, monkeypatch):
+    hb = tmp_path / "hb.txt"
+    monkeypatch.setenv("HIBS_INPLAY_TICK_ARCHIVE", str(tmp_path / "x.sqlite"))
+    from hibs_predictor.inplay import telemetry as tel_mod
+
+    monkeypatch.setattr(tel_mod, "worker_heartbeat_path", lambda: str(hb))
+    write_worker_heartbeat({"live": 2, "priced": 1})
+    assert hb.is_file()
+    age = tel_mod.read_worker_heartbeat_age_sec()
+    assert age is not None and age < 5
+
+
+def test_telemetry_error_rate():
+    tel = get_telemetry()
+    tel.ticks_ok = 95
+    tel.ticks_fail = 5
+    assert tel.error_rate_pct() == 5.0
+
+
+def test_telemetry_as_dict_no_deadlock():
+    tel = get_telemetry()
+    tel.record_tick(ok=True, latency_ms=12.5)
+    snap = tel.as_dict()
+    assert snap["ticks_ok"] >= 1
+    assert snap["p95_latency_ms"] is not None
+
+
+def test_probability_validation():
+    ok, _ = validate_probabilities({"home": 0.4, "draw": 0.3, "away": 0.3})
+    assert ok
