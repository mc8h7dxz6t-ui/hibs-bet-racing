+#!/usr/bin/env bash
+# Institutional++ preflight for in-play quant lane — pass | warn | fail
+set -euo pipefail
+ROOT="$(cd "$(dirname "$0")/.." && pwd)"
+cd "$ROOT"
+export PYTHONPATH="${ROOT}/src${PYTHONPATH:+:$PYTHONPATH}"
+export HIBS_INPLAY_ARCHIVE_TICKS="${HIBS_INPLAY_ARCHIVE_TICKS:-1}"
+export HIBS_INPLAY_SUSPEND_VAR="${HIBS_INPLAY_SUSPEND_VAR:-1}"
+
+echo "==> In-play institutional preflight"
+
+python3 - <<'PY'
+import json
+import sys
+
+from hibs_predictor.inplay.readiness import inplay_scorecard
+
+sc = inplay_scorecard()
+print(json.dumps(sc, indent=2))
+score = float(sc.get("score_pct") or 0)
+blocking = sc.get("blocking_issues") or []
+if blocking:
+    print(f"FAIL blocking={blocking}", file=sys.stderr)
+    sys.exit(2)
+if score < 80:
+    print(f"WARN score_pct={score} (<80)", file=sys.stderr)
+    sys.exit(1)
+if score < 96:
+    print(f"WARN score_pct={score} (<96 target)", file=sys.stderr)
+    sys.exit(1)
+print(f"PASS score_pct={score} grade={sc.get('institutional_grade')}")
+PY
