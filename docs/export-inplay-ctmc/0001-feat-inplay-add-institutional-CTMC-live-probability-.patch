+#!/usr/bin/env bash
+# 15-second in-play quant tick worker (institutional stack entrypoint).
+set -euo pipefail
+ROOT="$(cd "$(dirname "$0")/.." && pwd)"
+cd "$ROOT"
+export PYTHONPATH="${ROOT}/src${PYTHONPATH:+:$PYTHONPATH}"
+export HIBS_INPLAY_ENABLED="${HIBS_INPLAY_ENABLED:-1}"
+TICK="${HIBS_INPLAY_TICK_SEC:-15}"
+
+if [[ ! -d .venv ]]; then
+  python3 -m venv .venv
+fi
+# shellcheck disable=SC1091
+source .venv/bin/activate
+pip -q install -r requirements.txt >/dev/null
+
+echo "[inplay-worker] tick=${TICK}s enabled=${HIBS_INPLAY_ENABLED} solver=${HIBS_INPLAY_SOLVER:-ctmc}"
+exec python - <<'PY'
+import os
+import time
+
+from hibs_predictor.data_aggregator import DataAggregator
+from hibs_predictor.inplay.engine import inplay_engine_from_env
+from hibs_predictor.inplay.execution import InplayExecutionEngine
+from hibs_predictor.live_scores import attach_live_to_fixtures
+from hibs_predictor.web import fetch_all_fixtures
+
+tick = float(os.getenv("HIBS_INPLAY_TICK_SEC", "15"))
+execute = os.getenv("HIBS_INPLAY_WORKER_EXECUTE", "0").strip().lower() in ("1", "true", "yes")
+bankroll = float(os.getenv("HIBS_INPLAY_BANKROLL", "1000"))
+
+agg = DataAggregator()
+quant = inplay_engine_from_env()
+exec_engine = InplayExecutionEngine(quant=quant)
+
+while True:
+    try:
+        bundle = fetch_all_fixtures()
+        rows = bundle.get("all") if isinstance(bundle, dict) else []
+        attach_live_to_fixtures(rows, agg, include_events=True, include_stats=True)
+        live_rows = [r for r in rows if r.get("is_live")]
+        snaps = quant.tick_many(live_rows)
+        print(f"[tick] live={len(live_rows)} priced={len(snaps)}")
+        if execute:
+            for row in live_rows:
+                result = exec_engine.execute_if_edge(row, bankroll=bankroll)
+                if result.executed or result.reason not in ("not_live", "no_edge"):
+                    print(f"  {row.get('id')} -> {result.reason} orders={len(result.orders)}")
+    except Exception as exc:
+        print(f"[tick] error: {exc!r}")
+    time.sleep(tick)
+PY
