+++ b/src/hibs_predictor/inplay/ctmc.py
@@ -0,0 +1,125 @@
+"""CTMC generator Q(t) and forward Kolmogorov solver for 1X2 terminal probs."""
+
+from __future__ import annotations
+
+import math
+from typing import Dict, Tuple
+
+import numpy as np
+
+from hibs_predictor.inplay.state import MatchState
+
+
+def _matrix_expm(q: np.ndarray, dt: float) -> np.ndarray:
+    """Matrix exponential exp(Q dt) — scipy if present, else truncated Taylor."""
+    m = q * float(dt)
+    try:
+        from scipy.linalg import expm  # type: ignore
+
+        return np.asarray(expm(m), dtype=float)
+    except Exception:
+        out = np.eye(q.shape[0], dtype=float)
+        term = np.eye(q.shape[0], dtype=float)
+        for k in range(1, 16):
+            term = term @ m / k
+            out = out + term
+        return out
+
+
+def build_score_generator(n: int, lam_h_per_min: float, lam_a_per_min: float) -> np.ndarray:
+    """Infinitesimal generator on truncated score grid (g_h, g_a) ∈ [0, n-1]."""
+    size = n * n
+    q = np.zeros((size, size), dtype=float)
+    for gh in range(n):
+        for ga in range(n):
+            idx = gh * n + ga
+            rate_out = 0.0
+            if gh + 1 < n:
+                j = (gh + 1) * n + ga
+                q[idx, j] = lam_h_per_min
+                rate_out += lam_h_per_min
+            if ga + 1 < n:
+                j = gh * n + (ga + 1)
+                q[idx, j] = lam_a_per_min
+                rate_out += lam_a_per_min
+            q[idx, idx] = -rate_out
+    return q
+
+
+def state_index(goals_home: int, goals_away: int, n: int) -> int:
+    gh = max(0, min(n - 1, int(goals_home)))
+    ga = max(0, min(n - 1, int(goals_away)))
+    return gh * n + ga
+
+
+def aggregate_1x2(dist: np.ndarray, n: int) -> Dict[str, float]:
+    p_home = p_draw = p_away = 0.0
+    for gh in range(n):
+        for ga in range(n):
+            p = float(dist[gh * n + ga])
+            if gh > ga:
+                p_home += p
+            elif gh == ga:
+                p_draw += p
+            else:
+                p_away += p
+    total = p_home + p_draw + p_away
+    if total <= 0:
+        return {"home": 1 / 3, "draw": 1 / 3, "away": 1 / 3}
+    return {
+        "home": p_home / total,
+        "draw": p_draw / total,
+        "away": p_away / total,
+    }
+
+
+def solve_terminal_1x2_ctmc(
+    state: MatchState,
+    lam_h_remaining: float,
+    lam_a_remaining: float,
+    *,
+    goal_cap: int = 8,
+    step_minutes: float = 1.0,
+) -> Tuple[Dict[str, float], Dict[str, float]]:
+    """
+    Solve d p / dt = p Q(t) via piecewise-homogeneous 1-minute matrix exponentiation.
+
+    λ inputs are expected goals over *remaining* match time; converted to per-minute rates.
+    """
+    n = max(3, int(goal_cap) + 1)
+    remaining = max(0.0, state.minutes_remaining)
+    if remaining <= 0.0:
+        return _terminal_from_current_score(state), {"method": "terminal_score", "steps": 0}
+
+    lam_h_min = max(0.0, lam_h_remaining) / max(remaining, 1.0)
+    lam_a_min = max(0.0, lam_a_remaining) / max(remaining, 1.0)
+
+    idx = state_index(state.goals_home, state.goals_away, n)
+    dist = np.zeros(n * n, dtype=float)
+    dist[idx] = 1.0
+
+    steps = max(1, int(math.ceil(remaining / step_minutes)))
+    dt = remaining / steps
+    q = build_score_generator(n, lam_h_min, lam_a_min)
+    transition = _matrix_expm(q, dt)
+    for _ in range(steps):
+        dist = dist @ transition
+
+    probs = aggregate_1x2(dist, n)
+    meta = {
+        "method": "ctmc_matrix_exp",
+        "steps": steps,
+        "step_minutes": round(dt, 4),
+        "goal_cap": n - 1,
+        "lambda_home_per_min": round(lam_h_min, 5),
+        "lambda_away_per_min": round(lam_a_min, 5),
+    }
+    return probs, meta
+
+
+def _terminal_from_current_score(state: MatchState) -> Dict[str, float]:
+    if state.goals_home > state.goals_away:
+        return {"home": 1.0, "draw": 0.0, "away": 0.0}
+    if state.goals_home < state.goals_away:
+        return {"home": 0.0, "draw": 0.0, "away": 1.0}
+    return {"home": 0.0, "draw": 1.0, "away": 0.0}
