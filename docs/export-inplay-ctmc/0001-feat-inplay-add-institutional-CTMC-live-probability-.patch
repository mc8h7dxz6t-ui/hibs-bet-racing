+++ b/src/hibs_predictor/inplay/engine.py
@@ -0,0 +1,213 @@
+"""15-second quant tick — CTMC / MC probability engine."""
+
+from __future__ import annotations
+
+import os
+import time
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Optional
+
+from hibs_predictor.inplay.ctmc import solve_terminal_1x2_ctmc
+from hibs_predictor.inplay.event_stack import EventStack
+from hibs_predictor.inplay.features import extract_live_features
+from hibs_predictor.inplay.feeds import parse_live_fixture_tick
+from hibs_predictor.inplay.intensity import compute_intensities
+from hibs_predictor.inplay.monte_carlo import simulate_terminal_1x2_mc
+from hibs_predictor.inplay.risk import RiskDecision, evaluate_risk, risk_config_from_env
+from hibs_predictor.inplay.state import MatchState, PrematchPrior, match_state_from_fixture, prematch_prior_from_fixture
+
+
+def _env_float(name: str, default: float) -> float:
+    try:
+        return float(os.getenv(name, str(default)))
+    except ValueError:
+        return default
+
+
+def _env_int(name: str, default: int) -> int:
+    try:
+        return int(os.getenv(name, str(default)))
+    except ValueError:
+        return default
+
+
+def inplay_enabled() -> bool:
+    return os.getenv("HIBS_INPLAY_ENABLED", "0").strip().lower() in ("1", "true", "yes", "on")
+
+
+@dataclass
+class InplayEngineConfig:
+    tick_sec: float = 15.0
+    match_minutes: float = 95.0
+    solver: str = "ctmc"  # ctmc | mc
+    mc_paths: int = 10000
+
+
+@dataclass
+class ProbabilitySnapshot:
+    fixture_id: str
+    state: Dict[str, Any]
+    probabilities: Dict[str, float]
+    probabilities_pct: Dict[str, float]
+    intensities: Dict[str, Any]
+    features: Dict[str, Any]
+    solver_meta: Dict[str, Any]
+    ts: float = field(default_factory=time.time)
+
+    def as_dict(self) -> Dict[str, Any]:
+        return {
+            "fixture_id": self.fixture_id,
+            "state": self.state,
+            "probabilities": self.probabilities,
+            "probabilities_pct": self.probabilities_pct,
+            "intensities": self.intensities,
+            "features": self.features,
+            "solver": self.solver_meta,
+            "ts": self.ts,
+        }
+
+
+class InplayQuantEngine:
+    """QuantEngine: rolling Markov tick over live fixtures."""
+
+    def __init__(
+        self,
+        *,
+        config: Optional[InplayEngineConfig] = None,
+        event_stack: Optional[EventStack] = None,
+    ):
+        self.config = config or inplay_engine_config_from_env()
+        self.stack = event_stack or EventStack()
+        self._cache: Dict[str, ProbabilitySnapshot] = {}
+
+    def tick_fixture(self, row: Dict[str, Any]) -> Optional[ProbabilitySnapshot]:
+        if not row.get("is_live"):
+            return None
+        fid = str(row.get("id") or "")
+        if not fid:
+            return None
+        tick = parse_live_fixture_tick(row, match_minutes=self.config.match_minutes)
+        self.stack.push_tick(fid, tick)
+
+        state = match_state_from_fixture(row, match_minutes=self.config.match_minutes)
+        prior = prematch_prior_from_fixture(row)
+        hist = self._history_with_age(fid, state.minute)
+        features = extract_live_features(row, state, history=hist)
+        lam_h, lam_a, intensity_dbg = compute_intensities(state, prior, features)
+
+        if self.config.solver == "mc":
+            probs, solver_meta = simulate_terminal_1x2_mc(
+                state, lam_h, lam_a, n_paths=self.config.mc_paths
+            )
+        else:
+            probs, solver_meta = solve_terminal_1x2_ctmc(state, lam_h, lam_a)
+
+        snap = ProbabilitySnapshot(
+            fixture_id=fid,
+            state=state.as_dict(),
+            probabilities={k: round(v, 6) for k, v in probs.items()},
+            probabilities_pct={k: round(v * 100.0, 2) for k, v in probs.items()},
+            intensities=intensity_dbg,
+            features=features.as_dict(),
+            solver_meta=solver_meta,
+        )
+        self._cache[fid] = snap
+        return snap
+
+    def evaluate_execution(
+        self,
+        row: Dict[str, Any],
+        snapshot: Optional[ProbabilitySnapshot] = None,
+    ) -> RiskDecision:
+        snap = snapshot or self._cache.get(str(row.get("id") or ""))
+        if not snap:
+            snap = self.tick_fixture(row)
+        if not snap:
+            return RiskDecision(fixture_id=str(row.get("id") or ""), suspended=True, suspend_reason="not_live")
+        odds = _market_odds_from_row(row)
+        return evaluate_risk(
+            snap.fixture_id,
+            snap.probabilities,
+            odds,
+            row=row,
+        )
+
+    def attach_to_fixture(self, row: Dict[str, Any]) -> bool:
+        """Compute live 1X2 and attach `inplay_prediction` to dashboard row."""
+        if not inplay_enabled():
+            return False
+        snap = self.tick_fixture(row)
+        if not snap:
+            return False
+        row["inplay_prediction"] = snap.as_dict()
+        risk = self.evaluate_execution(row, snap)
+        row["inplay_risk"] = {
+            "suspended": risk.suspended,
+            "suspend_reason": risk.suspend_reason,
+            "signals": [
+                {
+                    "outcome": s.outcome,
+                    "edge": s.edge,
+                    "approved": s.approved,
+                    "kelly": s.kelly,
+                    "decimal_odds": s.decimal_odds,
+                }
+                for s in risk.signals
+            ],
+        }
+        return True
+
+    def tick_many(self, fixtures: List[Dict[str, Any]]) -> Dict[str, ProbabilitySnapshot]:
+        out: Dict[str, ProbabilitySnapshot] = {}
+        for row in fixtures:
+            snap = self.tick_fixture(row)
+            if snap:
+                out[snap.fixture_id] = snap
+        return out
+
+    def get_cached(self, fixture_id: str) -> Optional[ProbabilitySnapshot]:
+        return self._cache.get(str(fixture_id))
+
+    def _history_with_age(self, fixture_id: str, current_minute: float) -> List[Dict[str, Any]]:
+        hist = self.stack.history(fixture_id, limit=40)
+        out: List[Dict[str, Any]] = []
+        for item in reversed(hist):
+            try:
+                minute = float(item.get("minute", 0))
+            except (TypeError, ValueError):
+                minute = 0.0
+            row = dict(item)
+            row["age_minutes"] = max(0.0, current_minute - minute)
+            out.append(row)
+        return out
+
+
+def inplay_engine_config_from_env() -> InplayEngineConfig:
+    solver = (os.getenv("HIBS_INPLAY_SOLVER") or "ctmc").strip().lower()
+    return InplayEngineConfig(
+        tick_sec=_env_float("HIBS_INPLAY_TICK_SEC", 15.0),
+        match_minutes=_env_float("HIBS_INPLAY_MATCH_MINUTES", 95.0),
+        solver="mc" if solver == "mc" else "ctmc",
+        mc_paths=_env_int("HIBS_INPLAY_MC_PATHS", 10000),
+    )
+
+
+def inplay_engine_from_env() -> InplayQuantEngine:
+    return InplayQuantEngine(config=inplay_engine_config_from_env())
+
+
+def _market_odds_from_row(row: Dict[str, Any]) -> Dict[str, float]:
+    out: Dict[str, float] = {}
+    best = row.get("best_odds_1x2") if isinstance(row.get("best_odds_1x2"), dict) else {}
+    mapping = {"home": "home", "draw": "draw", "away": "away"}
+    for side, key in mapping.items():
+        raw = best.get(side)
+        if raw is None:
+            raw = row.get(f"odds_{side}")
+        try:
+            val = float(raw)
+        except (TypeError, ValueError):
+            continue
+        if val > 1.0:
+            out[side] = val
+    return out
