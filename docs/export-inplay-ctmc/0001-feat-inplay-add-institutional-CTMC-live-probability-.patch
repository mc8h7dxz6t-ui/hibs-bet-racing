+"""FIX/JSON feed normalisation into event-stack payloads."""
+
+from __future__ import annotations
+
+from typing import Any, Dict, List, Optional
+
+from hibs_predictor.inplay.state import MatchState, match_state_from_fixture
+
+
+def parse_live_fixture_tick(row: Dict[str, Any], *, match_minutes: float = 95.0) -> Dict[str, Any]:
+    """Normalise dashboard/API row into a quant-engine tick payload."""
+    state = match_state_from_fixture(row, match_minutes=match_minutes)
+    stats = row.get("live_stats") if isinstance(row.get("live_stats"), dict) else {}
+    stat_rows = stats.get("rows") if isinstance(stats.get("rows"), list) else []
+    corners_h = corners_a = shots_h = shots_a = None
+    for item in stat_rows:
+        if not isinstance(item, dict):
+            continue
+        label = str(item.get("label") or "").lower()
+        if "corner" in label:
+            corners_h, corners_a = item.get("home"), item.get("away")
+        if "shots on" in label:
+            shots_h, shots_a = item.get("home"), item.get("away")
+    return {
+        "fixture_id": str(row.get("id") or ""),
+        "minute": state.minute,
+        "live_xg_home": row.get("live_xg_home"),
+        "live_xg_away": row.get("live_xg_away"),
+        "live_score_home": state.goals_home,
+        "live_score_away": state.goals_away,
+        "shots_on_home": shots_h,
+        "shots_on_away": shots_a,
+        "corners_home": corners_h,
+        "corners_away": corners_a,
+        "live_status": row.get("live_status"),
+        "state": state.as_dict(),
+    }
+
+
+def parse_api_football_events(events: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
+    """Map API-Football fixture/events rows to stack events."""
+    out: List[Dict[str, Any]] = []
+    for ev in events or []:
+        if not isinstance(ev, dict):
+            continue
+        out.append(
+            {
+                "type": ev.get("type"),
+                "detail": ev.get("detail"),
+                "minute": (ev.get("time") or {}).get("elapsed"),
+                "team": (ev.get("team") or {}).get("name"),
+                "player": (ev.get("player") or {}).get("name"),
+            }
+        )
+    return out
