+"""Smart order router — REST hooks; FIX stub for institutional venues."""
+
+from __future__ import annotations
+
+import os
+import time
+import uuid
+from typing import Any, Dict, List, Optional
+
+
+class SmartOrderRouter:
+    """
+    Route orders across venues with volume splitting.
+    Default: paper log only. Set HIBS_INPLAY_EXECUTE=paper|live (live requires explicit confirm).
+    """
+
+    def __init__(self) -> None:
+        self.mode = self._resolve_mode()
+        self.venues = self._parse_venues()
+
+    def _resolve_mode(self) -> str:
+        execute = (os.getenv("HIBS_INPLAY_EXECUTE") or "dry").strip().lower()
+        if execute == "live":
+            confirm = (os.getenv("HIBS_INPLAY_CONFIRM_LIVE") or "").strip().upper()
+            if confirm != "YES":
+                return "dry"
+            return "live"
+        if execute in ("paper", "shadow"):
+            return "paper"
+        return "dry"
+
+    def _parse_venues(self) -> List[str]:
+        raw = (os.getenv("HIBS_INPLAY_VENUES") or "betfair,matchbook").strip()
+        return [v.strip() for v in raw.split(",") if v.strip()]
+
+    def route_order(
+        self,
+        *,
+        fixture_id: str,
+        outcome: str,
+        decimal_odds: float,
+        stake: float,
+        meta: Optional[Dict[str, Any]] = None,
+    ) -> Dict[str, Any]:
+        """Split stake across venues (equal slices v1)."""
+        if stake <= 0 or decimal_odds <= 1.0:
+            return {"status": "rejected", "reason": "invalid_stake_or_odds"}
+        n = max(1, len(self.venues))
+        slice_stake = round(stake / n, 2)
+        legs = []
+        for venue in self.venues:
+            legs.append(self._submit_leg(venue, fixture_id, outcome, decimal_odds, slice_stake, meta))
+        return {
+            "status": "routed",
+            "mode": self.mode,
+            "order_id": str(uuid.uuid4()),
+            "total_stake": stake,
+            "legs": legs,
+            "ts": time.time(),
+        }
+
+    def _submit_leg(
+        self,
+        venue: str,
+        fixture_id: str,
+        outcome: str,
+        decimal_odds: float,
+        stake: float,
+        meta: Optional[Dict[str, Any]],
+    ) -> Dict[str, Any]:
+        if self.mode == "live":
+            return self._live_submit(venue, fixture_id, outcome, decimal_odds, stake, meta)
+        return {
+            "venue": venue,
+            "status": "paper" if self.mode == "paper" else "dry",
+            "fixture_id": fixture_id,
+            "outcome": outcome,
+            "decimal_odds": decimal_odds,
+            "stake": stake,
+            "meta": meta or {},
+        }
+
+    def _live_submit(
+        self,
+        venue: str,
+        fixture_id: str,
+        outcome: str,
+        decimal_odds: float,
+        stake: float,
+        meta: Optional[Dict[str, Any]],
+    ) -> Dict[str, Any]:
+        # Institutional FIX/REST adapters plug in here (Betfair, Matchbook, Pinnacle).
+        return {
+            "venue": venue,
+            "status": "live_stub",
+            "message": "Wire venue adapter before live submit",
+            "fixture_id": fixture_id,
+            "outcome": outcome,
+            "decimal_odds": decimal_odds,
+            "stake": stake,
+            "meta": meta or {},
+        }
