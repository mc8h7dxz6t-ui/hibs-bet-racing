@@ -0,0 +1,60 @@
+"""Monte Carlo parallel paths for terminal 1X2 (GPU-ready batch interface)."""
+
+from __future__ import annotations
+
+import os
+from typing import Dict, Tuple
+
+import numpy as np
+
+from hibs_predictor.inplay.state import MatchState
+
+
+def _env_int(name: str, default: int) -> int:
+    try:
+        return int(os.getenv(name, str(default)))
+    except ValueError:
+        return default
+
+
+def simulate_terminal_1x2_mc(
+    state: MatchState,
+    lam_h_remaining: float,
+    lam_a_remaining: float,
+    *,
+    n_paths: int | None = None,
+    seed: int | None = None,
+) -> Tuple[Dict[str, float], Dict[str, float]]:
+    """
+    Simulate remaining goals as coupled Poisson processes (100k paths default in prod).
+    """
+    paths = n_paths if n_paths is not None else _env_int("HIBS_INPLAY_MC_PATHS", 10000)
+    remaining = max(0.0, state.minutes_remaining)
+    if remaining <= 0.0:
+        from hibs_predictor.inplay.ctmc import _terminal_from_current_score
+
+        return _terminal_from_current_score(state), {"method": "mc_terminal_score", "paths": 0}
+
+    rng = np.random.default_rng(seed)
+    lam_h = max(0.0, lam_h_remaining)
+    lam_a = max(0.0, lam_a_remaining)
+    add_h = rng.poisson(lam_h, size=paths)
+    add_a = rng.poisson(lam_a, size=paths)
+    final_h = state.goals_home + add_h
+    final_a = state.goals_away + add_a
+    wins_h = np.sum(final_h > final_a)
+    draws = np.sum(final_h == final_a)
+    wins_a = np.sum(final_h < final_a)
+    total = float(paths)
+    probs = {
+        "home": wins_h / total,
+        "draw": draws / total,
+        "away": wins_a / total,
+    }
+    meta = {
+        "method": "monte_carlo_poisson",
+        "paths": paths,
+        "lambda_home_remaining": round(lam_h, 4),
+        "lambda_away_remaining": round(lam_a, 4),
+    }
+    return probs, meta
