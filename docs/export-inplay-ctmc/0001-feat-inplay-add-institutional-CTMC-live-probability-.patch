+@app.route("/api/inplay/probabilities")
+@login_required
+def api_inplay_probabilities():
+    """Live CTMC 1X2 probabilities + Kelly risk signals for in-play fixtures."""
+    from hibs_predictor.inplay.integration import inplay_payload_for_rows
+
+    raw_ids = (request.args.get("ids") or "").strip()
+    include_domestic = request.args.get("domestic") == "1"
+    data = _load_fixtures_for_http(include_domestic=include_domestic)
+    all_rows = data.get("all") or []
+    if raw_ids:
+        want = {part.strip() for part in raw_ids.split(",") if part.strip()}
+        rows = [f for f in all_rows if str(f.get("id")) in want and f.get("is_live")]
+    else:
+        rows = [f for f in all_rows if f.get("is_live")]
+    return jsonify(inplay_payload_for_rows(rows))
+
+
 @app.route("/api/fixtures")
 @login_required
 def api_fixtures():
