@@ -0,0 +1,118 @@
+"""Low-latency execution engine — Kelly gate + paper/live mode."""
+
+from __future__ import annotations
+
+import json
+import os
+import time
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+
+from hibs_predictor.inplay.engine import InplayQuantEngine, ProbabilitySnapshot
+from hibs_predictor.inplay.risk import RiskDecision, TradeSignal
+from hibs_predictor.inplay.router import SmartOrderRouter
+
+
+@dataclass
+class ExecutionResult:
+    fixture_id: str
+    executed: bool
+    mode: str
+    orders: List[Dict[str, Any]] = field(default_factory=list)
+    reason: str = ""
+    ts: float = field(default_factory=time.time)
+
+    def as_dict(self) -> Dict[str, Any]:
+        return {
+            "fixture_id": self.fixture_id,
+            "executed": self.executed,
+            "mode": self.mode,
+            "orders": self.orders,
+            "reason": self.reason,
+            "ts": self.ts,
+        }
+
+
+class InplayExecutionEngine:
+    """Kelly-checked execution — paper by default."""
+
+    def __init__(
+        self,
+        *,
+        quant: Optional[InplayQuantEngine] = None,
+        router: Optional[SmartOrderRouter] = None,
+    ):
+        self.quant = quant or InplayQuantEngine()
+        self.router = router or SmartOrderRouter()
+        self._log_path = Path(os.getenv("HIBS_INPLAY_EXEC_LOG", "logs/inplay_execution.jsonl"))
+
+    def execute_if_edge(
+        self,
+        row: Dict[str, Any],
+        *,
+        bankroll: float = 1000.0,
+    ) -> ExecutionResult:
+        fid = str(row.get("id") or "")
+        snap = self.quant.tick_fixture(row)
+        if not snap:
+            return ExecutionResult(fixture_id=fid, executed=False, mode=self.router.mode, reason="not_live")
+        risk = self.quant.evaluate_execution(row, snap)
+        if risk.suspended:
+            return ExecutionResult(
+                fixture_id=fid,
+                executed=False,
+                mode=self.router.mode,
+                reason=risk.suspend_reason or "suspended",
+            )
+        approved = [s for s in risk.signals if s.approved]
+        if not approved:
+            return ExecutionResult(fixture_id=fid, executed=False, mode=self.router.mode, reason="no_edge")
+        orders = []
+        for signal in approved:
+            stake = self._stake_from_signal(signal, bankroll)
+            if stake <= 0:
+                continue
+            order = self.router.route_order(
+                fixture_id=fid,
+                outcome=signal.outcome,
+                decimal_odds=signal.decimal_odds,
+                stake=stake,
+                meta={"edge": signal.edge, "model_prob": signal.model_prob},
+            )
+            orders.append(order)
+        executed = bool(orders) and self.router.mode != "dry"
+        result = ExecutionResult(
+            fixture_id=fid,
+            executed=executed,
+            mode=self.router.mode,
+            orders=orders,
+            reason="edge_ok" if orders else "stake_zero",
+        )
+        self._audit(result, snap, risk)
+        return result
+
+    def _stake_from_signal(self, signal: TradeSignal, bankroll: float) -> float:
+        pct = float(signal.kelly.get("suggested_percent") or 0.0)
+        return round(bankroll * (pct / 100.0), 2)
+
+    def _audit(
+        self,
+        result: ExecutionResult,
+        snap: ProbabilitySnapshot,
+        risk: RiskDecision,
+    ) -> None:
+        try:
+            self._log_path.parent.mkdir(parents=True, exist_ok=True)
+            row = {
+                "result": result.as_dict(),
+                "probabilities": snap.probabilities,
+                "signals": [
+                    {"outcome": s.outcome, "edge": s.edge, "approved": s.approved}
+                    for s in risk.signals
+                ],
+            }
+            with self._log_path.open("a", encoding="utf-8") as fh:
+                fh.write(json.dumps(row, default=str) + "\n")
+        except OSError:
+            pass
diff --git a/src/hibs_predictor/inplay/features.py b/src/hibs_predictor/inplay/features.py
