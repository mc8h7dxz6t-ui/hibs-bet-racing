+"""Dashboard and API wiring for the in-play quant stack."""
+
+from __future__ import annotations
+
+from typing import Any, Dict, List, Optional
+
+from hibs_predictor.inplay.engine import InplayQuantEngine, inplay_enabled, inplay_engine_from_env
+
+
+def attach_inplay_predictions(
+    fixtures: List[Dict[str, Any]],
+    *,
+    engine: Optional[InplayQuantEngine] = None,
+) -> int:
+    """Run quant tick on live rows; returns count updated."""
+    if not inplay_enabled():
+        return 0
+    quant = engine or inplay_engine_from_env()
+    updated = 0
+    for row in fixtures or []:
+        if not row.get("is_live"):
+            continue
+        if quant.attach_to_fixture(row):
+            updated += 1
+    return updated
+
+
+def inplay_payload_for_rows(
+    fixtures: List[Dict[str, Any]],
+    *,
+    engine: Optional[InplayQuantEngine] = None,
+) -> Dict[str, Any]:
+    """API payload keyed by fixture id."""
+    if not inplay_enabled():
+        return {"enabled": False, "fixtures": {}}
+    quant = engine or inplay_engine_from_env()
+    out: Dict[str, Any] = {}
+    for row in fixtures or []:
+        if not row.get("is_live"):
+            continue
+        fid = str(row.get("id") or "")
+        if not fid:
+            continue
+        snap = quant.tick_fixture(row)
+        if not snap:
+            continue
+        risk = quant.evaluate_execution(row, snap)
+        out[fid] = {
+            "prediction": snap.as_dict(),
+            "risk": {
+                "suspended": risk.suspended,
+                "suspend_reason": risk.suspend_reason,
+                "signals": [
+                    {
+                        "outcome": s.outcome,
+                        "edge": s.edge,
+                        "approved": s.approved,
+                        "kelly": s.kelly,
+                    }
+                    for s in risk.signals
+                ],
+            },
+        }
+    return {"enabled": True, "fixtures": out, "count": len(out)}
diff --git a/src/hibs_predictor/inplay/intensity.py b/src/hibs_predictor/inplay/intensity.py
