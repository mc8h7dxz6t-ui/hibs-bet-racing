+"""Tests for live in-play CTMC probability engine."""
+
+from __future__ import annotations
+
+import numpy as np
+
+from hibs_predictor.inplay.ctmc import aggregate_1x2, build_score_generator, solve_terminal_1x2_ctmc
+from hibs_predictor.inplay.engine import InplayQuantEngine, InplayEngineConfig
+from hibs_predictor.inplay.features import extract_live_features
+from hibs_predictor.inplay.intensity import compute_intensities, time_decay_factor
+from hibs_predictor.inplay.monte_carlo import simulate_terminal_1x2_mc
+from hibs_predictor.inplay.risk import evaluate_risk, high_danger_state
+from hibs_predictor.inplay.state import MatchState, PitchZone, match_state_from_fixture, prematch_prior_from_fixture
+
+
+def _live_fixture(**overrides):
+    base = {
+        "id": "99001",
+        "is_live": True,
+        "live_minute": 67,
+        "live_score_home": 1,
+        "live_score_away": 0,
+        "live_status": "2H",
+        "live_xg_home": 1.45,
+        "live_xg_away": 0.82,
+        "home": "Hibs",
+        "away": "Hearts",
+        "league_code": "SCOTLAND",
+        "prediction": {"expected_goals_home": 1.55, "expected_goals_away": 1.05},
+        "best_odds_1x2": {"home": 1.72, "draw": 3.8, "away": 5.2},
+        "live_stats": {
+            "rows": [
+                {"label": "Possession", "home": "58%", "away": "42%"},
+                {"label": "Corner kicks", "home": 6, "away": 3},
+                {"label": "Shots on goal", "home": 5, "away": 2},
+            ]
+        },
+    }
+    base.update(overrides)
+    return base
+
+
+def test_match_state_from_fixture():
+    state = match_state_from_fixture(_live_fixture())
+    assert state.goals_home == 1
+    assert state.goals_away == 0
+    assert state.minute == 67
+    assert state.possession == PitchZone.HOME
+
+
+def test_time_decay_has_late_match_spike():
+    d89 = time_decay_factor(89.0)
+    d20 = time_decay_factor(20.0)
+    assert d89 > d20
+
+
+def test_intensities_respond_to_red_card():
+    state = MatchState(goals_home=0, goals_away=0, red_home=1, minute=30.0)
+    prior = prematch_prior_from_fixture(_live_fixture())
+    feats = extract_live_features(_live_fixture(), state)
+    lam_h, lam_a, _ = compute_intensities(state, prior, feats)
+    state_ok = MatchState(goals_home=0, goals_away=0, minute=30.0)
+    lam_h_ok, lam_a_ok, _ = compute_intensities(state_ok, prior, feats)
+    assert lam_h < lam_h_ok
+    assert lam_a > lam_a_ok
+
+
+def test_ctmc_probs_sum_to_one():
+    state = MatchState(goals_home=1, goals_away=1, minute=70.0, match_minutes=95.0)
+    probs, meta = solve_terminal_1x2_ctmc(state, lam_h_remaining=0.9, lam_a_remaining=0.8)
+    assert meta["method"] == "ctmc_matrix_exp"
+    assert abs(sum(probs.values()) - 1.0) < 1e-6
+    assert all(v >= 0 for v in probs.values())
+
+
+def test_ctmc_leading_team_has_higher_win_prob():
+    state = MatchState(goals_home=2, goals_away=0, minute=80.0, match_minutes=95.0)
+    probs, _ = solve_terminal_1x2_ctmc(state, lam_h_remaining=0.25, lam_a_remaining=0.55)
+    assert probs["home"] > probs["away"]
+
+
+def test_monte_carlo_probs_sum_to_one():
+    state = MatchState(goals_home=0, goals_away=0, minute=10.0, match_minutes=95.0)
+    probs, meta = simulate_terminal_1x2_mc(state, 1.4, 1.1, n_paths=5000, seed=42)
+    assert meta["paths"] == 5000
+    assert abs(sum(probs.values()) - 1.0) < 0.02
+
+
+def test_generator_rows_sum_zero():
+    q = build_score_generator(5, 0.03, 0.025)
+    assert np.allclose(q.sum(axis=1), 0.0, atol=1e-12)
+
+
+def test_aggregate_1x2_distribution():
+    n = 4
+    dist = np.zeros(n * n)
+    dist[1 * n + 0] = 0.5  # 1-0 home win
+    dist[0 * n + 1] = 0.5  # 0-1 away win
+    probs = aggregate_1x2(dist, n)
+    assert abs(probs["home"] - 0.5) < 1e-9
+    assert abs(probs["away"] - 0.5) < 1e-9
+
+
+def test_quant_engine_attaches_prediction(monkeypatch):
+    monkeypatch.setenv("HIBS_INPLAY_ENABLED", "1")
+    row = _live_fixture()
+    engine = InplayQuantEngine(config=InplayEngineConfig(solver="ctmc", mc_paths=1000))
+    assert engine.attach_to_fixture(row) is True
+    pred = row.get("inplay_prediction") or {}
+    assert pred.get("probabilities_pct", {}).get("home", 0) > 50
+
+
+def test_risk_var_suspension():
+    row = _live_fixture(live_status="VAR", live_last_event={"detail": "VAR check"})
+    assert high_danger_state(row) == "var_review"
+    decision = evaluate_risk(
+        "99001",
+        {"home": 0.5, "draw": 0.25, "away": 0.25},
+        {"home": 2.0, "draw": 3.5, "away": 4.0},
+        row=row,
+    )
+    assert decision.suspended is True
+
+
+def test_risk_detects_positive_edge():
+    row = _live_fixture()
+    decision = evaluate_risk(
+        "99001",
+        {"home": 0.72, "draw": 0.16, "away": 0.12},
+        {"home": 1.72, "draw": 3.8, "away": 5.2},
+        row=row,
+    )
+    assert decision.suspended is False
+    assert any(s.approved for s in decision.signals)
