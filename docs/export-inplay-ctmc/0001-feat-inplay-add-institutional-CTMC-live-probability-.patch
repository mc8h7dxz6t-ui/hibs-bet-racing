@@ -0,0 +1,134 @@
+"""Fractional Kelly, suspension gates, and information-asymmetry filters."""
+
+from __future__ import annotations
+
+import os
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Optional
+
+from hibs_predictor.betting_engine import OddsAnalyzer
+
+
+@dataclass
+class RiskConfig:
+    kelly_fraction: float = 0.25
+    min_edge: float = 0.025
+    max_stake_pct: float = 10.0
+    min_liquidity: float = 500.0
+    max_spread_pct: float = 4.0
+    fee_pct: float = 0.02
+    suspend_on_var: bool = True
+    suspend_on_penalty: bool = True
+
+
+@dataclass
+class TradeSignal:
+    outcome: str
+    model_prob: float
+    market_prob: float
+    edge: float
+    decimal_odds: float
+    kelly: Dict[str, Any]
+    approved: bool
+    reason: str = ""
+
+
+@dataclass
+class RiskDecision:
+    fixture_id: str
+    suspended: bool
+    suspend_reason: str = ""
+    signals: List[TradeSignal] = field(default_factory=list)
+    meta: Dict[str, Any] = field(default_factory=dict)
+
+
+def risk_config_from_env() -> RiskConfig:
+    def _f(name: str, default: float) -> float:
+        try:
+            return float(os.getenv(name, str(default)))
+        except ValueError:
+            return default
+
+    return RiskConfig(
+        kelly_fraction=_f("HIBS_INPLAY_KELLY_FRACTION", 0.25),
+        min_edge=_f("HIBS_INPLAY_MIN_EDGE", 0.025),
+        max_stake_pct=_f("HIBS_INPLAY_MAX_STAKE_PCT", 10.0),
+        min_liquidity=_f("HIBS_INPLAY_MIN_LIQUIDITY", 500.0),
+        max_spread_pct=_f("HIBS_INPLAY_MAX_SPREAD_PCT", 4.0),
+        fee_pct=_f("HIBS_INPLAY_FEE_PCT", 0.02),
+        suspend_on_var=os.getenv("HIBS_INPLAY_SUSPEND_VAR", "1").strip().lower() not in ("0", "false", "no"),
+        suspend_on_penalty=os.getenv("HIBS_INPLAY_SUSPEND_PENALTY", "1").strip().lower() not in ("0", "false", "no"),
+    )
+
+
+def high_danger_state(row: Dict[str, Any]) -> Optional[str]:
+    """Information asymmetry filter — freeze during VAR / penalties."""
+    status = str(row.get("live_status") or row.get("live_status_long") or "").upper()
+    if "VAR" in status:
+        return "var_review"
+    ev = row.get("live_last_event") if isinstance(row.get("live_last_event"), dict) else {}
+    detail = str(ev.get("detail") or ev.get("type") or "").lower()
+    if "penalty" in detail:
+        return "penalty_sequence"
+    if "var" in detail:
+        return "var_review"
+    return None
+
+
+def evaluate_risk(
+    fixture_id: str,
+    model_probs: Dict[str, float],
+    market_odds: Dict[str, float],
+    *,
+    row: Optional[Dict[str, Any]] = None,
+    liquidity: Optional[float] = None,
+    spread_pct: Optional[float] = None,
+    config: Optional[RiskConfig] = None,
+) -> RiskDecision:
+    cfg = config or risk_config_from_env()
+    row = row or {}
+    danger = high_danger_state(row)
+    if danger and (
+        (danger == "var_review" and cfg.suspend_on_var)
+        or (danger == "penalty_sequence" and cfg.suspend_on_penalty)
+    ):
+        return RiskDecision(fixture_id=fixture_id, suspended=True, suspend_reason=danger)
+
+    if liquidity is not None and liquidity < cfg.min_liquidity:
+        return RiskDecision(
+            fixture_id=fixture_id,
+            suspended=True,
+            suspend_reason="low_liquidity",
+            meta={"liquidity": liquidity},
+        )
+    if spread_pct is not None and spread_pct > cfg.max_spread_pct:
+        return RiskDecision(
+            fixture_id=fixture_id,
+            suspended=True,
+            suspend_reason="spread_too_wide",
+            meta={"spread_pct": spread_pct},
+        )
+
+    signals: List[TradeSignal] = []
+    for outcome, model_p in model_probs.items():
+        odds = market_odds.get(outcome)
+        if odds is None or odds <= 1.0:
+            continue
+        market_p = 1.0 / odds
+        edge = model_p - market_p - cfg.fee_pct
+        kelly = OddsAnalyzer.kelly_criterion(model_p, odds, fraction=cfg.kelly_fraction)
+        approved = edge >= cfg.min_edge and kelly.get("suggested_percent", 0) > 0
+        reason = "edge_ok" if approved else "edge_below_threshold"
+        signals.append(
+            TradeSignal(
+                outcome=outcome,
+                model_prob=round(model_p, 4),
+                market_prob=round(market_p, 4),
+                edge=round(edge, 4),
+                decimal_odds=odds,
+                kelly=kelly,
+                approved=approved,
+                reason=reason,
+            )
+        )
+    return RiskDecision(fixture_id=fixture_id, suspended=False, signals=signals)
