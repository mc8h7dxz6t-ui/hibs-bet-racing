index 0000000..dfc1177
--- /dev/null
+++ b/src/hibs_predictor/inplay/features.py
@@ -0,0 +1,235 @@
+"""Live feature engineering for rolling Poisson intensities."""
+
+from __future__ import annotations
+
+import math
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Optional
+
+from hibs_predictor.inplay.state import MatchState, PitchZone
+
+
+@dataclass
+class LiveFeatureVector:
+    """f_i(t) inputs to log-linear intensity model."""
+
+    xg_momentum_home: float = 0.0
+    xg_momentum_away: float = 0.0
+    xg_divergence: float = 0.0
+    possession_tilt: float = 0.0
+    corner_pressure_home: float = 0.0
+    corner_pressure_away: float = 0.0
+    shots_on_momentum_home: float = 0.0
+    shots_on_momentum_away: float = 0.0
+    score_state_pressure: float = 0.0
+    red_card_home_penalty: float = 0.0
+    red_card_away_penalty: float = 0.0
+    meta: Dict[str, Any] = field(default_factory=dict)
+
+    def as_list(self) -> List[float]:
+        return [
+            self.xg_momentum_home,
+            self.xg_momentum_away,
+            self.xg_divergence,
+            self.possession_tilt,
+            self.corner_pressure_home,
+            self.corner_pressure_away,
+            self.shots_on_momentum_home,
+            self.shots_on_momentum_away,
+            self.score_state_pressure,
+            self.red_card_home_penalty,
+            self.red_card_away_penalty,
+        ]
+
+    def as_dict(self) -> Dict[str, Any]:
+        keys = (
+            "xg_momentum_home",
+            "xg_momentum_away",
+            "xg_divergence",
+            "possession_tilt",
+            "corner_pressure_home",
+            "corner_pressure_away",
+            "shots_on_momentum_home",
+            "shots_on_momentum_away",
+            "score_state_pressure",
+            "red_card_home_penalty",
+            "red_card_away_penalty",
+        )
+        out = {k: round(getattr(self, k), 4) for k in keys}
+        if self.meta:
+            out["meta"] = self.meta
+        return out
+
+
+def default_feature_weights() -> List[float]:
+    """ML-ready weights w_i (hand-tuned v1; swap via env/JSON in production)."""
+    return [
+        0.35,  # xg_momentum_home
+        0.35,  # xg_momentum_away
+        0.22,  # xg_divergence
+        0.18,  # possession_tilt
+        0.12,  # corner_pressure_home
+        0.12,  # corner_pressure_away
+        0.10,  # shots_on_momentum_home
+        0.10,  # shots_on_momentum_away
+        0.08,  # score_state_pressure
+        -0.55,  # red_card_home_penalty (reduces home scoring)
+        -0.55,  # red_card_away_penalty
+    ]
+
+
+def extract_live_features(
+    row: Dict[str, Any],
+    state: MatchState,
+    *,
+    history: Optional[List[Dict[str, Any]]] = None,
+    window_minutes: float = 5.0,
+) -> LiveFeatureVector:
+    """Compute rolling live metrics from fixture row + optional tick history."""
+    xg_h = _float_or_none(row.get("live_xg_home"))
+    xg_a = _float_or_none(row.get("live_xg_away"))
+    stats = _stats_map(row)
+    poss_h = stats.get("possession")
+    poss_a = stats.get("possession_away")
+    corners_h = stats.get("corners")
+    corners_a = stats.get("corners_away")
+    shots_h = stats.get("shots_on")
+    shots_a = stats.get("shots_on_away")
+
+    hist = history or []
+    xg_m_h, xg_m_a = _rolling_xg_momentum(hist, xg_h, xg_a, window_minutes=window_minutes)
+    s_m_h, s_m_a = _rolling_stat_momentum(hist, "shots_on", shots_h, shots_a, window_minutes)
+
+    minute = max(1.0, float(state.minute or 1.0))
+    xg_div = 0.0
+    if xg_h is not None and xg_a is not None:
+        xg_div = (xg_h - xg_a) / minute
+
+    poss_tilt = 0.0
+    if poss_h is not None and poss_a is not None:
+        poss_tilt = (poss_h - poss_a) / 100.0
+
+    corner_h = (corners_h or 0.0) / minute
+    corner_a = (corners_a or 0.0) / minute
+
+    score_diff = state.goals_home - state.goals_away
+    score_pressure = math.tanh(score_diff / 1.5)
+
+    red_h_pen = -1.0 if state.red_home else 0.0
+    red_a_pen = -1.0 if state.red_away else 0.0
+
+    zone_boost = 0.0
+    if state.possession == PitchZone.HOME:
+        zone_boost = 0.05
+    elif state.possession == PitchZone.AWAY:
+        zone_boost = -0.05
+
+    return LiveFeatureVector(
+        xg_momentum_home=xg_m_h,
+        xg_momentum_away=xg_m_a,
+        xg_divergence=xg_div + zone_boost,
+        possession_tilt=poss_tilt,
+        corner_pressure_home=corner_h,
+        corner_pressure_away=corner_a,
+        shots_on_momentum_home=s_m_h,
+        shots_on_momentum_away=s_m_a,
+        score_state_pressure=score_pressure,
+        red_card_home_penalty=red_h_pen,
+        red_card_away_penalty=red_a_pen,
+        meta={
+            "minute": state.minute,
+            "window_minutes": window_minutes,
+            "live_xg_home": xg_h,
+            "live_xg_away": xg_a,
+        },
+    )
+
+
+def _stats_map(row: Dict[str, Any]) -> Dict[str, float]:
+    stats = row.get("live_stats") if isinstance(row.get("live_stats"), dict) else {}
+    rows = stats.get("rows") if isinstance(stats.get("rows"), list) else []
+    out: Dict[str, float] = {}
+    for item in rows:
+        if not isinstance(item, dict):
+            continue
+        label = str(item.get("label") or "").lower()
+        home = _parse_stat(item.get("home"))
+        away = _parse_stat(item.get("away"))
+        if "possession" in label:
+            out["possession"] = home
+            out["possession_away"] = away
+        elif "corner" in label:
+            out["corners"] = home
+            out["corners_away"] = away
+        elif "shots on" in label:
+            out["shots_on"] = home
+            out["shots_on_away"] = away
+    return out
+
+
+def _parse_stat(value: Any) -> Optional[float]:
+    if value is None:
+        return None
+    text = str(value).strip().rstrip("%")
+    if not text or text == "-":
+        return None
+    try:
+        return float(text)
+    except ValueError:
+        return None
+
+
+def _float_or_none(value: Any) -> Optional[float]:
+    try:
+        return float(value) if value is not None else None
+    except (TypeError, ValueError):
+        return None
+
+
+def _rolling_xg_momentum(
+    history: List[Dict[str, Any]],
+    xg_h: Optional[float],
+    xg_a: Optional[float],
+    *,
+    window_minutes: float,
+) -> tuple[float, float]:
+    if xg_h is None or xg_a is None or len(history) < 2:
+        return 0.0, 0.0
+    recent = [h for h in history if _within_window(h, window_minutes)]
+    if len(recent) < 2:
+        return 0.0, 0.0
+    first = recent[0]
+    last = recent[-1]
+    dt = max(0.5, float(last.get("minute", 0)) - float(first.get("minute", 0)))
+    dh = float(last.get("live_xg_home", xg_h)) - float(first.get("live_xg_home", xg_h))
+    da = float(last.get("live_xg_away", xg_a)) - float(first.get("live_xg_away", xg_a))
+    return dh / dt, da / dt
+
+
+def _rolling_stat_momentum(
+    history: List[Dict[str, Any]],
+    key: str,
+    current_h: Optional[float],
+    current_a: Optional[float],
+    window_minutes: float,
+) -> tuple[float, float]:
+    if current_h is None or current_a is None or len(history) < 2:
+        return 0.0, 0.0
+    recent = [h for h in history if _within_window(h, window_minutes)]
+    if len(recent) < 2:
+        return 0.0, 0.0
+    first, last = recent[0], recent[-1]
+    dt = max(0.5, float(last.get("minute", 0)) - float(first.get("minute", 0)))
+    fh = float(first.get(key + "_home", current_h))
+    fa = float(first.get(key + "_away", current_a))
+    lh = float(last.get(key + "_home", current_h))
+    la = float(last.get(key + "_away", current_a))
+    return (lh - fh) / dt, (la - fa) / dt
+
+
+def _within_window(snapshot: Dict[str, Any], window_minutes: float) -> bool:
+    try:
+        age = float(snapshot.get("age_minutes", 0))
+    except (TypeError, ValueError):
+        age = 0.0
+    return age <= window_minutes
