+"""Match state vector X(t) for the in-play CTMC."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from enum import Enum
+from typing import Any, Dict, Optional
+
+
+class PitchZone(str, Enum):
+    HOME = "H"
+    AWAY = "A"
+    NEUTRAL = "N"
+
+
+@dataclass(frozen=True)
+class MatchState:
+    """X(t) = (G_H, G_A, P, R_H, R_A) at elapsed minute t."""
+
+    goals_home: int = 0
+    goals_away: int = 0
+    possession: PitchZone = PitchZone.NEUTRAL
+    red_home: int = 0
+    red_away: int = 0
+    minute: float = 0.0
+    match_minutes: float = 95.0
+
+    @property
+    def minutes_remaining(self) -> float:
+        return max(0.0, float(self.match_minutes) - float(self.minute))
+
+    def as_dict(self) -> Dict[str, Any]:
+        return {
+            "goals_home": self.goals_home,
+            "goals_away": self.goals_away,
+            "possession": self.possession.value,
+            "red_home": self.red_home,
+            "red_away": self.red_away,
+            "minute": round(float(self.minute), 2),
+            "minutes_remaining": round(self.minutes_remaining, 2),
+        }
+
+
+@dataclass
+class PrematchPrior:
+    """Pre-match λ inputs (α, β, γ) from the offline engine."""
+
+    lambda_home: float
+    lambda_away: float
+    league_code: str = ""
+    home_team: str = ""
+    away_team: str = ""
+    gamma_home: float = 1.06
+    gamma_away: float = 0.96
+    fixture_id: str = ""
+    meta: Dict[str, Any] = field(default_factory=dict)
+
+
+def match_state_from_fixture(row: Dict[str, Any], *, match_minutes: float = 95.0) -> MatchState:
+    """Build MatchState from a dashboard fixture row with live_* fields."""
+    gh = row.get("live_score_home")
+    ga = row.get("live_score_away")
+    if gh is None or ga is None:
+        score = str(row.get("live_score") or "")
+        if "-" in score:
+            parts = score.split("-", 1)
+            try:
+                gh = int(parts[0].strip())
+                ga = int(parts[1].strip())
+            except ValueError:
+                gh = ga = 0
+        else:
+            gh = ga = 0
+    minute_raw = row.get("live_minute")
+    try:
+        minute = float(minute_raw) if minute_raw is not None else 0.0
+    except (TypeError, ValueError):
+        minute = 0.0
+    reds = _red_cards_from_row(row)
+    possession = _possession_zone_from_stats(row)
+    return MatchState(
+        goals_home=max(0, int(gh or 0)),
+        goals_away=max(0, int(ga or 0)),
+        possession=possession,
+        red_home=reds[0],
+        red_away=reds[1],
+        minute=minute,
+        match_minutes=match_minutes,
+    )
+
+
+def prematch_prior_from_fixture(row: Dict[str, Any]) -> PrematchPrior:
+    """Extract baseline intensities from pre-match prediction payload."""
+    pred = row.get("prediction") if isinstance(row.get("prediction"), dict) else {}
+    lam_h = pred.get("expected_goals_home")
+    lam_a = pred.get("expected_goals_away")
+    if lam_h is None:
+        lam_h = row.get("xg_home")
+    if lam_a is None:
+        lam_a = row.get("xg_away")
+    try:
+        lam_h_f = max(0.12, float(lam_h or 1.35))
+        lam_a_f = max(0.12, float(lam_a or 1.15))
+    except (TypeError, ValueError):
+        lam_h_f, lam_a_f = 1.35, 1.15
+    return PrematchPrior(
+        lambda_home=lam_h_f,
+        lambda_away=lam_a_f,
+        league_code=str(row.get("league_code") or row.get("league") or ""),
+        home_team=str(row.get("home") or ""),
+        away_team=str(row.get("away") or ""),
+        fixture_id=str(row.get("id") or ""),
+        meta={"source": "fixture_prediction"},
+    )
+
+
+def _red_cards_from_row(row: Dict[str, Any]) -> tuple[int, int]:
+    stats = row.get("live_stats") if isinstance(row.get("live_stats"), dict) else {}
+    rows = stats.get("rows") if isinstance(stats.get("rows"), list) else []
+    rh = ra = 0
+    for item in rows:
+        if not isinstance(item, dict):
+            continue
+        label = str(item.get("label") or "").lower()
+        if "red" not in label:
+            continue
+        try:
+            rh = int(item.get("home") or 0)
+            ra = int(item.get("away") or 0)
+        except (TypeError, ValueError):
+            continue
+        break
+    ev = row.get("live_last_event") if isinstance(row.get("live_last_event"), dict) else {}
+    detail = str(ev.get("detail") or ev.get("type") or "").lower()
+    if "red card" in detail:
+        team = str(ev.get("team") or "").lower()
+        home = str(row.get("home") or "").lower()
+        if team and home and team in home:
+            rh = max(rh, 1)
+        else:
+            ra = max(ra, 1)
+    return rh, ra
+
+
+def _possession_zone_from_stats(row: Dict[str, Any]) -> PitchZone:
+    stats = row.get("live_stats") if isinstance(row.get("live_stats"), dict) else {}
+    rows = stats.get("rows") if isinstance(stats.get("rows"), list) else []
+    poss_h = poss_a = None
+    for item in rows:
+        if not isinstance(item, dict):
+            continue
+        if str(item.get("label") or "").lower() != "possession":
+            continue
+        poss_h = _parse_pct(item.get("home"))
+        poss_a = _parse_pct(item.get("away"))
+        break
+    if poss_h is None or poss_a is None:
+        return PitchZone.NEUTRAL
+    if poss_h - poss_a >= 8.0:
+        return PitchZone.HOME
+    if poss_a - poss_h >= 8.0:
+        return PitchZone.AWAY
+    return PitchZone.NEUTRAL
+
+
+def _parse_pct(value: Any) -> Optional[float]:
+    if value is None:
+        return None
+    text = str(value).strip().rstrip("%")
+    if not text or text == "-":
+        return None
+    try:
+        return float(text)
+    except ValueError:
+        return None
