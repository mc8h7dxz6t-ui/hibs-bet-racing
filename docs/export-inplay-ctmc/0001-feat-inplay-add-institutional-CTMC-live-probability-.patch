+++ b/src/hibs_predictor/inplay/event_stack.py
@@ -0,0 +1,86 @@
+"""Redis-backed event stack with in-memory fallback for live tick history."""
+
+from __future__ import annotations
+
+import json
+import os
+import time
+from collections import deque
+from dataclasses import dataclass, field
+from typing import Any, Deque, Dict, List, Optional
+
+
+@dataclass
+class EventStackConfig:
+    redis_url: str = ""
+    max_ticks_per_fixture: int = 120
+    ttl_sec: int = 7200
+
+
+class EventStack:
+    """
+    Append-only tick ring per fixture_id.
+    Production: Redis LIST/ZSET; dev: in-process deque.
+    """
+
+    def __init__(self, config: Optional[EventStackConfig] = None):
+        cfg = config or EventStackConfig(
+            redis_url=(os.getenv("HIBS_INPLAY_REDIS_URL") or "").strip(),
+        )
+        self._cfg = cfg
+        self._memory: Dict[str, Deque[Dict[str, Any]]] = {}
+        self._redis = None
+        if cfg.redis_url:
+            try:
+                import redis  # type: ignore
+
+                self._redis = redis.from_url(cfg.redis_url, decode_responses=True)
+            except Exception:
+                self._redis = None
+
+    def push_tick(self, fixture_id: str, payload: Dict[str, Any]) -> None:
+        fid = str(fixture_id)
+        row = dict(payload)
+        row["ts"] = time.time()
+        if self._redis is not None:
+            key = f"hibs:inplay:ticks:{fid}"
+            self._redis.lpush(key, json.dumps(row, default=str))
+            self._redis.ltrim(key, 0, self._cfg.max_ticks_per_fixture - 1)
+            self._redis.expire(key, self._cfg.ttl_sec)
+            return
+        ring = self._memory.setdefault(fid, deque(maxlen=self._cfg.max_ticks_per_fixture))
+        ring.appendleft(row)
+
+    def history(self, fixture_id: str, *, limit: int = 40) -> List[Dict[str, Any]]:
+        fid = str(fixture_id)
+        if self._redis is not None:
+            key = f"hibs:inplay:ticks:{fid}"
+            raw = self._redis.lrange(key, 0, max(0, limit - 1))
+            out: List[Dict[str, Any]] = []
+            for item in raw:
+                try:
+                    out.append(json.loads(item))
+                except json.JSONDecodeError:
+                    continue
+            return out
+        ring = self._memory.get(fid)
+        if not ring:
+            return []
+        return list(ring)[:limit]
+
+    def latest(self, fixture_id: str) -> Optional[Dict[str, Any]]:
+        hist = self.history(fixture_id, limit=1)
+        return hist[0] if hist else None
+
+    def push_event(self, fixture_id: str, event: Dict[str, Any]) -> None:
+        """Structured match event (goal, card, sub) onto the stack."""
+        self.push_tick(
+            fixture_id,
+            {"type": "event", "event": event, "minute": event.get("minute")},
+        )
+
+    def stats(self) -> Dict[str, Any]:
+        return {
+            "backend": "redis" if self._redis is not None else "memory",
+            "fixtures_tracked": len(self._memory) if self._redis is None else None,
+        }
