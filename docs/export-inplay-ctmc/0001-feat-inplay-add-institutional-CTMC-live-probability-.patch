index 0000000..0b8fb71
--- /dev/null
+++ b/src/hibs_predictor/inplay/intensity.py
@@ -0,0 +1,116 @@
+"""Non-homogeneous Poisson hazard rates λ_H(t), λ_A(t)."""
+
+from __future__ import annotations
+
+import math
+import os
+from typing import List, Optional, Tuple
+
+from hibs_predictor.calibrated_lambdas import league_home_away_multipliers
+from hibs_predictor.inplay.features import LiveFeatureVector, default_feature_weights
+from hibs_predictor.inplay.state import MatchState, PrematchPrior
+
+
+def _env_float(name: str, default: float) -> float:
+    try:
+        return float(os.getenv(name, str(default)))
+    except ValueError:
+        return default
+
+
+def time_decay_factor(minute: float, *, match_minutes: float = 95.0) -> float:
+    """
+    δ(t): historical scoring escalation — elevated around 44' and 89'.
+    """
+    t = max(0.0, min(float(minute), match_minutes)) / max(match_minutes, 1.0)
+    base = 0.82 + 0.28 * t
+    spike44 = 0.22 * math.exp(-((minute - 44.0) ** 2) / (2.0 * 6.0**2))
+    spike89 = 0.32 * math.exp(-((minute - 89.0) ** 2) / (2.0 * 5.0**2))
+    ht_dip = -0.08 * math.exp(-((minute - 45.0) ** 2) / (2.0 * 4.0**2))
+    return max(0.35, base + spike44 + spike89 + ht_dip)
+
+
+def red_card_multiplier(red_home: int, red_away: int) -> Tuple[float, float]:
+    """Scale intensities when a team is down to ten (or fewer) men."""
+    home_pen = 0.72 ** max(0, red_home)
+    away_pen = 0.72 ** max(0, red_away)
+    # Opponent boost when other side has red
+    if red_away:
+        home_pen *= 1.12
+    if red_home:
+        away_pen *= 1.12
+    return home_pen, away_pen
+
+
+def score_state_intensity_nudge(state: MatchState) -> Tuple[float, float]:
+    """
+    Trailing team presses; leading team sits — mild intensity nudge.
+    """
+    diff = state.goals_home - state.goals_away
+    if diff == 0:
+        return 1.0, 1.0
+    if diff > 0:
+        return 0.94, 1.08
+    return 1.08, 0.94
+
+
+def compute_intensities(
+    state: MatchState,
+    prior: PrematchPrior,
+    features: LiveFeatureVector,
+    *,
+    weights: Optional[List[float]] = None,
+) -> Tuple[float, float, dict]:
+    """
+    λ_H(t) = α_H · β_A · γ_home · δ(t) · exp(Σ w_i f_i) · adjustments
+    Returns (λ_home_per_match, λ_away_per_match, debug).
+    """
+    w = weights or default_feature_weights()
+    feats = features.as_list()
+    log_term = 0.0
+    for wi, fi in zip(w, feats):
+        log_term += wi * fi
+    log_term = max(-2.5, min(2.5, log_term))
+
+    gamma_h, gamma_a = league_home_away_multipliers(prior.league_code)
+    if prior.gamma_home:
+        gamma_h = prior.gamma_home
+    if prior.gamma_away:
+        gamma_a = prior.gamma_away
+
+    alpha_h = max(0.12, float(prior.lambda_home))
+    beta_a = max(0.12, float(prior.lambda_away))
+    delta = time_decay_factor(state.minute, match_minutes=state.match_minutes)
+
+    red_h, red_a = red_card_multiplier(state.red_home, state.red_away)
+    score_h, score_a = score_state_intensity_nudge(state)
+
+    lam_h = alpha_h * gamma_h * delta * math.exp(log_term) * red_h * score_h
+    lam_a = beta_a * gamma_a * delta * math.exp(-log_term * 0.85) * red_a * score_a
+
+    floor = _env_float("HIBS_INPLAY_LAMBDA_FLOOR", 0.05)
+    cap = _env_float("HIBS_INPLAY_LAMBDA_CAP", 4.5)
+    lam_h = max(floor, min(cap, lam_h))
+    lam_a = max(floor, min(cap, lam_a))
+
+    remaining = state.minutes_remaining
+    scale = remaining / max(state.match_minutes, 1.0)
+    lam_h_rem = lam_h * scale
+    lam_a_rem = lam_a * scale
+
+    debug = {
+        "alpha_home": round(alpha_h, 4),
+        "beta_away": round(beta_a, 4),
+        "gamma_home": round(gamma_h, 4),
+        "gamma_away": round(gamma_a, 4),
+        "delta_t": round(delta, 4),
+        "log_feature_term": round(log_term, 4),
+        "red_multiplier_home": round(red_h, 4),
+        "red_multiplier_away": round(red_a, 4),
+        "lambda_home_full_match": round(lam_h, 4),
+        "lambda_away_full_match": round(lam_a, 4),
+        "lambda_home_remaining": round(lam_h_rem, 4),
+        "lambda_away_remaining": round(lam_a_rem, 4),
+        "minutes_remaining": round(remaining, 2),
+    }
+    return lam_h_rem, lam_a_rem, debug
