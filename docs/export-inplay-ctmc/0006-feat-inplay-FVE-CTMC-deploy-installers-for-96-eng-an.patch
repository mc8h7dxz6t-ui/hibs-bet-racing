+#!/usr/bin/env bash
+# Arm local CTMC in-play lane on main VPS — systemd worker + evidence env (paper only).
+#
+#   cd /opt/hibs-bet && git pull   # must include src/hibs_predictor/inplay/
+#   sudo bash scripts/install_inplay_vps.sh
+set -euo pipefail
+
+APP="${DEPLOY_PATH:-/opt/hibs-bet}"
+
+if [[ "$(id -u)" -ne 0 ]]; then
+  echo "Run as root: sudo bash $0" >&2
+  exit 1
+fi
+
+if [[ ! -f "${APP}/src/hibs_predictor/inplay/engine.py" ]]; then
+  echo "ERROR: CTMC inplay package missing — merge cursor/live-inplay-ctmc-engine-7e4d first." >&2
+  echo "  Mac: git am ~/hibs-racing/docs/export-inplay-ctmc/*.patch && git push" >&2
+  exit 1
+fi
+
+step() { echo ""; echo "========== $* =========="; }
+
+step "1) Env — paper lane + evidence window"
+touch "${APP}/.env"
+upsert() {
+  local key="$1" val="$2"
+  if grep -q "^${key}=" "${APP}/.env" 2>/dev/null; then
+    sed -i "s|^${key}=.*|${key}=${val}|" "${APP}/.env"
+  else
+    echo "${key}=${val}" >>"${APP}/.env"
+  fi
+}
+upsert HIBS_INPLAY_ENABLED 1
+upsert HIBS_INPLAY_EXECUTE paper
+upsert HIBS_INPLAY_WORKER_EXECUTE 1
+upsert HIBS_INPLAY_FETCH_MARKS 1
+upsert HIBS_INPLAY_WORKER_REQUIRED 1
+upsert HIBS_INPLAY_ARCHIVE_TICKS 1
+upsert HIBS_INPLAY_SUSPEND_VAR 1
+upsert HIBS_INPLAY_KERNEL 1
+upsert HIBS_INPLAY_KELLY_FRACTION 0.25
+upsert HIBS_INPLAY_EVIDENCE_DB "${APP}/data/inplay_evidence.sqlite"
+upsert HIBS_INPLAY_TICK_ARCHIVE "${APP}/data/inplay_ticks.sqlite"
+upsert HIBS_HEALTH_INPLAY_PROBE 1
+grep -q '^HIBS_EVIDENCE_DEPLOY_DATE=' "${APP}/.env" 2>/dev/null || \
+  upsert HIBS_EVIDENCE_DEPLOY_DATE "$(date -u +%Y-%m-%d)"
+chown www-data:www-data "${APP}/.env"
+chmod 640 "${APP}/.env"
+
+step "2) Data dirs"
+mkdir -p "${APP}/data" "${APP}/logs" "${APP}/.cache"
+chown -R www-data:www-data "${APP}/data" "${APP}/logs" "${APP}/.cache"
+
+step "3) Rust kernel (optional — score gate)"
+if command -v cargo >/dev/null 2>&1; then
+  if sudo -u www-data bash "${APP}/scripts/build_inplay_kernel.sh" 2>/dev/null; then
+    echo "Rust kernel built"
+  else
+    echo "WARN: Rust build failed — set HIBS_INPLAY_KERNEL=0 or install rustup" >&2
+    upsert HIBS_INPLAY_KERNEL 0
+  fi
+else
+  echo "WARN: cargo not found — HIBS_INPLAY_KERNEL=0"
+  upsert HIBS_INPLAY_KERNEL 0
+fi
+
+step "4) systemd hibs-inplay-worker"
+cp "${APP}/deploy/hibs-inplay-worker.service" /etc/systemd/system/hibs-inplay-worker.service
+systemctl daemon-reload
+systemctl enable hibs-inplay-worker.service
+systemctl restart hibs-inplay-worker.service
+sleep 3
+
+step "5) Scorecard + evidence gates"
+export DEPLOY_PATH="${APP}" PYTHONPATH="${APP}/src" HOME="${APP}"
+sudo -u www-data env DEPLOY_PATH="${APP}" PYTHONPATH="${APP}/src" HOME="${APP}" \
+  bash "${APP}/scripts/score_inplay_institutional.sh" || true
+sudo -u www-data env DEPLOY_PATH="${APP}" PYTHONPATH="${APP}/src" HOME="${APP}" \
+  bash "${APP}/scripts/verify_inplay_evidence_gates.sh" || true
+
+cat <<EOF
+
+========== IN-PLAY CTMC ARMED (paper) ==========
+Worker:  systemctl status hibs-inplay-worker
+Score:   bash scripts/score_inplay_institutional.sh   (target 96%)
+Evidence: bash scripts/verify_inplay_evidence_gates.sh  (I1–I5 calendar)
+API:     curl -sS http://127.0.0.1:8000/api/inplay/readiness | python3 -m json.tool | head
+
+Engineering 96% needs: worker heartbeat fresh, kernel built OR KERNEL=0, no circuit open.
+buyer_ready (I1–I5) accumulates over live matchdays — hands-off, no dashboard loads.
+EOF
