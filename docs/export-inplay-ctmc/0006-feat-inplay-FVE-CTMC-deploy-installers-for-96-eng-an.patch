+#!/usr/bin/env bash
+# One-shot: FVE line shopper + local CTMC in-play (96% engineering + I1–I5 evidence).
+#
+# Prereq: CTMC branch on /opt/hibs-bet (src/hibs_predictor/inplay/).
+#
+# Step 1 — FVE box (77.68.89.75), paste bootstrap from:
+#   bash scripts/install_fve_lines_stack.sh --print-fve
+#
+# Step 2 — Main VPS (77.68.89.73):
+#   cd /opt/hibs-bet && git pull   # or git am patches for CTMC branch
+#   sudo bash scripts/install_fve_inplay_evidence_stack.sh
+set -euo pipefail
+
+APP="${DEPLOY_PATH:-/opt/hibs-bet}"
+FVE_HOST="${FVE_REMOTE_HOST:-77.68.89.75}"
+
+[[ "$(id -u)" -eq 0 ]] || { echo "run as root on main VPS" >&2; exit 1; }
+
+echo "========== FVE line shopper (main VPS wire) =========="
+bash "${APP}/scripts/install_fve_lines_stack.sh" --main || {
+  echo "WARN: FVE not reachable at ${FVE_HOST} — finish bootstrap on FVE box first" >&2
+  bash "${APP}/scripts/install_fve_lines_stack.sh" --print-fve
+}
+
+echo ""
+echo "========== CTMC in-play worker (local evidence) =========="
+bash "${APP}/scripts/install_inplay_vps.sh"
+
+echo ""
+echo "========== Re-arm hands-off (includes watchdog repair) =========="
+bash "${APP}/scripts/install_hands_off_automation.sh"
+
+echo ""
+echo "========== Verify four-stack evidence =========="
+bash "${APP}/scripts/install_fve_lines_stack.sh" --verify || true
+bash "${APP}/scripts/score_inplay_institutional.sh" || true
+bash "${APP}/scripts/verify_inplay_evidence_gates.sh" || true
+
+cat <<EOF
+
+========== TARGET STATE ==========
+Line shopper:  https://hibs-bet.co.uk/line-trader  (FVE reachable + worker_live)
+In-play eng:   score_inplay_institutional.sh >= 96% (A++)
+In-play evid:  verify_inplay_evidence_gates.sh — I1–I5 accumulate on WC live matches
+Hands-off:     30m cycle repairs worker + seeds football F7
+
+FVE down? Re-run bootstrap on .75 then: sudo bash scripts/install_fve_lines_stack.sh --main
+EOF
