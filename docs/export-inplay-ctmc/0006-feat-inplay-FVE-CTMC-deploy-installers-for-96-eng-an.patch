--- /dev/null
+++ b/deploy/hibs-inplay-worker.service
@@ -0,0 +1,33 @@
+# In-play CTMC quant worker — 15s tick loop, paper execution, evidence accumulation.
+#
+# Install:
+#   sudo bash /opt/hibs-bet/scripts/install_inplay_vps.sh
+[Unit]
+Description=hibs-bet in-play CTMC quant worker
+Documentation=file:/opt/hibs-bet/docs/INPLAY_INSTITUTIONAL_SCORECARD.md
+After=network-online.target hibs-bet.service
+Wants=network-online.target
+
+[Service]
+Type=simple
+User=www-data
+Group=www-data
+WorkingDirectory=/opt/hibs-bet
+Environment=HOME=/opt/hibs-bet
+Environment=PYTHONPATH=/opt/hibs-bet/src
+EnvironmentFile=-/opt/hibs-bet/.env
+Environment=HIBS_INPLAY_ENABLED=1
+Environment=HIBS_INPLAY_WORKER_REQUIRED=1
+Environment=HIBS_INPLAY_ARCHIVE_TICKS=1
+Environment=HIBS_INPLAY_SUSPEND_VAR=1
+Environment=HIBS_INPLAY_TICK_SEC=15
+ExecStart=/opt/hibs-bet/scripts/run_inplay_quant_worker.sh
+Restart=on-failure
+RestartSec=10
+TimeoutStopSec=30
+StandardOutput=journal
+StandardError=journal
+SyslogIdentifier=hibs-inplay-worker
+
+[Install]
+WantedBy=multi-user.target
