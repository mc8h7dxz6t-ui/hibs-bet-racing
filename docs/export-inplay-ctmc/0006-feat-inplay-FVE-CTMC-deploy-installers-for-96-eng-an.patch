+#!/usr/bin/env bash
+# FVE line shopper — two-VPS installer helper (run sections on the right host).
+#
+# FVE box (77.68.89.75) — as root:
+#   curl -fsSL https://raw.githubusercontent.com/mc8h7dxz6t-ui/hibs-bet/main/deploy/ops-bootstrap-fve-vps.sh | sudo \
+#     HIBS_MAIN_IP=77.68.89.73 HIBS_UPSTREAM_BASE_URL=https://hibs-bet.co.uk bash
+#
+# Main VPS (77.68.89.73) — as root:
+#   sudo FVE_REMOTE_HOST=77.68.89.75 bash /opt/hibs-bet/scripts/install_fve_lines_stack.sh --main
+#
+# Verify both:
+#   bash /opt/hibs-bet/scripts/install_fve_lines_stack.sh --verify
+set -euo pipefail
+
+APP="${DEPLOY_PATH:-/opt/hibs-bet}"
+FVE_HOST="${FVE_REMOTE_HOST:-77.68.89.75}"
+FVE_PORT="${FVE_API_PORT:-8010}"
+PUBLIC="${HIBS_PUBLIC_HOST:-hibs-bet.co.uk}"
+
+usage() {
+  cat <<EOF
+Usage:
+  $0 --main      Wire main VPS nginx + .env to remote FVE (run on 77.68.89.73)
+  $0 --verify    Probe FVE direct + public proxy + hibs status
+  $0 --print-fve Print bootstrap one-liner for FVE box
+EOF
+}
+
+verify_all() {
+  local ok=0
+  echo "==> Direct FVE ${FVE_HOST}:${FVE_PORT}/health"
+  if curl -fsS --max-time 8 "http://${FVE_HOST}:${FVE_PORT}/health" | head -c 200; then
+    echo ""
+  else
+    echo "FAIL"
+    ok=1
+  fi
+  echo "==> Public https://${PUBLIC}/fve-api/health"
+  if curl -fsS --max-time 12 "https://${PUBLIC}/fve-api/health" | head -c 200; then
+    echo ""
+  else
+    echo "FAIL"
+    ok=1
+  fi
+  echo "==> hibs /api/fve/status"
+  curl -fsS --max-time 12 "http://127.0.0.1:8000/api/fve/status" 2>/dev/null | \
+    python3 -c "import sys,json; d=json.load(sys.stdin); print('reachable',d.get('reachable'),'worker_live',d.get('worker_live'),'paused',d.get('paused'))" || ok=1
+  return "${ok}"
+}
+
+print_fve() {
+  cat <<EOF
+Run on FVE VPS (${FVE_HOST}):
+
+curl -fsSL https://raw.githubusercontent.com/mc8h7dxz6t-ui/hibs-bet/main/deploy/ops-bootstrap-fve-vps.sh | sudo \\
+  HIBS_MAIN_IP=77.68.89.73 \\
+  HIBS_UPSTREAM_BASE_URL=https://hibs-bet.co.uk \\
+  HIBS_FVE_RAW_BRANCH=main \\
+  bash
+EOF
+}
+
+case "${1:-}" in
+  --main)
+    [[ "$(id -u)" -eq 0 ]] || { echo "run as root" >&2; exit 1; }
+    FVE_REMOTE_HOST="${FVE_HOST}" HIBS_PUBLIC_HOST="${PUBLIC}" DEPLOY_PATH="${APP}" \
+      bash "${APP}/deploy/apply-vps-fve-remote-host.sh"
+    verify_all || exit 1
+    ;;
+  --verify) verify_all ;;
+  --print-fve) print_fve ;;
+  -h|--help|"") usage ;;
+  *) usage; exit 1 ;;
+esac
