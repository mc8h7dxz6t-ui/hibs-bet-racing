+def _opta_payload(fixture_id: int = 12345, msg_type: int = 7, seq: int = 99) -> bytes:
+    body = bytes([0, 67, 1])  # home goal min 67
+    header = struct.pack("<HQI", msg_type, seq, fixture_id)
+    return header + body
+
+
+def _sr_payload(match_id: int = 555, msg_type: int = 3, ts_ms: int = 1700000000) -> bytes:
+    body = bytes([1, 23, 1])
+    header = struct.pack("<B H Q I", 1, msg_type, ts_ms, match_id)
+    return header + body
+
+
+@pytest.mark.skipif(not kernel_available(), reason="rust kernel not built")
+def test_rust_kernel_intensity_fast():
+    lam_h, lam_a, meta = rust_intensity(
+        alpha_home=1.4,
+        beta_away=1.1,
+        gamma_home=1.06,
+        gamma_away=0.96,
+        minute=55.0,
+        match_minutes=95.0,
+        features=[0.1] * 13,
+        weights=HAND_TUNED_WEIGHTS,
+        red_home=0,
+        red_away=0,
+        goals_home=1,
+        goals_away=0,
+    )
+    assert lam_h > 0 and lam_a > 0
+    assert meta.get("kernel") == "rust"
+    assert int(meta.get("elapsed_us") or 0) < 50000
+
