index 0000000..fb7d3a9
--- /dev/null
+++ b/src/hibs_predictor/inplay/tick_archive.py
@@ -0,0 +1,136 @@
+"""Persistent tick archive for ML weight training."""
+
+from __future__ import annotations
+
+import json
+import os
+import sqlite3
+import time
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+
+
+def archive_path() -> Path:
+    raw = (os.getenv("HIBS_INPLAY_TICK_ARCHIVE") or "").strip()
+    if raw:
+        return Path(raw)
+    root = Path(__file__).resolve().parents[3]
+    return root / "data" / "inplay_tick_archive.sqlite"
+
+
+def _connect() -> sqlite3.Connection:
+    path = archive_path()
+    path.parent.mkdir(parents=True, exist_ok=True)
+    conn = sqlite3.connect(str(path))
+    conn.row_factory = sqlite3.Row
+    conn.execute(
+        """
+        CREATE TABLE IF NOT EXISTS inplay_ticks (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            fixture_id TEXT NOT NULL,
+            ts REAL NOT NULL,
+            minute REAL,
+            goals_home INTEGER,
+            goals_away INTEGER,
+            features_json TEXT NOT NULL,
+            lambda_home REAL,
+            lambda_away REAL,
+            outcome_home INTEGER,
+            outcome_draw INTEGER,
+            outcome_away INTEGER,
+            label_1x2 TEXT
+        )
+        """
+    )
+    conn.execute("CREATE INDEX IF NOT EXISTS idx_inplay_fixture_ts ON inplay_ticks(fixture_id, ts)")
+    conn.commit()
+    return conn
+
+
+def append_tick(
+    fixture_id: str,
+    *,
+    minute: float,
+    goals_home: int,
+    goals_away: int,
+    features: Dict[str, Any],
+    lambda_home: float,
+    lambda_away: float,
+    probabilities: Optional[Dict[str, float]] = None,
+    label_1x2: Optional[str] = None,
+) -> None:
+    if os.getenv("HIBS_INPLAY_ARCHIVE_TICKS", "1").strip().lower() in ("0", "false", "no", "off"):
+        return
+    probs = probabilities or {}
+    with _connect() as conn:
+        conn.execute(
+            """
+            INSERT INTO inplay_ticks
+            (fixture_id, ts, minute, goals_home, goals_away, features_json,
+             lambda_home, lambda_away, outcome_home, outcome_draw, outcome_away, label_1x2)
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+            """,
+            (
+                str(fixture_id),
+                time.time(),
+                minute,
+                goals_home,
+                goals_away,
+                json.dumps(features, default=str),
+                lambda_home,
+                lambda_away,
+                probs.get("home"),
+                probs.get("draw"),
+                probs.get("away"),
+                label_1x2,
+            ),
+        )
+        conn.commit()
+
+
+def load_training_rows(*, limit: int = 50000) -> List[Dict[str, Any]]:
+    with _connect() as conn:
+        rows = conn.execute(
+            """
+            SELECT fixture_id, minute, goals_home, goals_away, features_json,
+                   lambda_home, lambda_away, label_1x2
+            FROM inplay_ticks
+            WHERE label_1x2 IS NOT NULL
+            ORDER BY id DESC
+            LIMIT ?
+            """,
+            (limit,),
+        ).fetchall()
+    out: List[Dict[str, Any]] = []
+    for row in rows:
+        try:
+            feats = json.loads(row["features_json"])
+        except json.JSONDecodeError:
+            feats = {}
+        out.append(
+            {
+                "fixture_id": row["fixture_id"],
+                "minute": row["minute"],
+                "goals_home": row["goals_home"],
+                "goals_away": row["goals_away"],
+                "features": feats,
+                "lambda_home": row["lambda_home"],
+                "lambda_away": row["lambda_away"],
+                "label_1x2": row["label_1x2"],
+            }
+        )
+    return out
+
+
+def label_finished_fixture(fixture_id: str, *, result: str) -> int:
+    """Backfill label on archived ticks after FT (home|draw|away)."""
+    result = result.strip().lower()
+    if result not in ("home", "draw", "away"):
+        return 0
+    with _connect() as conn:
+        cur = conn.execute(
+            "UPDATE inplay_ticks SET label_1x2 = ? WHERE fixture_id = ? AND label_1x2 IS NULL",
+            (result, str(fixture_id)),
+        )
+        conn.commit()
+        return int(cur.rowcount or 0)
diff --git a/src/hibs_predictor/inplay/venues/__init__.py b/src/hibs_predictor/inplay/venues/__init__.py
new file mode 100644
index 0000000..6a456e7
--- /dev/null
+++ b/src/hibs_predictor/inplay/venues/__init__.py
@@ -0,0 +1,331 @@
+"""Exchange venue adapters — Betfair, Matchbook, Pinnacle."""
+
+from __future__ import annotations
+
+import json
+import os
+import uuid
+from abc import ABC, abstractmethod
+from typing import Any, Dict, List, Optional
+
+import requests
+
+from hibs_predictor.inplay.venues.fix_codec import build_new_order_single
+
+
+class VenueAdapter(ABC):
+    name: str
+
+    @abstractmethod
+    def get_1x2_odds(self, fixture_id: str) -> Dict[str, float]: ...
+
+    @abstractmethod
+    def submit_back(
+        self,
+        *,
+        fixture_id: str,
+        outcome: str,
+        decimal_odds: float,
+        stake: float,
+        meta: Optional[Dict[str, Any]] = None,
+    ) -> Dict[str, Any]: ...
+
+
+class BetfairAdapter(VenueAdapter):
+    name = "betfair"
+
+    def __init__(self) -> None:
+        self.app_key = (os.getenv("BETFAIR_APP_KEY") or os.getenv("BETFAIR_APPLICATION_KEY") or "").strip()
+        self.session = (os.getenv("BETFAIR_SESSION_TOKEN") or "").strip()
+        self.api = (os.getenv("BETFAIR_API_URL") or "https://api.betfair.com/exchange/betting/rest/v1.0").strip()
+        self.timeout = float(os.getenv("HIBS_INPLAY_VENUE_TIMEOUT", "8"))
+
+    def _headers(self) -> Dict[str, str]:
+        return {
+            "X-Application": self.app_key,
+            "X-Authentication": self.session,
+            "Content-Type": "application/json",
+            "Accept": "application/json",
+        }
+
+    def get_1x2_odds(self, fixture_id: str) -> Dict[str, float]:
+        market_id = self._market_map().get(str(fixture_id))
+        if not market_id or not self.app_key or not self.session:
+            return {}
+        resp = requests.post(
+            f"{self.api}/listMarketBook/",
+            headers=self._headers(),
+            json={"marketIds": [market_id], "priceProjection": {"priceData": ["EX_BEST_OFFERS"]}},
+            timeout=self.timeout,
+        )
+        if resp.status_code != 200:
+            return {}
+        data = resp.json()
+        if not isinstance(data, list) or not data:
+            return {}
+        runners = (data[0] or {}).get("runners") or []
+        return self._runners_to_1x2(runners)
+
+    def submit_back(
+        self,
+        *,
+        fixture_id: str,
+        outcome: str,
+        decimal_odds: float,
+        stake: float,
+        meta: Optional[Dict[str, Any]] = None,
+    ) -> Dict[str, Any]:
+        market_id = self._market_map().get(str(fixture_id))
+        selection_id = self._selection_map(str(fixture_id), outcome)
+        if not market_id or not selection_id:
+            return {"venue": self.name, "status": "rejected", "reason": "market_map_missing"}
+        if not self.app_key or not self.session:
+            return {"venue": self.name, "status": "rejected", "reason": "credentials_missing"}
+        cl_id = str(uuid.uuid4())
+        fix_msg = build_new_order_single(
+            cl_ord_id=cl_id,
+            symbol=market_id,
+            side="back",
+            qty=stake,
+            price=decimal_odds,
+        )
+        payload = {
+            "marketId": market_id,
+            "instructions": [
+                {
+                    "selectionId": selection_id,
+                    "side": "BACK",
+                    "orderType": "LIMIT",
+                    "limitOrder": {"size": stake, "price": decimal_odds, "persistenceType": "LAPSE"},
+                }
+            ],
+            "customerRef": cl_id[:32],
+        }
+        resp = requests.post(
+            f"{self.api}/placeOrders/",
+            headers=self._headers(),
+            json=payload,
+            timeout=self.timeout,
+        )
+        return {
+            "venue": self.name,
+            "status": "submitted" if resp.status_code == 200 else "error",
+            "http_status": resp.status_code,
+            "fix_preview": fix_msg.encode()[:120].decode("ascii", errors="replace"),
+            "response": resp.json() if resp.content else {},
+        }
+
+    def _market_map(self) -> Dict[str, str]:
+        return _json_map_env("HIBS_BETFAIR_MARKET_MAP_JSON")
+
+    def _selection_map(self, fixture_id: str, outcome: str) -> Optional[int]:
+        data = _json_map_env("HIBS_BETFAIR_SELECTION_MAP_JSON")
+        val = data.get(f"{fixture_id}:{outcome.lower()}")
+        try:
+            return int(val) if val is not None else None
+        except (TypeError, ValueError):
+            return None
+
+    @staticmethod
+    def _runners_to_1x2(runners: List[Dict[str, Any]]) -> Dict[str, float]:
+        odds: Dict[str, float] = {}
+        for i, runner in enumerate(runners[:3]):
+            ex = runner.get("ex") if isinstance(runner.get("ex"), dict) else {}
+            backs = ex.get("availableToBack") or []
+            if not backs:
+                continue
+            try:
+                price = float(backs[0].get("price"))
+            except (TypeError, ValueError, IndexError):
+                continue
+            key = ("home", "draw", "away")[min(i, 2)]
+            odds[key] = price
+        return odds
+
+
+class MatchbookAdapter(VenueAdapter):
+    name = "matchbook"
+
+    def __init__(self) -> None:
+        self.user = (os.getenv("MATCHBOOK_USERNAME") or "").strip()
+        self.pwd = (os.getenv("MATCHBOOK_PASSWORD") or "").strip()
+        self.base = (os.getenv("MATCHBOOK_API_BASE") or "https://api.matchbook.com/edge/rest").strip()
+        self.token: Optional[str] = None
+        self.timeout = float(os.getenv("HIBS_INPLAY_VENUE_TIMEOUT", "8"))
+
+    def _login(self) -> None:
+        resp = requests.post(
+            f"{self.base}/security/session",
+            json={"username": self.user, "password": self.pwd},
+            headers={"Accept": "application/json", "Content-Type": "application/json"},
+            timeout=self.timeout,
+        )
+        resp.raise_for_status()
+        self.token = str(resp.json().get("session-token") or resp.cookies.get("session-token") or "")
+
+    def _headers(self) -> Dict[str, str]:
+        if not self.token:
+            self._login()
+        return {"Accept": "application/json", "session-token": self.token or ""}
+
+    def get_1x2_odds(self, fixture_id: str) -> Dict[str, float]:
+        event_id = self._event_map().get(str(fixture_id))
+        if not event_id or not self.user or not self.pwd:
+            return {}
+        resp = requests.get(
+            f"{self.base}/events/{event_id}",
+            headers=self._headers(),
+            params={"include-prices": "true", "odds-type": "DECIMAL"},
+            timeout=self.timeout,
+        )
+        if resp.status_code != 200:
+            return {}
+        markets = resp.json().get("markets") or []
+        for market in markets:
+            if str(market.get("name") or "").lower() in ("match odds", "1x2", "win-draw-win"):
+                return self._market_prices(market)
+        return {}
+
+    def submit_back(
+        self,
+        *,
+        fixture_id: str,
+        outcome: str,
+        decimal_odds: float,
+        stake: float,
+        meta: Optional[Dict[str, Any]] = None,
+    ) -> Dict[str, Any]:
+        runner_id = self._runner_map(str(fixture_id), outcome)
+        if not runner_id:
+            return {"venue": self.name, "status": "rejected", "reason": "runner_map_missing"}
+        if not self.user or not self.pwd:
+            return {"venue": self.name, "status": "rejected", "reason": "credentials_missing"}
+        offer = {
+            "runner-id": runner_id,
+            "side": "back",
+            "odds": decimal_odds,
+            "stake": stake,
+            "keep-in-play": True,
+        }
+        resp = requests.post(
+            f"{self.base}/v2/offers",
+            headers={**self._headers(), "Content-Type": "application/json"},
+            json={"odds-type": "DECIMAL", "exchange-type": "back-lay", "offers": [offer]},
+            timeout=self.timeout,
+        )
+        return {
+            "venue": self.name,
+            "status": "submitted" if resp.status_code in (200, 201) else "error",
+            "http_status": resp.status_code,
+            "response": resp.json() if resp.content else {},
+        }
+
+    def _event_map(self) -> Dict[str, str]:
+        return _json_map_env("HIBS_MATCHBOOK_EVENT_MAP_JSON")
+
+    def _runner_map(self, fixture_id: str, outcome: str) -> Optional[int]:
+        data = _json_map_env("HIBS_MATCHBOOK_RUNNER_MAP_JSON")
+        val = data.get(f"{fixture_id}:{outcome.lower()}")
+        try:
+            return int(val) if val is not None else None
+        except (TypeError, ValueError):
+            return None
+
+    @staticmethod
+    def _market_prices(market: Dict[str, Any]) -> Dict[str, float]:
+        odds: Dict[str, float] = {}
+        runners = market.get("runners") or []
+        for i, runner in enumerate(runners[:3]):
+            prices = runner.get("prices") or []
+            back = next((p for p in prices if str(p.get("side") or "").lower() == "back"), None)
+            if not back:
+                continue
+            try:
+                val = float(back.get("odds"))
+            except (TypeError, ValueError):
+                continue
+            odds[("home", "draw", "away")[min(i, 2)]] = val
+        return odds
+
+
+class PinnacleAdapter(VenueAdapter):
+    name = "pinnacle"
+
+    def __init__(self) -> None:
+        self.api = (os.getenv("PINNACLE_API_URL") or "https://api.pinnacle.com").strip()
+        self.user = (os.getenv("PINNACLE_USERNAME") or "").strip()
+        self.pwd = (os.getenv("PINNACLE_PASSWORD") or "").strip()
+        self.timeout = float(os.getenv("HIBS_INPLAY_VENUE_TIMEOUT", "8"))
+
+    def get_1x2_odds(self, fixture_id: str) -> Dict[str, float]:
+        event_id = _json_map_env("HIBS_PINNACLE_EVENT_MAP_JSON").get(str(fixture_id))
+        if not event_id or not self.user or not self.pwd:
+            return {}
+        resp = requests.get(
+            f"{self.api}/v1/odds",
+            params={"sportId": 29, "eventIds": event_id, "oddsFormat": "Decimal"},
+            auth=(self.user, self.pwd),
+            timeout=self.timeout,
+        )
+        if resp.status_code != 200:
+            return {}
+        data = resp.json()
+        leagues = data.get("leagues") if isinstance(data, dict) else []
+        for league in leagues or []:
+            for event in league.get("events") or []:
+                for period in event.get("periods") or []:
+                    if str(period.get("number")) != "0":
+                        continue
+                    moneyline = period.get("moneyline") if isinstance(period.get("moneyline"), dict) else {}
+                    out: Dict[str, float] = {}
+                    for side, key in (("home", "home"), ("draw", "draw"), ("away", "away")):
+                        try:
+                            out[side] = float(moneyline.get(key))
+                        except (TypeError, ValueError):
+                            continue
+                    return out
+        return {}
+
+    def submit_back(
+        self,
+        *,
+        fixture_id: str,
+        outcome: str,
+        decimal_odds: float,
+        stake: float,
+        meta: Optional[Dict[str, Any]] = None,
+    ) -> Dict[str, Any]:
+        cl_id = str(uuid.uuid4())
+        fix_msg = build_new_order_single(
+            cl_ord_id=cl_id,
+            symbol=str(fixture_id),
+            side=outcome,
+            qty=stake,
+            price=decimal_odds,
+        )
+        return {
+            "venue": self.name,
+            "status": "fix_preview",
+            "message": "Pinnacle write requires licensed FIX session",
+            "fix": fix_msg.encode().decode("ascii", errors="replace"),
+        }
+
+
+def _json_map_env(name: str) -> Dict[str, str]:
+    raw = (os.getenv(name) or "{}").strip()
+    try:
+        data = json.loads(raw)
+        return {str(k): str(v) for k, v in data.items()} if isinstance(data, dict) else {}
+    except json.JSONDecodeError:
+        return {}
+
+
+def adapter_for(venue: str) -> VenueAdapter:
+    v = venue.strip().lower()
+    if v == "betfair":
+        return BetfairAdapter()
+    if v == "matchbook":
+        return MatchbookAdapter()
+    if v == "pinnacle":
+        return PinnacleAdapter()
+    raise ValueError(f"unknown venue: {venue}")
diff --git a/src/hibs_predictor/inplay/venues/fix_codec.py b/src/hibs_predictor/inplay/venues/fix_codec.py
new file mode 100644
index 0000000..663c24b
--- /dev/null
+++ b/src/hibs_predictor/inplay/venues/fix_codec.py
@@ -0,0 +1,60 @@
+"""Minimal FIX 4.4 subset + venue REST adapters."""
+
+from __future__ import annotations
+
+import time
+import uuid
+from dataclasses import dataclass
+from typing import Any, Dict, Optional
+
+
+@dataclass
+class FixMessage:
+    msg_type: str
+    fields: Dict[str, str]
+    raw: str
+
+    def encode(self) -> bytes:
+        parts = [f"8=FIX.4.4|35={self.msg_type}"]
+        for tag, value in sorted(self.fields.items(), key=lambda kv: int(kv[0])):
+            parts.append(f"{tag}={value}")
+        body = "|".join(parts)
+        checksum = sum(ord(c) for c in body) % 256
+        return f"{body}|10={checksum:03d}".encode("ascii")
+
+
+def build_new_order_single(
+    *,
+    cl_ord_id: str,
+    symbol: str,
+    side: str,
+    qty: float,
+    price: float,
+) -> FixMessage:
+    return FixMessage(
+        msg_type="D",
+        fields={
+            "11": cl_ord_id,
+            "55": symbol,
+            "54": "1" if side.lower() in ("buy", "back", "home", "draw", "away") else "2",
+            "38": f"{qty:.2f}",
+            "44": f"{price:.4f}",
+            "59": "0",
+            "60": time.strftime("%Y%m%d-%H:%M:%S"),
+        },
+        raw="",
+    )
+
+
+def parse_fix_payload(payload: bytes) -> FixMessage:
+    text = payload.decode("ascii", errors="replace")
+    fields: Dict[str, str] = {}
+    msg_type = "0"
+    for part in text.split("|"):
+        if "=" not in part:
+            continue
+        tag, val = part.split("=", 1)
+        if tag == "35":
+            msg_type = val
+        fields[tag] = val
+    return FixMessage(msg_type=msg_type, fields=fields, raw=text)
