diff --git a/src/hibs_predictor/inplay/sentiment.py b/src/hibs_predictor/inplay/sentiment.py
new file mode 100644
index 0000000..ae7220d
--- /dev/null
+++ b/src/hibs_predictor/inplay/sentiment.py
@@ -0,0 +1,140 @@
+"""Sentiment / shock lane — injury, red card, goal momentum from live events."""
+
+from __future__ import annotations
+
+import os
+import re
+import time
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Optional
+
+import requests
+
+_SHOCK_KEYWORDS = {
+    "injury": -0.35,
+    "substitution": -0.05,
+    "red card": -0.55,
+    "second yellow": -0.45,
+    "penalty": 0.15,
+    "var": -0.20,
+    "goal": 0.40,
+    "own goal": 0.25,
+}
+
+
+@dataclass
+class SentimentSnapshot:
+    shock_home: float = 0.0
+    shock_away: float = 0.0
+    aggregate: float = 0.0
+    headlines: List[str] = field(default_factory=list)
+    source: str = "events"
+
+    def as_dict(self) -> Dict[str, Any]:
+        return {
+            "shock_home": round(self.shock_home, 4),
+            "shock_away": round(self.shock_away, 4),
+            "aggregate": round(self.aggregate, 4),
+            "headlines": self.headlines[:5],
+            "source": self.source,
+        }
+
+
+def score_event_text(text: str) -> float:
+    t = text.lower()
+    score = 0.0
+    for kw, weight in _SHOCK_KEYWORDS.items():
+        if kw in t:
+            score += weight
+    return max(-1.0, min(1.0, score))
+
+
+def sentiment_from_fixture_row(row: Dict[str, Any]) -> SentimentSnapshot:
+    """Event-driven sentiment from live_last_event + recent goal flow."""
+    home = str(row.get("home") or "").lower()
+    away = str(row.get("away") or "").lower()
+    shock_h = shock_a = 0.0
+    headlines: List[str] = []
+
+    ev = row.get("live_last_event") if isinstance(row.get("live_last_event"), dict) else {}
+    label = str(ev.get("label") or ev.get("detail") or ev.get("type") or "")
+    if label:
+        headlines.append(label)
+        team = str(ev.get("team") or "").lower()
+        mag = score_event_text(label)
+        if team and home and team in home:
+            shock_h += mag
+        elif team and away and team in away:
+            shock_a += mag
+        else:
+            shock_h += mag * 0.5
+            shock_a += mag * 0.5
+
+    try:
+        gh = int(row.get("live_score_home") or 0)
+        ga = int(row.get("live_score_away") or 0)
+        minute = float(row.get("live_minute") or 1)
+    except (TypeError, ValueError):
+        gh = ga = 0
+        minute = 1.0
+    if minute > 0:
+        shock_h += 0.08 * (gh / minute)
+        shock_a += 0.08 * (ga / minute)
+
+    feed = _fetch_optional_headlines(row)
+    headlines.extend(feed.get("lines") or [])
+    shock_h += float(feed.get("shock_home") or 0.0)
+    shock_a += float(feed.get("shock_away") or 0.0)
+    source = "events+feed" if feed.get("lines") else "events"
+
+    return SentimentSnapshot(
+        shock_home=max(-1.0, min(1.0, shock_h)),
+        shock_away=max(-1.0, min(1.0, shock_a)),
+        aggregate=max(-1.0, min(1.0, shock_h - shock_a)),
+        headlines=headlines,
+        source=source,
+    )
+
+
+def _fetch_optional_headlines(row: Dict[str, Any]) -> Dict[str, Any]:
+    url = (os.getenv("HIBS_INPLAY_SENTIMENT_FEED_URL") or "").strip()
+    if not url:
+        return {}
+    timeout = float(os.getenv("HIBS_INPLAY_SENTIMENT_TIMEOUT", "2.5"))
+    home = str(row.get("home") or "")
+    away = str(row.get("away") or "")
+    try:
+        resp = requests.get(url, timeout=timeout, params={"home": home, "away": away})
+        resp.raise_for_status()
+        text = resp.text[:4000]
+    except requests.RequestException:
+        return {}
+    lines = _extract_shock_lines(text, home, away)
+    shock_h = shock_a = 0.0
+    for line, team in lines:
+        mag = score_event_text(line)
+        if team == "home":
+            shock_h += mag
+        elif team == "away":
+            shock_a += mag
+    return {"lines": [l for l, _ in lines[:5]], "shock_home": shock_h, "shock_away": shock_a}
+
+
+def _extract_shock_lines(text: str, home: str, away: str) -> List[tuple[str, str]]:
+    out: List[tuple[str, str]] = []
+    home_l = home.lower()
+    away_l = away.lower()
+    for raw in text.splitlines():
+        line = re.sub(r"\s+", " ", raw).strip()
+        if len(line) < 12:
+            continue
+        low = line.lower()
+        if not any(k in low for k in _SHOCK_KEYWORDS):
+            continue
+        team = "neutral"
+        if home_l and home_l in low:
+            team = "home"
+        elif away_l and away_l in low:
+            team = "away"
+        out.append((line[:160], team))
+    return out
