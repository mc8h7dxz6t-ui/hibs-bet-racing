+            )
+            debug = {
+                "alpha_home": round(alpha_h, 4),
+                "beta_away": round(beta_a, 4),
+                "gamma_home": round(gamma_h, 4),
+                "gamma_away": round(gamma_a, 4),
+                "kernel": kmeta,
+                "lambda_home_remaining": round(lam_h, 4),
+                "lambda_away_remaining": round(lam_a, 4),
+                "minutes_remaining": round(state.minutes_remaining, 2),
+            }
+            return lam_h, lam_a, debug
+        except RuntimeError:
+            pass
+
     log_term = 0.0
     for wi, fi in zip(w, feats):
         log_term += wi * fi
