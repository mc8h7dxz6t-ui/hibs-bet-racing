@@ -0,0 +1,154 @@
+"""Train log-linear intensity weights w_i from tick archive via Poisson GLM."""
+
+from __future__ import annotations
+
+import json
+import os
+from pathlib import Path
+from typing import Any, Dict, List, Optional, Tuple
+
+import numpy as np
+
+from hibs_predictor.inplay.tick_archive import load_training_rows
+
+HAND_TUNED_WEIGHTS = [
+    0.35,
+    0.35,
+    0.22,
+    0.18,
+    0.12,
+    0.12,
+    0.10,
+    0.10,
+    0.08,
+    -0.55,
+    -0.55,
+    0.12,
+    0.12,
+]
+
+FEATURE_KEYS = (
+    "xg_momentum_home",
+    "xg_momentum_away",
+    "xg_divergence",
+    "possession_tilt",
+    "corner_pressure_home",
+    "corner_pressure_away",
+    "shots_on_momentum_home",
+    "shots_on_momentum_away",
+    "score_state_pressure",
+    "red_card_home_penalty",
+    "red_card_away_penalty",
+    "sentiment_shock_home",
+    "sentiment_shock_away",
+)
+
+
+def weights_cache_path() -> Path:
+    raw = (os.getenv("HIBS_INPLAY_WEIGHTS_PATH") or "").strip()
+    if raw:
+        return Path(raw)
+    root = Path(__file__).resolve().parents[3]
+    return root / ".cache" / "inplay_weights.json"
+
+
+def load_trained_weights() -> Optional[List[float]]:
+    path = weights_cache_path()
+    if not path.is_file():
+        return None
+    try:
+        data = json.loads(path.read_text(encoding="utf-8"))
+        weights = data.get("weights")
+        if isinstance(weights, list) and len(weights) == len(FEATURE_KEYS):
+            return [float(x) for x in weights]
+    except (OSError, json.JSONDecodeError, TypeError, ValueError):
+        return None
+    return None
+
+
+def resolve_feature_weights() -> List[float]:
+    trained = load_trained_weights()
+    if trained:
+        return trained
+    base = list(HAND_TUNED_WEIGHTS)
+    # Pad for sentiment features when using hand-tuned only
+    while len(base) < len(FEATURE_KEYS):
+        base.append(0.0)
+    return base[: len(FEATURE_KEYS)]
+
+
+def train_weights(*, min_rows: int = 200) -> Dict[str, Any]:
+    rows = load_training_rows()
+    if len(rows) < min_rows:
+        return {
+            "ok": False,
+            "reason": "insufficient_labeled_rows",
+            "rows": len(rows),
+            "min_rows": min_rows,
+        }
+    x, y_home, y_away = _build_matrices(rows)
+    w_home = _fit_poisson_weights(x, y_home)
+    w_away = _fit_poisson_weights(x, y_away)
+    weights = [(a + b) / 2.0 for a, b in zip(w_home, w_away)]
+    report = {
+        "ok": True,
+        "rows": len(rows),
+        "weights": {k: round(w, 5) for k, w in zip(FEATURE_KEYS, weights)},
+        "home_weights": {k: round(w, 5) for k, w in zip(FEATURE_KEYS, w_home)},
+        "away_weights": {k: round(w, 5) for k, w in zip(FEATURE_KEYS, w_away)},
+    }
+    path = weights_cache_path()
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(
+        json.dumps({"weights": weights, "report": report}, indent=2),
+        encoding="utf-8",
+    )
+    return report
+
+
+def _build_matrices(rows: List[Dict[str, Any]]) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
+    x_rows: List[List[float]] = []
+    y_home: List[float] = []
+    y_away: List[float] = []
+    for row in rows:
+        feats = row.get("features") if isinstance(row.get("features"), dict) else {}
+        x_rows.append([float(feats.get(k, 0.0) or 0.0) for k in FEATURE_KEYS])
+        label = str(row.get("label_1x2") or "")
+        minute = max(1.0, float(row.get("minute") or 1.0))
+        gh = int(row.get("goals_home") or 0)
+        ga = int(row.get("goals_away") or 0)
+        # Proxy target: goals per remaining minute bucket
+        rem = max(1.0, 95.0 - minute)
+        if label == "home":
+            y_home.append(max(0.0, (gh + 1 - ga) / rem))
+            y_away.append(max(0.0, ga / rem))
+        elif label == "away":
+            y_home.append(max(0.0, gh / rem))
+            y_away.append(max(0.0, (ga + 1 - gh) / rem))
+        else:
+            y_home.append(max(0.0, gh / rem))
+            y_away.append(max(0.0, ga / rem))
+    return np.asarray(x_rows, dtype=float), np.asarray(y_home, dtype=float), np.asarray(y_away, dtype=float)
+
+
+def _fit_poisson_weights(x: np.ndarray, y: np.ndarray) -> List[float]:
+    try:
+        from sklearn.linear_model import PoissonRegressor
+
+        model = PoissonRegressor(alpha=0.05, max_iter=300)
+        model.fit(x, np.clip(y, 0.0, None))
+        coef = model.coef_.tolist()
+        while len(coef) < len(FEATURE_KEYS):
+            coef.append(0.0)
+        return coef[: len(FEATURE_KEYS)]
+    except Exception:
+        # Ridge fallback on log-rate targets
+        from sklearn.linear_model import Ridge
+
+        model = Ridge(alpha=1.0)
+        target = np.log1p(np.clip(y, 0.0, None))
+        model.fit(x, target)
+        coef = model.coef_.tolist()
+        while len(coef) < len(FEATURE_KEYS):
+            coef.append(0.0)
+        return coef[: len(FEATURE_KEYS)]
