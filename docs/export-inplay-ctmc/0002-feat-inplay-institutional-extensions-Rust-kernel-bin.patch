+//! Low-latency in-play kernel — intensity + batch MC + binary frame peel.
+//! JSON stdin/stdout bridge for Python orchestration.
+
+use rand::Rng;
+use rand::SeedableRng;
+use rand_distr::{Distribution, Poisson};
+use serde::{Deserialize, Serialize};
+use std::io::{self, Read};
+
+#[derive(Debug, Deserialize)]
+struct IntensityRequest {
+    alpha_home: f64,
+    beta_away: f64,
+    gamma_home: f64,
+    gamma_away: f64,
+    minute: f64,
+    match_minutes: f64,
+    features: Vec<f64>,
+    weights: Vec<f64>,
+    red_home: u8,
+    red_away: u8,
+    goals_home: i32,
+    goals_away: i32,
+}
+
+#[derive(Debug, Serialize)]
+struct IntensityResponse {
+    lambda_home_remaining: f64,
+    lambda_away_remaining: f64,
+    delta_t: f64,
+    log_feature_term: f64,
+    elapsed_us: u64,
+}
+
+#[derive(Debug, Deserialize)]
+struct McRequest {
+    goals_home: i32,
+    goals_away: i32,
+    lambda_home_remaining: f64,
+    lambda_away_remaining: f64,
+    paths: u32,
+    seed: u64,
+}
+
+#[derive(Debug, Serialize)]
+struct McResponse {
+    home: f64,
+    draw: f64,
+    away: f64,
+    paths: u32,
+    elapsed_us: u64,
+}
+
+#[derive(Debug, Deserialize)]
+struct BinaryPeelRequest {
+    vendor: String,
+    payload_hex: String,
+}
+
+#[derive(Debug, Serialize)]
+struct BinaryPeelResponse {
+    vendor: String,
+    msg_type: u16,
+    seq: u64,
+    fixture_key: String,
+    body_len: usize,
+    elapsed_us: u64,
+}
+
+#[derive(Debug, Deserialize)]
+#[serde(tag = "op")]
+enum Request {
+    intensity(IntensityRequest),
+    mc(McRequest),
+    peel(BinaryPeelRequest),
+}
+
+#[derive(Debug, Serialize)]
+#[serde(untagged)]
+enum Response {
+    Intensity(IntensityResponse),
+    Mc(McResponse),
+    Peel(BinaryPeelResponse),
+    Error { error: String },
+}
+
+fn time_decay(minute: f64, match_minutes: f64) -> f64 {
+    let t = (minute / match_minutes.max(1.0)).clamp(0.0, 1.0);
+    let base = 0.82 + 0.28 * t;
+    let spike44 = 0.22 * (-((minute - 44.0).powi(2)) / (2.0 * 36.0)).exp();
+    let spike89 = 0.32 * (-((minute - 89.0).powi(2)) / (2.0 * 25.0)).exp();
+    let ht_dip = -0.08 * (-((minute - 45.0).powi(2)) / (2.0 * 16.0)).exp();
+    (base + spike44 + spike89 + ht_dip).max(0.35)
+}
+
+fn red_mult(red: u8, opp_red: u8) -> f64 {
+    let mut m = 0.72_f64.powi(red as i32);
+    if opp_red > 0 {
+        m *= 1.12;
+    }
+    m
+}
+
+fn score_nudge(gh: i32, ga: i32) -> (f64, f64) {
+    let d = gh - ga;
+    if d == 0 {
+        (1.0, 1.0)
+    } else if d > 0 {
+        (0.94, 1.08)
+    } else {
+        (1.08, 0.94)
+    }
+}
+
+fn compute_intensity(req: IntensityRequest) -> IntensityResponse {
+    let start = std::time::Instant::now();
+    let mut log_term = 0.0;
+    for (w, f) in req.weights.iter().zip(req.features.iter()) {
+        log_term += w * f;
+    }
+    log_term = log_term.clamp(-2.5, 2.5);
+    let delta = time_decay(req.minute, req.match_minutes);
+    let (sh, sa) = score_nudge(req.goals_home, req.goals_away);
+    let rh = red_mult(req.red_home, req.red_away);
+    let ra = red_mult(req.red_away, req.red_home);
+    let mut lam_h = req.alpha_home * req.gamma_home * delta * log_term.exp() * rh * sh;
+    let mut lam_a = req.beta_away * req.gamma_away * delta * (-log_term * 0.85).exp() * ra * sa;
+    lam_h = lam_h.clamp(0.05, 4.5);
+    lam_a = lam_a.clamp(0.05, 4.5);
+    let remaining = (req.match_minutes - req.minute).max(0.0);
+    let scale = remaining / req.match_minutes.max(1.0);
+    IntensityResponse {
+        lambda_home_remaining: lam_h * scale,
+        lambda_away_remaining: lam_a * scale,
+        delta_t: delta,
+        log_feature_term: log_term,
+        elapsed_us: start.elapsed().as_micros() as u64,
+    }
+}
+
+fn simulate_mc(req: McRequest) -> McResponse {
+    let start = std::time::Instant::now();
+    let lam_h = req.lambda_home_remaining.max(0.0);
+    let lam_a = req.lambda_away_remaining.max(0.0);
+    let mut rng = rand::rngs::StdRng::seed_from_u64(req.seed);
+    let mut wins_h = 0u32;
+    let mut draws = 0u32;
+    let mut wins_a = 0u32;
+    for _ in 0..req.paths {
+        let add_h = if lam_h <= 0.0 {
+            0
+        } else {
+            Poisson::new(lam_h).map(|d| d.sample(&mut rng) as i32).unwrap_or(0)
+        };
+        let add_a = if lam_a <= 0.0 {
+            0
+        } else {
+            Poisson::new(lam_a).map(|d| d.sample(&mut rng) as i32).unwrap_or(0)
+        };
+        let fh = req.goals_home + add_h;
+        let fa = req.goals_away + add_a;
+        if fh > fa {
+            wins_h += 1;
+        } else if fh == fa {
+            draws += 1;
+        } else {
+            wins_a += 1;
+        }
+    }
+    let total = req.paths as f64;
+    McResponse {
+        home: wins_h as f64 / total,
+        draw: draws as f64 / total,
+        away: wins_a as f64 / total,
+        paths: req.paths,
+        elapsed_us: start.elapsed().as_micros() as u64,
+    }
+}
+
+fn peel_binary(vendor: &str, payload: &[u8]) -> BinaryPeelResponse {
+    let start = std::time::Instant::now();
+    let (msg_type, seq, fixture_key, body_len) = match vendor.to_lowercase().as_str() {
+        "opta" => peel_opta(payload),
+        "sportradar" | "sr" => peel_sportradar(payload),
+        _ => (0u16, 0u64, String::new(), payload.len()),
+    };
+    BinaryPeelResponse {
+        vendor: vendor.to_string(),
+        msg_type,
+        seq,
+        fixture_key,
+        body_len,
+        elapsed_us: start.elapsed().as_micros() as u64,
+    }
+}
+
+fn peel_opta(payload: &[u8]) -> (u16, u64, String, usize) {
+    if payload.len() < 14 {
+        return (0, 0, String::new(), payload.len());
+    }
+    let msg_type = u16::from_le_bytes([payload[0], payload[1]]);
+    let seq = u64::from_le_bytes([
+        payload[2], payload[3], payload[4], payload[5], payload[6], payload[7], payload[8],
+        payload[9],
+    ]);
+    let fixture_id = u32::from_le_bytes([payload[10], payload[11], payload[12], payload[13]]);
+    (msg_type, seq, format!("opta:{}", fixture_id), payload.len().saturating_sub(14))
+}
+
+fn peel_sportradar(payload: &[u8]) -> (u16, u64, String, usize) {
+    if payload.len() < 15 {
+        return (0, 0, String::new(), payload.len());
+    }
+    let msg_type = u16::from_le_bytes([payload[1], payload[2]]);
+    let ts_ms = u64::from_le_bytes([
+        payload[3], payload[4], payload[5], payload[6], payload[7], payload[8], payload[9],
+        payload[10],
+    ]);
+    let match_id = u32::from_le_bytes([payload[11], payload[12], payload[13], payload[14]]);
+    (msg_type, ts_ms, format!("sr:{}", match_id), payload.len().saturating_sub(15))
+}
+
+fn decode_hex(s: &str) -> Result<Vec<u8>, String> {
+    if s.len() % 2 != 0 {
+        return Err("odd hex length".into());
+    }
+    (0..s.len())
+        .step_by(2)
+        .map(|i| u8::from_str_radix(&s[i..i + 2], 16).map_err(|e| e.to_string()))
+        .collect()
+}
+
+fn handle(req: Request) -> Response {
+    match req {
+        Request::intensity(r) => Response::Intensity(compute_intensity(r)),
+        Request::mc(r) => Response::Mc(simulate_mc(r)),
+        Request::peel(r) => match decode_hex(&r.payload_hex) {
+            Ok(bytes) => Response::Peel(peel_binary(&r.vendor, &bytes)),
+            Err(e) => Response::Error { error: e },
+        },
+    }
+}
+
+fn main() {
+    let mut input = String::new();
+    io::stdin().read_to_string(&mut input).expect("stdin");
+    let resp = match serde_json::from_str::<Request>(&input) {
+        Ok(req) => handle(req),
+        Err(e) => Response::Error {
+            error: format!("parse: {}", e),
+        },
+    };
+    println!("{}", serde_json::to_string(&resp).expect("serialize"));
+}
