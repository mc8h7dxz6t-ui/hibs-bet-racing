@@ -0,0 +1,127 @@
+"""Bridge to Rust hibs_inplay_kernel for sub-50ms intensity + batch MC."""
+
+from __future__ import annotations
+
+import json
+import os
+import subprocess
+import time
+from pathlib import Path
+from typing import Any, Dict, List, Optional, Tuple
+
+_ROOT = Path(__file__).resolve().parents[3]
+_KERNEL_BIN = Path(
+    os.getenv(
+        "HIBS_INPLAY_KERNEL_BIN",
+        str(_ROOT / "rust" / "hibs_inplay_kernel" / "target" / "release" / "hibs_inplay_kernel"),
+    )
+)
+
+
+def kernel_available() -> bool:
+    if os.getenv("HIBS_INPLAY_KERNEL", "1").strip().lower() in ("0", "false", "no", "off"):
+        return False
+    return _KERNEL_BIN.is_file() and os.access(_KERNEL_BIN, os.X_OK)
+
+
+def _invoke(payload: Dict[str, Any], *, timeout_sec: float = 2.0) -> Dict[str, Any]:
+    if not kernel_available():
+        raise RuntimeError("rust kernel binary not available")
+    started = time.perf_counter()
+    proc = subprocess.run(
+        [str(_KERNEL_BIN)],
+        input=json.dumps(payload),
+        capture_output=True,
+        text=True,
+        timeout=timeout_sec,
+        check=False,
+    )
+    elapsed_ms = (time.perf_counter() - started) * 1000.0
+    if proc.returncode != 0:
+        raise RuntimeError(proc.stderr.strip() or f"kernel exit {proc.returncode}")
+    data = json.loads(proc.stdout)
+    if "error" in data:
+        raise RuntimeError(str(data["error"]))
+    data["_bridge_elapsed_ms"] = round(elapsed_ms, 3)
+    return data
+
+
+def rust_intensity(
+    *,
+    alpha_home: float,
+    beta_away: float,
+    gamma_home: float,
+    gamma_away: float,
+    minute: float,
+    match_minutes: float,
+    features: List[float],
+    weights: List[float],
+    red_home: int,
+    red_away: int,
+    goals_home: int,
+    goals_away: int,
+) -> Tuple[float, float, Dict[str, Any]]:
+    data = _invoke(
+        {
+            "op": "intensity",
+            "alpha_home": alpha_home,
+            "beta_away": beta_away,
+            "gamma_home": gamma_home,
+            "gamma_away": gamma_away,
+            "minute": minute,
+            "match_minutes": match_minutes,
+            "features": features,
+            "weights": weights,
+            "red_home": red_home,
+            "red_away": red_away,
+            "goals_home": goals_home,
+            "goals_away": goals_away,
+        }
+    )
+    meta = {
+        "kernel": "rust",
+        "elapsed_us": data.get("elapsed_us"),
+        "bridge_ms": data.get("_bridge_elapsed_ms"),
+        "delta_t": data.get("delta_t"),
+        "log_feature_term": data.get("log_feature_term"),
+    }
+    return float(data["lambda_home_remaining"]), float(data["lambda_away_remaining"]), meta
+
+
+def rust_mc(
+    *,
+    goals_home: int,
+    goals_away: int,
+    lambda_home_remaining: float,
+    lambda_away_remaining: float,
+    paths: int,
+    seed: int = 42,
+) -> Tuple[Dict[str, float], Dict[str, Any]]:
+    data = _invoke(
+        {
+            "op": "mc",
+            "goals_home": goals_home,
+            "goals_away": goals_away,
+            "lambda_home_remaining": lambda_home_remaining,
+            "lambda_away_remaining": lambda_away_remaining,
+            "paths": paths,
+            "seed": seed,
+        },
+        timeout_sec=max(5.0, paths / 50000.0),
+    )
+    probs = {"home": float(data["home"]), "draw": float(data["draw"]), "away": float(data["away"])}
+    meta = {
+        "method": "rust_monte_carlo",
+        "paths": paths,
+        "elapsed_us": data.get("elapsed_us"),
+        "bridge_ms": data.get("_bridge_elapsed_ms"),
+    }
+    return probs, meta
+
+
+def rust_peel_binary(vendor: str, payload: bytes) -> Dict[str, Any]:
+    data = _invoke(
+        {"op": "peel", "vendor": vendor, "payload_hex": payload.hex()},
+        timeout_sec=0.05,
+    )
+    return data
