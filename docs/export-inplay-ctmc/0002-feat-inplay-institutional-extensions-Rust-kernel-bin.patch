index 0000000..146e24e
--- /dev/null
+++ b/src/hibs_predictor/inplay/monte_carlo_gpu.py
@@ -0,0 +1,169 @@
+"""GPU / vectorised batch Monte Carlo — 100k paths per fixture."""
+
+from __future__ import annotations
+
+import os
+from typing import Dict, List, Tuple
+
+import numpy as np
+
+from hibs_predictor.inplay.kernel_bridge import kernel_available, rust_mc
+from hibs_predictor.inplay.state import MatchState
+
+
+def _env_int(name: str, default: int) -> int:
+    try:
+        return int(os.getenv(name, str(default)))
+    except ValueError:
+        return default
+
+
+def _backend() -> str:
+    forced = (os.getenv("HIBS_INPLAY_MC_BACKEND") or "auto").strip().lower()
+    if forced in ("cpu", "numpy", "rust"):
+        return forced
+    if forced == "cupy":
+        try:
+            import cupy  # noqa: F401
+
+            return "cupy"
+        except ImportError:
+            return "numpy"
+    if forced == "torch":
+        try:
+            import torch  # noqa: F401
+
+            return "torch"
+        except ImportError:
+            return "numpy"
+    if kernel_available():
+        return "rust"
+    try:
+        import cupy  # noqa: F401
+
+        return "cupy"
+    except ImportError:
+        pass
+    try:
+        import torch  # noqa: F401
+
+        return "torch"
+    except ImportError:
+        pass
+    return "numpy"
+
+
+def simulate_terminal_1x2_mc_batch(
+    state: MatchState,
+    lam_h_remaining: float,
+    lam_a_remaining: float,
+    *,
+    n_paths: int | None = None,
+    seed: int | None = None,
+) -> Tuple[Dict[str, float], Dict[str, float]]:
+    paths = n_paths if n_paths is not None else _env_int("HIBS_INPLAY_MC_PATHS", 100000)
+    remaining = max(0.0, state.minutes_remaining)
+    if remaining <= 0.0:
+        from hibs_predictor.inplay.ctmc import _terminal_from_current_score
+
+        return _terminal_from_current_score(state), {"method": "mc_terminal_score", "paths": 0}
+
+    backend = _backend()
+    if backend == "rust":
+        return rust_mc(
+            goals_home=state.goals_home,
+            goals_away=state.goals_away,
+            lambda_home_remaining=max(0.0, lam_h_remaining),
+            lambda_away_remaining=max(0.0, lam_a_remaining),
+            paths=paths,
+            seed=int(seed or 42),
+        )
+    if backend == "cupy":
+        return _mc_cupy(state, lam_h_remaining, lam_a_remaining, paths, seed)
+    if backend == "torch":
+        return _mc_torch(state, lam_h_remaining, lam_a_remaining, paths, seed)
+    return _mc_numpy(state, lam_h_remaining, lam_a_remaining, paths, seed)
+
+
+def simulate_batch_fixtures(
+    jobs: List[Tuple[MatchState, float, float]],
+    *,
+    n_paths: int | None = None,
+    seed: int | None = None,
+) -> List[Tuple[Dict[str, float], Dict[str, float]]]:
+    """Vectorise MC across fixtures (same path count each)."""
+    return [
+        simulate_terminal_1x2_mc_batch(st, lh, la, n_paths=n_paths, seed=(seed or 0) + i)
+        for i, (st, lh, la) in enumerate(jobs)
+    ]
+
+
+def _mc_numpy(
+    state: MatchState,
+    lam_h: float,
+    lam_a: float,
+    paths: int,
+    seed: int | None,
+) -> Tuple[Dict[str, float], Dict[str, float]]:
+    rng = np.random.default_rng(seed)
+    add_h = rng.poisson(max(0.0, lam_h), size=paths)
+    add_a = rng.poisson(max(0.0, lam_a), size=paths)
+    final_h = state.goals_home + add_h
+    final_a = state.goals_away + add_a
+    wins_h = np.sum(final_h > final_a)
+    draws = np.sum(final_h == final_a)
+    wins_a = np.sum(final_h < final_a)
+    total = float(paths)
+    probs = {"home": wins_h / total, "draw": draws / total, "away": wins_a / total}
+    meta = {"method": "numpy_monte_carlo", "paths": paths, "backend": "numpy"}
+    return probs, meta
+
+
+def _mc_cupy(
+    state: MatchState,
+    lam_h: float,
+    lam_a: float,
+    paths: int,
+    seed: int | None,
+) -> Tuple[Dict[str, float], Dict[str, float]]:
+    import cupy as cp
+
+    rng = cp.random.default_rng(seed)
+    add_h = rng.poisson(max(0.0, lam_h), size=paths)
+    add_a = rng.poisson(max(0.0, lam_a), size=paths)
+    final_h = state.goals_home + add_h
+    final_a = state.goals_away + add_a
+    wins_h = int(cp.sum(final_h > final_a))
+    draws = int(cp.sum(final_h == final_a))
+    wins_a = int(cp.sum(final_h < final_a))
+    total = float(paths)
+    probs = {"home": wins_h / total, "draw": draws / total, "away": wins_a / total}
+    meta = {"method": "cupy_monte_carlo", "paths": paths, "backend": "cupy"}
+    return probs, meta
+
+
+def _mc_torch(
+    state: MatchState,
+    lam_h: float,
+    lam_a: float,
+    paths: int,
+    seed: int | None,
+) -> Tuple[Dict[str, float], Dict[str, float]]:
+    import torch
+
+    gen = torch.Generator(device="cpu")
+    if seed is not None:
+        gen.manual_seed(int(seed))
+    lam_h_t = torch.tensor(max(0.0, lam_h))
+    lam_a_t = torch.tensor(max(0.0, lam_a))
+    add_h = torch.poisson(lam_h_t.expand(paths).clone(), generator=gen)
+    add_a = torch.poisson(lam_a_t.expand(paths).clone(), generator=gen)
+    final_h = state.goals_home + add_h
+    final_a = state.goals_away + add_a
+    wins_h = int(torch.sum(final_h > final_a).item())
+    draws = int(torch.sum(final_h == final_a).item())
+    wins_a = int(torch.sum(final_h < final_a).item())
+    total = float(paths)
+    probs = {"home": wins_h / total, "draw": draws / total, "away": wins_a / total}
+    meta = {"method": "torch_monte_carlo", "paths": paths, "backend": "torch"}
+    return probs, meta
