new file mode 100644
index 0000000..ec729ee
--- /dev/null
+++ b/src/hibs_predictor/inplay/feeds_binary.py
@@ -0,0 +1,153 @@
+"""Sub-millisecond binary telemetric feed handlers (Opta / Sportradar)."""
+
+from __future__ import annotations
+
+import struct
+import time
+from dataclasses import dataclass
+from enum import Enum
+from typing import Any, Dict, List, Optional, Protocol
+
+from hibs_predictor.inplay.event_stack import EventStack
+from hibs_predictor.inplay.kernel_bridge import kernel_available, rust_peel_binary
+
+
+class FeedVendor(str, Enum):
+    OPTA = "opta"
+    SPORTRADAR = "sportradar"
+
+
+@dataclass
+class BinaryFrame:
+    vendor: FeedVendor
+    msg_type: int
+    seq: int
+    fixture_key: str
+    body: bytes
+    received_ts: float
+    parse_us: Optional[int] = None
+
+    def as_event(self) -> Dict[str, Any]:
+        return {
+            "type": "binary_feed",
+            "vendor": self.vendor.value,
+            "msg_type": self.msg_type,
+            "seq": self.seq,
+            "fixture_key": self.fixture_key,
+            "body_len": len(self.body),
+            "received_ts": self.received_ts,
+            "parse_us": self.parse_us,
+        }
+
+
+class BinaryFeedHandler(Protocol):
+    vendor: FeedVendor
+
+    def peel(self, payload: bytes) -> BinaryFrame: ...
+
+
+class OptaBinaryHandler:
+    """Opta F24-style envelope: u16 type | u64 seq | u32 fixture_id | body."""
+
+    vendor = FeedVendor.OPTA
+    HEADER = struct.Struct("<HQ I")
+
+    def peel(self, payload: bytes) -> BinaryFrame:
+        started = time.perf_counter()
+        if kernel_available() and len(payload) >= 14:
+            meta = rust_peel_binary("opta", payload)
+            frame = BinaryFrame(
+                vendor=self.vendor,
+                msg_type=int(meta.get("msg_type", 0)),
+                seq=int(meta.get("seq", 0)),
+                fixture_key=str(meta.get("fixture_key", "")),
+                body=payload[14:],
+                received_ts=time.time(),
+                parse_us=int(meta.get("elapsed_us", 0)),
+            )
+            return frame
+        msg_type, seq, fixture_id = self.HEADER.unpack_from(payload[: self.HEADER.size])
+        elapsed_us = int((time.perf_counter() - started) * 1_000_000)
+        return BinaryFrame(
+            vendor=self.vendor,
+            msg_type=msg_type,
+            seq=seq,
+            fixture_key=f"opta:{fixture_id}",
+            body=payload[self.HEADER.size :],
+            received_ts=time.time(),
+            parse_us=elapsed_us,
+        )
+
+
+class SportradarBinaryHandler:
+    """Sportradar live envelope: u8 ver | u16 type | u64 ts_ms | u32 match_id | body."""
+
+    vendor = FeedVendor.SPORTRADAR
+    HEADER = struct.Struct("<B H Q I")
+
+    def peel(self, payload: bytes) -> BinaryFrame:
+        started = time.perf_counter()
+        if kernel_available() and len(payload) >= 15:
+            meta = rust_peel_binary("sportradar", payload)
+            return BinaryFrame(
+                vendor=self.vendor,
+                msg_type=int(meta.get("msg_type", 0)),
+                seq=int(meta.get("seq", 0)),
+                fixture_key=str(meta.get("fixture_key", "")),
+                body=payload[15:],
+                received_ts=time.time(),
+                parse_us=int(meta.get("elapsed_us", 0)),
+            )
+        _ver, msg_type, ts_ms, match_id = self.HEADER.unpack_from(payload[: self.HEADER.size])
+        elapsed_us = int((time.perf_counter() - started) * 1_000_000)
+        return BinaryFrame(
+            vendor=self.vendor,
+            msg_type=msg_type,
+            seq=ts_ms,
+            fixture_key=f"sr:{match_id}",
+            body=payload[self.HEADER.size :],
+            received_ts=time.time(),
+            parse_us=elapsed_us,
+        )
+
+
+def handler_for(vendor: str) -> BinaryFeedHandler:
+    v = vendor.strip().lower()
+    if v in ("opta", "statsperform", "stats_perform"):
+        return OptaBinaryHandler()
+    if v in ("sportradar", "sr", "radar"):
+        return SportradarBinaryHandler()
+    raise ValueError(f"unknown binary feed vendor: {vendor}")
+
+
+def ingest_binary_payload(
+    vendor: str,
+    payload: bytes,
+    *,
+    event_stack: Optional[EventStack] = None,
+    fixture_id: Optional[str] = None,
+) -> BinaryFrame:
+    """Parse binary frame and push to Redis/memory event stack."""
+    frame = handler_for(vendor).peel(payload)
+    fid = fixture_id or frame.fixture_key
+    stack = event_stack or EventStack()
+    stack.push_event(fid, frame.as_event())
+    if frame.body:
+        stack.push_tick(fid, {"binary_body_hex": frame.body[:256].hex(), "msg_type": frame.msg_type})
+    return frame
+
+
+def decode_goal_event_body(body: bytes) -> Dict[str, Any]:
+    """
+    Minimal body decoder for demo/test payloads:
+    [u8 team 0=home 1=away][u8 minute][u8 event_code]
+    """
+    if len(body) < 3:
+        return {}
+    team, minute, code = body[0], body[1], body[2]
+    return {
+        "team": "home" if team == 0 else "away",
+        "minute": int(minute),
+        "event_code": int(code),
+        "is_goal": code == 1,
+    }
