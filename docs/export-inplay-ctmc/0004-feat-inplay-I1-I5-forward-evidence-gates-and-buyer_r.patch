@@ -0,0 +1,137 @@
+"""I1 binary feed telemetry — seq gap detection and peel latency tracking."""
+
+from __future__ import annotations
+
+import os
+import threading
+import time
+from dataclasses import dataclass, field
+from typing import Dict, Optional, Tuple
+
+from hibs_predictor.inplay.evidence_store import record_feed_frame
+
+
+@dataclass
+class FeedTelemetry:
+    frames: int = 0
+    seq_gaps: int = 0
+    last_frame_ts: float = 0.0
+    window_start_ts: float = field(default_factory=time.time)
+    peel_us: list[int] = field(default_factory=list)
+    _last_seq: Dict[str, int] = field(default_factory=dict)
+    _lock: threading.Lock = field(default_factory=threading.Lock, repr=False)
+
+    def record(
+        self,
+        *,
+        vendor: str,
+        fixture_key: str,
+        seq: int,
+        parse_us: Optional[int],
+    ) -> int:
+        key = f"{vendor}:{fixture_key}"
+        gap = 0
+        with self._lock:
+            prev = self._last_seq.get(key)
+            if prev is not None and int(seq) > int(prev) + 1:
+                gap = int(seq) - int(prev) - 1
+                self.seq_gaps += gap
+            self._last_seq[key] = int(seq)
+            self.frames += 1
+            self.last_frame_ts = time.time()
+            if parse_us is not None:
+                self.peel_us.append(int(parse_us))
+                if len(self.peel_us) > 2000:
+                    self.peel_us = self.peel_us[-2000:]
+        try:
+            record_feed_frame(
+                vendor=vendor,
+                fixture_key=fixture_key,
+                seq=int(seq),
+                parse_us=parse_us,
+                seq_gap=gap,
+            )
+        except Exception:
+            pass
+        return gap
+
+    def uptime_pct(self, *, window_sec: float = 86400.0) -> float:
+        with self._lock:
+            now = time.time()
+            start = max(self.window_start_ts, now - window_sec)
+            if self.frames <= 0:
+                return 0.0
+            if self.last_frame_ts <= start:
+                return 0.0
+            active = self.last_frame_ts - start
+            return round(min(100.0, 100.0 * active / max(window_sec, 1.0)), 2)
+
+    def p99_peel_us(self) -> Optional[float]:
+        with self._lock:
+            if not self.peel_us:
+                return None
+            ordered = sorted(self.peel_us)
+            idx = min(len(ordered) - 1, int(0.99 * len(ordered)))
+            return float(ordered[idx])
+
+    def seq_gap_rate_pct(self) -> float:
+        with self._lock:
+            if self.frames <= 0:
+                return 0.0
+            return round(100.0 * self.seq_gaps / self.frames, 3)
+
+    def as_dict(self) -> dict:
+        with self._lock:
+            frames = self.frames
+            seq_gaps = self.seq_gaps
+            peel = list(self.peel_us)
+            last_ts = self.last_frame_ts
+            win_start = self.window_start_ts
+        seq_gap_rate = round(100.0 * seq_gaps / frames, 3) if frames else 0.0
+        p99 = None
+        if peel:
+            ordered = sorted(peel)
+            idx = min(len(ordered) - 1, int(0.99 * len(ordered)))
+            p99 = float(ordered[idx])
+        now = time.time()
+        uptime = 0.0
+        if frames > 0 and last_ts > 0:
+            start = max(win_start, now - 86400.0)
+            active = last_ts - start
+            uptime = round(min(100.0, 100.0 * active / max(86400.0, 1.0)), 2)
+        return {
+            "frames": frames,
+            "seq_gaps": seq_gaps,
+            "seq_gap_rate_pct": seq_gap_rate,
+            "p99_peel_us": p99,
+            "uptime_pct": uptime,
+            "last_frame_ts": last_ts or None,
+        }
+
+
+_FEED = FeedTelemetry()
+
+
+def get_feed_telemetry() -> FeedTelemetry:
+    return _FEED
+
+
+def ingest_uptime_pct(*, since_ts: float, window_sec: float = 86400.0) -> float:
+    """Proxy uptime when DB has frames in window."""
+    from hibs_predictor.inplay.evidence_store import _connect
+
+    try:
+        with _connect() as conn:
+            row = conn.execute(
+                "SELECT COUNT(*) AS n, MIN(ts) AS t0, MAX(ts) AS t1 FROM inplay_feed_frames WHERE ts >= ?",
+                (since_ts,),
+            ).fetchone()
+        n = int(row["n"] or 0) if row else 0
+        if n <= 0:
+            return get_feed_telemetry().uptime_pct(window_sec=window_sec)
+        t0 = float(row["t0"] or since_ts)
+        t1 = float(row["t1"] or time.time())
+        span = max(window_sec, t1 - since_ts, 1.0)
+        return round(min(100.0, 100.0 * (t1 - t0) / span), 2)
+    except Exception:
+        return get_feed_telemetry().uptime_pct(window_sec=window_sec)
