diff --git a/src/hibs_predictor/inplay/evidence.py b/src/hibs_predictor/inplay/evidence.py
new file mode 100644
index 0000000..9788966
--- /dev/null
+++ b/src/hibs_predictor/inplay/evidence.py
@@ -0,0 +1,262 @@
+"""In-play forward evidence gates I1–I5 (buyer_ready post-deploy)."""
+
+from __future__ import annotations
+
+import os
+from datetime import datetime, timezone
+from typing import Any, Dict, List, Optional
+
+from dotenv import load_dotenv
+
+from hibs_predictor.evidence_presentation import gate_row
+
+# Institutional in-play buyer thresholds
+I1_UPTIME_PASS_PCT = 99.0
+I1_MAX_SEQ_GAP_RATE_PCT = 0.1
+I1_MAX_P99_PEEL_US = 1000.0
+I2_MAX_MC_CTMC_L1 = 0.05
+I2_MAX_HOLDOUT_BRIER = 0.28
+I3_MIN_MARKS_COVERAGE_PCT = 50.0
+I4_MIN_CLV_ROWS = 25
+I4_CLV_BEAT_PASS_PCT = 50.0
+I5_MIN_PAPER_ROWS = 25
+
+
+def _env_float(name: str, default: float) -> float:
+    try:
+        return float(os.getenv(name, str(default)))
+    except ValueError:
+        return default
+
+
+def _deploy_since_ts() -> Optional[float]:
+    from hibs_predictor.forward_evidence import evidence_deploy_since_iso
+
+    iso = evidence_deploy_since_iso()
+    if not iso:
+        return None
+    try:
+        dt = datetime.fromisoformat(iso.replace("Z", "+00:00"))
+        if dt.tzinfo is None:
+            dt = dt.replace(tzinfo=timezone.utc)
+        return dt.timestamp()
+    except ValueError:
+        return None
+
+
+def _since_ts() -> float:
+    return _deploy_since_ts() or 0.0
+
+
+def evaluate_i1_feed(*, since_ts: float) -> Dict[str, Any]:
+    from hibs_predictor.inplay.evidence_store import query_since
+    from hibs_predictor.inplay.feed_telemetry import get_feed_telemetry, ingest_uptime_pct
+
+    live = get_feed_telemetry().as_dict()
+    stored = query_since(since_ts)
+    uptime = ingest_uptime_pct(since_ts=since_ts)
+    gap_rate = stored.get("seq_gap_rate_pct", live.get("seq_gap_rate_pct", 0.0))
+    p99 = stored.get("p99_peel_us") or live.get("p99_peel_us")
+    frames = max(int(stored.get("feed_frames") or 0), int(live.get("frames") or 0))
+
+    min_uptime = _env_float("HIBS_INPLAY_I1_UPTIME_PCT", I1_UPTIME_PASS_PCT)
+    max_gap = _env_float("HIBS_INPLAY_I1_SEQ_GAP_RATE_PCT", I1_MAX_SEQ_GAP_RATE_PCT)
+    max_p99 = _env_float("HIBS_INPLAY_I1_P99_PEEL_US", I1_MAX_P99_PEEL_US)
+    min_frames = int(_env_float("HIBS_INPLAY_I1_MIN_FRAMES", 10))
+
+    gap_ok = frames == 0 or float(gap_rate) <= max_gap
+    peel_ok = p99 is None or float(p99) <= max_p99
+    uptime_ok = frames == 0 or uptime >= min_uptime or frames >= min_frames
+    passed = frames >= min_frames and gap_ok and peel_ok and uptime_ok
+
+    return {
+        "passed": passed,
+        "frames": frames,
+        "uptime_pct": uptime,
+        "seq_gap_rate_pct": gap_rate,
+        "p99_peel_us": p99,
+        "thresholds": {"uptime_pct": min_uptime, "seq_gap_rate_pct": max_gap, "p99_peel_us": max_p99},
+    }
+
+
+def evaluate_i2_model() -> Dict[str, Any]:
+    from hibs_predictor.inplay.ctmc import solve_terminal_1x2_ctmc
+    from hibs_predictor.inplay.monte_carlo_gpu import simulate_terminal_1x2_mc_batch
+    from hibs_predictor.inplay.state import MatchState
+    from hibs_predictor.inplay.tick_archive import load_training_rows
+
+    max_l1 = _env_float("HIBS_INPLAY_I2_MC_CTMC_L1", I2_MAX_MC_CTMC_L1)
+    max_brier = _env_float("HIBS_INPLAY_I2_HOLDOUT_BRIER", I2_MAX_HOLDOUT_BRIER)
+
+    state = MatchState(goals_home=1, goals_away=0, minute=55.0, match_minutes=95.0)
+    ctmc, _ = solve_terminal_1x2_ctmc(state, 0.9, 0.75)
+    mc, _ = simulate_terminal_1x2_mc_batch(state, 0.9, 0.75, n_paths=2000, seed=42)
+    l1 = sum(abs(float(ctmc.get(k, 0)) - float(mc.get(k, 0))) for k in ("home", "draw", "away"))
+    sanity_ok = l1 <= max_l1
+
+    rows = load_training_rows(limit=500)
+    holdout_brier = None
+    cal_ok = True
+    if len(rows) >= 40:
+        split = int(len(rows) * 0.8)
+        holdout = rows[split:]
+        if holdout:
+            brier_sum = 0.0
+            n = 0
+            for row in holdout:
+                label = (row.get("label_1x2") or "").strip().lower()
+                if label not in ("home", "draw", "away"):
+                    continue
+                lam_h = float(row.get("lambda_home") or 0.5)
+                lam_a = float(row.get("lambda_away") or 0.5)
+                st = MatchState(
+                    goals_home=int(row.get("goals_home") or 0),
+                    goals_away=int(row.get("goals_away") or 0),
+                    minute=float(row.get("minute") or 45.0),
+                    match_minutes=95.0,
+                )
+                probs, _ = solve_terminal_1x2_ctmc(st, lam_h, lam_a)
+                for outcome in ("home", "draw", "away"):
+                    p = float(probs.get(outcome, 0))
+                    y = 1.0 if outcome == label else 0.0
+                    brier_sum += (p - y) ** 2
+                n += 1
+            if n > 0:
+                holdout_brier = round(brier_sum / (3 * n), 4)
+                cal_ok = holdout_brier <= max_brier
+
+    passed = sanity_ok and (holdout_brier is None or cal_ok)
+    return {
+        "passed": passed,
+        "mc_ctmc_l1": round(l1, 4),
+        "holdout_brier": holdout_brier,
+        "holdout_n": len(rows),
+        "thresholds": {"mc_ctmc_l1": max_l1, "holdout_brier": max_brier},
+    }
+
+
+def evaluate_i3_marks(*, since_ts: float) -> Dict[str, Any]:
+    from hibs_predictor.inplay.evidence_store import query_since
+
+    stored = query_since(since_ts)
+    min_cov = _env_float("HIBS_INPLAY_I3_MARKS_COVERAGE_PCT", I3_MIN_MARKS_COVERAGE_PCT)
+    n = int(stored.get("marks_snapshots") or 0)
+    avg_cov = float(stored.get("marks_coverage_avg_pct") or 0.0)
+    passed = n > 0 and avg_cov >= min_cov
+    return {
+        "passed": passed,
+        "snapshots": n,
+        "coverage_avg_pct": avg_cov,
+        "threshold_pct": min_cov,
+    }
+
+
+def evaluate_i4_clv(*, since_ts: float) -> Dict[str, Any]:
+    from hibs_predictor.inplay.evidence_store import query_since
+
+    stored = query_since(since_ts)
+    min_n = int(_env_float("HIBS_INPLAY_I4_MIN_ROWS", I4_MIN_CLV_ROWS))
+    beat_pct = _env_float("HIBS_INPLAY_I4_BEAT_PCT", I4_CLV_BEAT_PASS_PCT)
+    n = int(stored.get("clv_settled_n") or 0)
+    beat = int(stored.get("clv_beat_n") or 0)
+    actual_pct = round(100.0 * beat / n, 1) if n else 0.0
+    passed = n >= min_n and actual_pct >= beat_pct
+    return {
+        "passed": passed,
+        "n_settled": n,
+        "beat_n": beat,
+        "beat_pct": actual_pct,
+        "threshold_n": min_n,
+        "threshold_beat_pct": beat_pct,
+    }
+
+
+def evaluate_i5_paper(*, since_ts: float) -> Dict[str, Any]:
+    from hibs_predictor.inplay.evidence_store import query_since
+
+    stored = query_since(since_ts)
+    min_n = int(_env_float("HIBS_INPLAY_I5_MIN_ROWS", I5_MIN_PAPER_ROWS))
+    n = int(stored.get("paper_n") or 0)
+    passed = n >= min_n
+    return {"passed": passed, "n": n, "threshold_n": min_n}
+
+
+def inplay_evidence_gates() -> Dict[str, Any]:
+    """Forward evidence I1–I5 for in-play buyer_ready."""
+    load_dotenv()
+    since_ts = _since_ts()
+    since_iso = None
+    if since_ts > 0:
+        since_iso = datetime.fromtimestamp(since_ts, tz=timezone.utc).replace(microsecond=0).isoformat()
+
+    i1 = evaluate_i1_feed(since_ts=since_ts)
+    i2 = evaluate_i2_model()
+    i3 = evaluate_i3_marks(since_ts=since_ts)
+    i4 = evaluate_i4_clv(since_ts=since_ts)
+    i5 = evaluate_i5_paper(since_ts=since_ts)
+
+    gates: List[Dict[str, Any]] = [
+        gate_row(
+            "I1_feed",
+            label="Binary ingest uptime, seq gaps, p99 peel",
+            passed=bool(i1["passed"]),
+            actual={
+                "uptime_pct": i1["uptime_pct"],
+                "seq_gap_rate_pct": i1["seq_gap_rate_pct"],
+                "p99_peel_us": i1["p99_peel_us"],
+                "frames": i1["frames"],
+            },
+            threshold=i1["thresholds"],
+            message="Record binary frames via ingest_binary_payload during live window",
+            critical=True,
+        ),
+        gate_row(
+            "I2_model",
+            label="MC vs CTMC sanity; held-out tick calibration",
+            passed=bool(i2["passed"]),
+            actual={"mc_ctmc_l1": i2["mc_ctmc_l1"], "holdout_brier": i2["holdout_brier"]},
+            threshold=i2["thresholds"],
+            message="Archive labeled ticks; MC/CTMC L1 must stay tight",
+            critical=True,
+        ),
+        gate_row(
+            "I3_marks",
+            label="fetch_exchange_marks coverage in live window",
+            passed=bool(i3["passed"]),
+            actual={"coverage_avg_pct": i3["coverage_avg_pct"], "snapshots": i3["snapshots"]},
+            threshold=f">={i3['threshold_pct']}%",
+            message="Router must poll venues during live ticks",
+            critical=True,
+        ),
+        gate_row(
+            "I4_clv",
+            label="In-play taken odds vs close-of-window fair",
+            passed=bool(i4["passed"]),
+            actual={"n_settled": i4["n_settled"], "beat_pct": i4["beat_pct"]},
+            threshold={"n": i4["threshold_n"], "beat_pct": i4["threshold_beat_pct"]},
+            message="Settle inplay_clv_audit rows at FT with close fair prices",
+            critical=True,
+        ),
+        gate_row(
+            "I5_paper",
+            label="In-play paper rows with verification hash",
+            passed=bool(i5["passed"]),
+            actual={"n": i5["n"]},
+            threshold=f">={i5['threshold_n']}",
+            message="HIBS_INPLAY_EXECUTE=paper and worker execute enabled",
+            critical=True,
+        ),
+    ]
+
+    buyer_ready = all(g.get("pass") for g in gates)
+    return {
+        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
+        "since_deploy": since_iso,
+        "gates": gates,
+        "buyer_ready": buyer_ready,
+        "I1": i1,
+        "I2": i2,
+        "I3": i3,
+        "I4": i4,
+        "I5": i5,
+    }
diff --git a/src/hibs_predictor/inplay/evidence_store.py b/src/hibs_predictor/inplay/evidence_store.py
new file mode 100644
index 0000000..67e41c8
--- /dev/null
+++ b/src/hibs_predictor/inplay/evidence_store.py
@@ -0,0 +1,266 @@
+"""SQLite persistence for in-play forward evidence (I1–I5 audit tables)."""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import os
+import sqlite3
+import time
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+
+
+def evidence_db_path() -> Path:
+    raw = (os.getenv("HIBS_INPLAY_EVIDENCE_DB") or "").strip()
+    if raw:
+        return Path(raw)
+    root = Path(__file__).resolve().parents[3]
+    return root / "data" / "inplay_evidence.sqlite"
+
+
+def _connect() -> sqlite3.Connection:
+    path = evidence_db_path()
+    path.parent.mkdir(parents=True, exist_ok=True)
+    conn = sqlite3.connect(str(path))
+    conn.row_factory = sqlite3.Row
+    conn.executescript(
+        """
+        CREATE TABLE IF NOT EXISTS inplay_feed_frames (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            vendor TEXT NOT NULL,
+            fixture_key TEXT NOT NULL,
+            seq INTEGER NOT NULL,
+            parse_us INTEGER,
+            seq_gap INTEGER DEFAULT 0,
+            ts REAL NOT NULL
+        );
+        CREATE INDEX IF NOT EXISTS idx_feed_frames_ts ON inplay_feed_frames(ts);
+        CREATE INDEX IF NOT EXISTS idx_feed_frames_fixture ON inplay_feed_frames(fixture_key, vendor);
+
+        CREATE TABLE IF NOT EXISTS inplay_marks_snapshots (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            fixture_id TEXT NOT NULL,
+            venues_total INTEGER NOT NULL,
+            venues_ok INTEGER NOT NULL,
+            coverage_pct REAL NOT NULL,
+            ts REAL NOT NULL
+        );
+        CREATE INDEX IF NOT EXISTS idx_marks_ts ON inplay_marks_snapshots(ts);
+
+        CREATE TABLE IF NOT EXISTS inplay_clv_audit (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            fixture_id TEXT NOT NULL,
+            outcome TEXT NOT NULL,
+            taken_decimal REAL NOT NULL,
+            model_prob REAL,
+            close_fair_decimal REAL,
+            clv_bps REAL,
+            ts_taken REAL NOT NULL,
+            ts_close REAL,
+            settled INTEGER DEFAULT 0
+        );
+        CREATE INDEX IF NOT EXISTS idx_clv_ts ON inplay_clv_audit(ts_taken);
+
+        CREATE TABLE IF NOT EXISTS inplay_paper_executions (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            fixture_id TEXT NOT NULL,
+            outcome TEXT NOT NULL,
+            decimal_odds REAL NOT NULL,
+            stake REAL NOT NULL,
+            mode TEXT NOT NULL,
+            verification_hash TEXT NOT NULL,
+            payload_json TEXT NOT NULL,
+            ts REAL NOT NULL
+        );
+        CREATE INDEX IF NOT EXISTS idx_paper_ts ON inplay_paper_executions(ts);
+        """
+    )
+    conn.commit()
+    return conn
+
+
+def record_feed_frame(
+    *,
+    vendor: str,
+    fixture_key: str,
+    seq: int,
+    parse_us: Optional[int],
+    seq_gap: int = 0,
+    ts: Optional[float] = None,
+) -> None:
+    with _connect() as conn:
+        conn.execute(
+            """
+            INSERT INTO inplay_feed_frames (vendor, fixture_key, seq, parse_us, seq_gap, ts)
+            VALUES (?, ?, ?, ?, ?, ?)
+            """,
+            (vendor, fixture_key, int(seq), parse_us, int(seq_gap), float(ts or time.time())),
+        )
+        conn.commit()
+
+
+def record_marks_snapshot(
+    *,
+    fixture_id: str,
+    venues_total: int,
+    venues_ok: int,
+    ts: Optional[float] = None,
+) -> None:
+    total = max(1, int(venues_total))
+    ok = max(0, int(venues_ok))
+    cov = round(100.0 * ok / total, 2)
+    with _connect() as conn:
+        conn.execute(
+            """
+            INSERT INTO inplay_marks_snapshots (fixture_id, venues_total, venues_ok, coverage_pct, ts)
+            VALUES (?, ?, ?, ?, ?)
+            """,
+            (str(fixture_id), total, ok, cov, float(ts or time.time())),
+        )
+        conn.commit()
+
+
+def record_clv_taken(
+    *,
+    fixture_id: str,
+    outcome: str,
+    taken_decimal: float,
+    model_prob: Optional[float] = None,
+    ts: Optional[float] = None,
+) -> int:
+    with _connect() as conn:
+        cur = conn.execute(
+            """
+            INSERT INTO inplay_clv_audit
+            (fixture_id, outcome, taken_decimal, model_prob, ts_taken)
+            VALUES (?, ?, ?, ?, ?)
+            """,
+            (str(fixture_id), outcome.strip().lower(), float(taken_decimal), model_prob, float(ts or time.time())),
+        )
+        conn.commit()
+        return int(cur.lastrowid or 0)
+
+
+def settle_clv_close(
+    *,
+    fixture_id: str,
+    close_fair_by_outcome: Dict[str, float],
+    ts: Optional[float] = None,
+) -> int:
+    updated = 0
+    with _connect() as conn:
+        rows = conn.execute(
+            """
+            SELECT id, outcome, taken_decimal FROM inplay_clv_audit
+            WHERE fixture_id = ? AND settled = 0
+            """,
+            (str(fixture_id),),
+        ).fetchall()
+        for row in rows:
+            outcome = str(row["outcome"])
+            close_dec = close_fair_by_outcome.get(outcome)
+            if not close_dec or close_dec <= 1.0:
+                continue
+            taken = float(row["taken_decimal"])
+            clv_bps = round(10000.0 * (taken / float(close_dec) - 1.0), 2)
+            conn.execute(
+                """
+                UPDATE inplay_clv_audit
+                SET close_fair_decimal = ?, clv_bps = ?, ts_close = ?, settled = 1
+                WHERE id = ?
+                """,
+                (float(close_dec), clv_bps, float(ts or time.time()), int(row["id"])),
+            )
+            updated += 1
+        conn.commit()
+    return updated
+
+
+def record_paper_execution(payload: Dict[str, Any]) -> str:
+    canonical = json.dumps(payload, sort_keys=True, default=str)
+    vhash = hashlib.sha256(canonical.encode("utf-8")).hexdigest()
+    with _connect() as conn:
+        conn.execute(
+            """
+            INSERT INTO inplay_paper_executions
+            (fixture_id, outcome, decimal_odds, stake, mode, verification_hash, payload_json, ts)
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+            """,
+            (
+                str(payload.get("fixture_id") or ""),
+                str(payload.get("outcome") or ""),
+                float(payload.get("decimal_odds") or 0),
+                float(payload.get("stake") or 0),
+                str(payload.get("mode") or "paper"),
+                vhash,
+                canonical,
+                float(payload.get("ts") or time.time()),
+            ),
+        )
+        conn.commit()
+    return vhash
+
+
+def query_since(ts_min: float) -> Dict[str, Any]:
+    with _connect() as conn:
+        feed = conn.execute(
+            """
+            SELECT COUNT(*) AS n,
+                   SUM(CASE WHEN seq_gap > 0 THEN 1 ELSE 0 END) AS gaps,
+                   MAX(parse_us) AS max_parse_us
+            FROM inplay_feed_frames WHERE ts >= ?
+            """,
+            (ts_min,),
+        ).fetchone()
+        peel_rows = [
+            int(r[0])
+            for r in conn.execute(
+                "SELECT parse_us FROM inplay_feed_frames WHERE ts >= ? AND parse_us IS NOT NULL",
+                (ts_min,),
+            ).fetchall()
+        ]
+        marks = conn.execute(
+            """
+            SELECT AVG(coverage_pct) AS avg_cov, COUNT(*) AS n
+            FROM inplay_marks_snapshots WHERE ts >= ?
+            """,
+            (ts_min,),
+        ).fetchone()
+        clv = conn.execute(
+            """
+            SELECT COUNT(*) AS n,
+                   SUM(CASE WHEN clv_bps > 0 THEN 1 ELSE 0 END) AS beat
+            FROM inplay_clv_audit WHERE ts_taken >= ? AND settled = 1
+            """,
+            (ts_min,),
+        ).fetchone()
+        paper = conn.execute(
+            """
+            SELECT COUNT(*) AS n FROM inplay_paper_executions
+            WHERE ts >= ? AND verification_hash IS NOT NULL AND verification_hash != ''
+            """,
+            (ts_min,),
+        ).fetchone()
+    p99 = _p99(peel_rows)
+    feed_n = int(feed["n"] or 0) if feed else 0
+    gap_n = int(feed["gaps"] or 0) if feed else 0
+    return {
+        "feed_frames": feed_n,
+        "seq_gaps": gap_n,
+        "seq_gap_rate_pct": round(100.0 * gap_n / feed_n, 3) if feed_n else 0.0,
+        "p99_peel_us": p99,
+        "marks_snapshots": int(marks["n"] or 0) if marks else 0,
+        "marks_coverage_avg_pct": round(float(marks["avg_cov"] or 0), 2) if marks else 0.0,
+        "clv_settled_n": int(clv["n"] or 0) if clv else 0,
+        "clv_beat_n": int(clv["beat"] or 0) if clv else 0,
+        "paper_n": int(paper["n"] or 0) if paper else 0,
+    }
+
+
+def _p99(values: List[int]) -> Optional[float]:
+    if not values:
+        return None
+    ordered = sorted(values)
+    idx = min(len(ordered) - 1, int(0.99 * len(ordered)))
+    return float(ordered[idx])
