+"""Post-match evidence settlement — CLV close-of-window and tick labels."""
+
+from __future__ import annotations
+
+from typing import Any, Dict, Optional
+
+
+def settle_fixture_evidence(row: Dict[str, Any]) -> Dict[str, Any]:
+    """
+    Settle I4 CLV rows using final best 1X2 as close-of-window fair proxy.
+    Call when fixture leaves live (FT or dashboard refresh after match).
+    """
+    fid = str(row.get("id") or "")
+    if not fid:
+        return {"fixture_id": "", "clv_updated": 0, "ticks_labeled": 0}
+
+    close: Dict[str, float] = {}
+    best = row.get("best_odds_1x2") if isinstance(row.get("best_odds_1x2"), dict) else {}
+    for side in ("home", "draw", "away"):
+        try:
+            val = float(best.get(side) or row.get(f"odds_{side}") or 0)
+        except (TypeError, ValueError):
+            val = 0.0
+        if val > 1.0:
+            close[side] = val
+
+    clv_updated = 0
+    if close:
+        try:
+            from hibs_predictor.inplay.evidence_store import settle_clv_close
+
+            clv_updated = settle_clv_close(fixture_id=fid, close_fair_by_outcome=close)
+        except Exception:
+            pass
+
+    ticks_labeled = 0
+    result = _result_1x2(row)
+    if result:
+        try:
+            from hibs_predictor.inplay.tick_archive import label_finished_fixture
+
+            ticks_labeled = label_finished_fixture(fid, result=result)
+        except Exception:
+            pass
+
+    return {"fixture_id": fid, "clv_updated": clv_updated, "ticks_labeled": ticks_labeled, "result": result}
+
+
+def _result_1x2(row: Dict[str, Any]) -> Optional[str]:
+    status = str(row.get("live_status") or row.get("status") or "").upper()
+    if status not in ("FT", "AET", "PEN", "FINISHED", "MATCH FINISHED"):
+        if not row.get("is_live") and row.get("live_score_home") is not None:
+            pass
+        else:
+            return None
+    try:
+        h = int(row.get("live_score_home") if row.get("live_score_home") is not None else row.get("score_home") or 0)
+        a = int(row.get("live_score_away") if row.get("live_score_away") is not None else row.get("score_away") or 0)
+    except (TypeError, ValueError):
+        return None
+    if h > a:
+        return "home"
+    if h < a:
+        return "away"
+    return "draw"
