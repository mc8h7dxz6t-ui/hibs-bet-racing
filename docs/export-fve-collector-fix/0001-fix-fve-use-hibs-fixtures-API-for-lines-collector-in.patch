 deploy/bootstrap-fve-dedicated-1gb.sh | 24 ++++++---
 scripts/lib_fve_local_repair.sh       | 17 ++-----
 scripts/run_fve_lines_collector.sh    | 72 +++++++++++++++++++++++++++
 4 files changed, 101 insertions(+), 23 deletions(-)
 create mode 100755 scripts/run_fve_lines_collector.sh

