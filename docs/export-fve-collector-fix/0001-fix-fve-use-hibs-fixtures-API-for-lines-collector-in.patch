 log "5/6 — start FVE API + ingest worker (docker profile ingest)"
 if [[ -f "${FVE_ROOT}/docker-compose.yml" ]]; then
@@ -95,9 +95,10 @@ else
   echo "  curl -fsSL ${RAW}/scripts/vps_unpause_fve_scrape_stack.sh | sudo bash"
