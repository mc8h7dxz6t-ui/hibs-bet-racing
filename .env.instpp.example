# Institutional++ demo environment — copy to .env.instpp and source before demos.
# All values have safe offline defaults; nothing here is required for make demo-all.

# ── Offline / air-gapped ─────────────────────────────────────────────────────
SKIP_LIVE=1
SKIP_LIVE_LLM=1

# ── Webhook Mesh + Replay ────────────────────────────────────────────────────
WEBHOOK_PROVIDER_SECRET=demo-secret
WEBHOOK_MESH_LEDGER=./data/demo/webhook_mesh.sqlite
WEBHOOK_DISPATCH_MODE=background
# Production durable delivery:
# WEBHOOK_DISPATCH_MODE=redis
# INST_REDIS_URL=redis://127.0.0.1:6379/0
# WEBHOOK_STREAM_CLAIM_IDLE_MS=30000
WEBHOOK_REPLAY_CAPTURE_DIR=./data/demo/captures

# ── Proxy-Risk + Drift Gate + Spend Guard integration ─────────────────────────
PROXY_DRIFT_MODE=shadow
# PROXY_DRIFT_BASELINE=./data/demo/drift_baseline.json
# PROXY_SPEND_WALLET_DB=./data/demo/portfolio/spend_wallet.sqlite
# PROXY_SPEND_LEDGER_DB=./data/demo/portfolio/spend_guard.sqlite

# ── Ad Guard spend ceiling ───────────────────────────────────────────────────
# AD_GUARD_SPEND_WALLET_DB=./data/demo/portfolio/spend_wallet.sqlite
# AD_GUARD_SPEND_LEDGER_DB=./data/demo/portfolio/spend_guard.sqlite

# ── AI Kit + Agent Ledger ────────────────────────────────────────────────────
# AI_AGENT_LEDGER_DB=./data/demo/portfolio/agent_ledger.sqlite
# AI_AGENT_PERMIT_DB=./data/demo/portfolio/agent_ledger_permits.sqlite

# ── ModelGovernor deploy gate ────────────────────────────────────────────────
# MODEL_GOVERNOR_DRIFT_BASELINE=./data/demo/drift_baseline.json
# MODEL_GOVERNOR_DRIFT_MODE=shadow

# ── Production profile (fail-closed /ready) ─────────────────────────────────
# INST_PRODUCTION_PROFILE=1
# INST_REQUIRE_POSTGRES=1
# INST_POSTGRES_DSN=postgresql://user:pass@host:5432/instpp
# INST_REDIS_URL=redis://127.0.0.1:6379/0
# WEBHOOK_DISPATCH_MODE=redis
# WEBHOOK_REQUIRE_REDIS_DISPATCH=1
# INST_BUNDLE_SIGNING_KEY=change-me-in-production

# ── Optional Redis (drift rolling state) ─────────────────────────────────────
# INST_REDIS_URL=redis://127.0.0.1:6379/0

# ── AI Kit live LLM (optional) ───────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# SKIP_LIVE_LLM=0

# ── Spend Guard OpenAI-compat gateway ────────────────────────────────────────
# SPEND_GUARD_WALLET_DB=./data/demo/portfolio/spend_wallet.sqlite
# SPEND_GUARD_LEDGER_DB=./data/demo/portfolio/spend_guard.sqlite
# SPEND_GUARD_MOCK_UPSTREAM=1
# SPEND_GUARD_UPSTREAM_BASE=https://api.openai.com/v1
# SPEND_GUARD_UPSTREAM_API_KEY=sk-...

# ── Workflow UI (make demo-gold-up) ─────────────────────────────────────────
INST_WORKFLOW_HOST=127.0.0.1
INST_WORKFLOW_PORT=8790
INST_COMPLIANCE_DB=./data/demo/portfolio/compliance.sqlite
INST_PROXY_DB=./data/demo/portfolio/proxy.sqlite
INST_EXPORT_DIR=./data/demo/ui_exports

# ── Demo output directories ──────────────────────────────────────────────────
PORTFOLIO_DEMO_DIR=./data/demo/portfolio
PHASE2_DEMO_DIR=./data/demo/phase2
GOLD_DEMO_DIR=./data/demo/spend_gold

# ── Institutional WAL paths (per-product defaults in demo scripts) ───────────
# INST_WAL_PATH=./data/demo/inst.wal
