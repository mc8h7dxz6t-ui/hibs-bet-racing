# hibs-racing — copy to .env and fill secrets (never commit .env)

# ── Paths (relative to repo root, or absolute — tilde expanded) ───────────────
HIBS_RACING_DATA_DIR=./data
HIBS_RACING_DB_PATH=./data/feature_store.sqlite
RACEFORM_DB_PATH=./raceform.db
# Block-storage VPS (see hibs-bet deploy/mount-racing-data-volume.sh):
# HIBS_RACING_DATA_DIR=/mnt/hibs-racing-data/data
# HIBS_RACING_SQLITE_BEEFY=1
# HIBS_RACING_SQLITE_CACHE_KB=65536
# HIBS_RACING_SQLITE_MMAP_BYTES=268435456

# ── Web server ─────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=5003
# Cross-app UI toggle (racing ↔ hibs-bet football / trading / lines) — display only
# HIBS_FOOTBALL_BASE_URL=http://127.0.0.1:5000
# HIBS_FOOTBALL_HOME_URL=https://hibs-bet.co.uk/
# HIBS_RACING_PUBLIC_URL=https://hibs-bet.co.uk/racing
# HIBS_RACING_BASE_URL=/racing
# HIBS_DOMAIN=hibs-bet.co.uk
# HIBS_TRADING_STATUS_URL=https://hibs-bet.co.uk/harvested-execution
# HIBS_LINE_TRADER_URL=https://hibs-bet.co.uk/line-trader
# HIBS_URL_PREFIX=/racing
# HIBS_PORTFOLIO_API_URL=/api/racing/portfolio/summary
# HIBS_UI_ASSET_VERSION=20260714b
FLASK_DEBUG=0
FLASK_SECRET_KEY=change-me-to-random-hex

# ── Automation (scripts/daily_refresh.sh, Docker supercronic @ 06:00) ─────────
HIBS_LOOKBACK_DAYS=7
HIBS_WEEKLY_LOOKBACK_DAYS=14
HIBS_PUBLIC_TRACKER=1
HIBS_TRACKER_HISTORY_DAYS=60
# HIBS_TRACKER_CORS_ORIGIN=*
# HIBS_DAILY_PICKS_TOP=3
# Morning batch odds: auto (API embed → matchbook → oddschecker scrape) | matchbook | oddschecker
HIBS_ODDS_SOURCE=auto
# Cards: auto (rpscrape when Racing API unfunded) | racing_api | rpscrape
HIBS_RACING_CARD_SOURCE=auto
# Scrape-first until Racing API funded (1 = force rpscrape cards when API missing)
# HIBS_RACING_SCRAPE_FIRST=1
# Oddschecker retail scrape fallback when Matchbook unavailable (default on)
HIBS_ODDS_AUTO_SCRAPE=1
# Set when VPS IP is 403-blocked by Oddschecker (Matchbook or cached quotes still used)
# HIBS_DISABLE_ODDSCHECKER=1
# Production: HIBS_OBSERVATION_LANE=0 (strict gates). Dev default: 1 until gate passed.
# After observation: sudo bash deploy/apply-vps-production-racing.sh
HIBS_OBSERVATION_LANE=0
HIBS_RACING_PRODUCTION=1

# ── Daily digest (optional — notify-daily after refresh-cards) ────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
#
# Email — Smart Portfolio digest (notify-daily after morning refresh)
# Sky (@sky.com) — recommended; use Sky SMTP, not Gmail/Yahoo:
# HIBS_DAILY_EMAIL_TO=you@sky.com
# SMTP_HOST=smtp.tools.sky.com
# SMTP_PORT=587
# SMTP_USER=you@sky.com
# SMTP_PASSWORD=your-mailbox-password
# SMTP_FROM=you@sky.com
# SMTP_USE_TLS=1
# SMTP_USE_SSL=0
# HIBS_DAILY_EMAIL_SUBJECT="Hibs Racing — morning picks"
# If 587 fails: SMTP_PORT=465 SMTP_USE_TLS=0 SMTP_USE_SSL=1

# ── The Racing API (required for refresh-cards) ───────────────────────────────
# https://www.theracingapi.com → My Account → Username + Password
RACING_API_USERNAME=
RACING_API_PASSWORD=
RACING_API_PLAN=free
RACING_API_BASE=https://api.theracingapi.com/v1
# Rate limits (optional — defaults in ingest/config.yaml rate_limits)
# RACING_API_PAUSE_SEC=1.5
# RACING_API_429_PAUSE_SEC=8
# RP_SCRAPE_DAY_PAUSE_SEC=4
# RP_RACECARD_REGION_PAUSE_SEC=5
# RP_VERDICT_RACE_PAUSE_SEC=1.2
# RP_VERDICT_WORKERS=2
# RP_VERDICT_MAX_RACES=20

# ── Matchbook exchange (required for value odds + paper ledger) ───────────────
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=
# MATCHBOOK_LOGIN_BASE=https://api.matchbook.com/bpapi/rest
# MATCHBOOK_API_BASE=https://api.matchbook.com/edge/rest

# ── Event-driven trading engine (sandboxed — zero capital risk by default) ─────
# HIBS_LIVE_TRADING_ENABLED=false  → parse streams, write simulated_trades only
HIBS_LIVE_TRADING_ENABLED=false
# HIBS_MATCHBOOK_STREAM_WS_URL=wss://api.matchbook.com/edge/stream/v1/prices
# HIBS_EXECUTION_LATENCY_MAX_MS=250
# HIBS_SLIPPAGE_MAX_TICKS=2
# HIBS_TRADING_IDEMPOTENCY_MS=5000
# HIBS_TRADING_WALLET_BALANCE=1000
# HIBS_TRADING_ODDS_TICK_SIZE=0.01

# ── Liquidity router (simulation only — default off) ───────────────────────────
# HIBS_LIQUIDITY_ROUTER_ACTIVE=false  → route + hedge ledger only; no outbound broker
HIBS_LIQUIDITY_ROUTER_ACTIVE=false
# HIBS_MIN_HEDGE_DELTA_BPS=150
# HIBS_MAX_VENUE_COMMISSION_BPS=200
# HIBS_ALLOWED_ROUTING_CHANNELS=matchbook,smarkets,betdaq
# Auto default when unset: matchbook → smarkets → betdaq (+ betfair when armed)
# HIBS_LIQUIDITY_ROUTER_POLL_SEC=5

# ── Affiliate partner links (Smart Portfolio slip copy + odds badges) ─────────
# HIBS_AFFILIATE_VENUE=matchbook
# HIBS_BETFAIR_MONETIZATION_ENABLED=0
# BETFAIR_APP_KEY=
# BETFAIR_USERNAME=
# BETFAIR_PASSWORD=
# HIBS_AFFILIATE_UTM_SOURCE=your_brand_app
# HIBS_AFFILIATE_TRACKING_ID=
# AFFILIATE_MATCHBOOK_BASE_URL=https://www.matchbook.com/
# AFFILIATE_BETFAIR_BASE_URL=https://www.betfair.com/exchange/plus/horse-racing/
# AFFILIATE_SMARKETS_BASE_URL=https://smarkets.com/event/horse-racing
# AFFILIATE_BETDAQ_BASE_URL=https://www.betdaq.com/exchange/horse-racing

# ── Racing Post / rpscrape fallback (optional — richer RP comments) ───────────
# EMAIL=
# ACCESS_TOKEN=

# ── Production mode (ranker-only scoring; fail if model missing) ─────────────
# Required on VPS — daily_refresh aborts if lgbm_ranker.txt missing when set.
HIBS_RACING_PRODUCTION=1

# ── Harville place calibration (A/B: 0=off, 1=longshot trim from config) ─────
HIBS_HARVILLE_CORRECTION=1

# ── Exchange place EV shadow (Gate3 paper lane; production off until flip) ───
# HIBS_EXCHANGE_EV_SHADOW=1
# HIBS_EXCHANGE_EV_PRODUCTION=0
# HIBS_EXCHANGE_COMMISSION=0.02
# HIBS_KELLY_FRACTION=0.25
# HIBS_MAX_RUNNER_RISK_PCT=0.02
# HIBS_EXCHANGE_EV_MIN_COVERAGE_PCT=50

# ── Docker only: path to host raceform.db mounted at /raceform/raceform.db ───
# RACEFORM_DB_PATH=/raceform/raceform.db

# ── Tipster IMAP (optional) ────────────────────────────────────────────────────
# TIPSTER_IMAP_HOST=imap.gmail.com
# TIPSTER_IMAP_PORT=993
# TIPSTER_IMAP_USER=you@gmail.com
# TIPSTER_IMAP_PASSWORD=your-app-password
# TIPSTER_IMAP_FOLDER=INBOX
# TIPSTER_IMAP_FROM=tipster@example.com
# TIPSTER_IMAP_UNSEEN_ONLY=1
# TIPSTER_IMAP_MARK_READ=0
# TIPSTER_IMAP_LIMIT=30

# ── Institutional health API (performance-safe defaults) ─────────────────────
# HIBS_RACING_HEALTH_TTL_SEC=20   — cache /api/health responses (use ?full=1 to bypass)
# HIBS_HEALTH_LIGHT=0             — set 1 to skip heavy recon on health polls only

# --- ROI / place Brier calibration (R8 gate) ---
# HIBS_RACING_DB_PATH=./data/feature_store.sqlite
# HIBS_RACING_DB=./data/feature_store.sqlite   — football trade_evidence cross-read
# HIBS_RACING_PLACE_BRIER_PASS_MAX=0.25
# HIBS_RACING_MIN_PLACE_CALIBRATION_N=20
# HIBS_RACING_SETTLE_AT_SP=0

# --- Live exchange routing (dual-arm; default off / analytics) ---
# HIBS_RACING_LIVE_ROUTING_ALLOWED=0
# HIBS_RACING_CONFIRM_LIVE=NO

# --- McFadden conditional logit win engine (sandboxed; default off) ---
# Copy block below to production .env — see docs/WIN_ENGINE_DEPLOYMENT.md
#
# McFadden Win Engine Staging Configuration (Leave as false initially)
HIBS_WIN_ENGINE_ACTIVE=false
HIBS_RACING_WIN_BRIER_PASS_MAX=0.185
HIBS_RACING_MIN_WIN_CALIBRATION_N=100
# HIBS_WIN_ENGINE_ALPHA=1.0
# HIBS_WIN_ENGINE_BETA=0.35

# --- Liquidity router flight guard (PR #97 — simulation until armed) ---
# HIBS_LIQUIDITY_ROUTER_ACTIVE=false
# HIBS_FLIGHT_LATENCY_MAX_MS=450
# HIBS_ADVERSE_SELECTION_VOLUME_DROP_PCT=0.40
