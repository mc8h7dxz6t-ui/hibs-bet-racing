# hibs-racing — copy to .env and fill secrets (never commit .env)

# ── Paths (relative to repo root, or absolute — tilde expanded) ───────────────
HIBS_RACING_DATA_DIR=./data
HIBS_RACING_DB_PATH=./data/feature_store.sqlite
RACEFORM_DB_PATH=./raceform.db

# ── Web server ─────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=5003
# Cross-app UI toggle (racing ↔ hibs-bet football) — display only
# HIBS_FOOTBALL_BASE_URL=http://127.0.0.1:5000
# HIBS_RACING_PUBLIC_URL=http://127.0.0.1:5003
FLASK_DEBUG=0
FLASK_SECRET_KEY=change-me-to-random-hex

# ── Automation (scripts/daily_refresh.sh, Docker supercronic @ 06:00) ─────────
HIBS_LOOKBACK_DAYS=7
HIBS_WEEKLY_LOOKBACK_DAYS=14
HIBS_PUBLIC_TRACKER=1
HIBS_TRACKER_HISTORY_DAYS=60
# HIBS_TRACKER_CORS_ORIGIN=*
# HIBS_DAILY_PICKS_TOP=3
# Morning batch odds: matchbook (exchange back prices) | auto (Racing API embed first)
HIBS_ODDS_SOURCE=matchbook

# ── Daily digest (optional — notify-daily after refresh-cards) ────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
#
# Email — Smart Portfolio digest (notify-daily after morning refresh)
# Sky (@sky.com) — recommended; use Sky SMTP, not Gmail/Yahoo:
# HIBS_DAILY_EMAIL_TO=you@sky.com
# SMTP_HOST=smtp.tools.sky.com
# SMTP_PORT=587
# SMTP_USER=you@sky.com
# SMTP_PASSWORD=your-mailbox-password
# SMTP_FROM=you@sky.com
# SMTP_USE_TLS=1
# SMTP_USE_SSL=0
# HIBS_DAILY_EMAIL_SUBJECT=Hibs Racing — morning picks
# If 587 fails: SMTP_PORT=465 SMTP_USE_TLS=0 SMTP_USE_SSL=1

# ── The Racing API (required for refresh-cards) ───────────────────────────────
# https://www.theracingapi.com → My Account → Username + Password
RACING_API_USERNAME=
RACING_API_PASSWORD=
RACING_API_PLAN=free
RACING_API_BASE=https://api.theracingapi.com/v1
# Rate limits (optional — defaults in ingest/config.yaml rate_limits)
# RACING_API_PAUSE_SEC=1.5
# RACING_API_429_PAUSE_SEC=8
# RP_SCRAPE_DAY_PAUSE_SEC=4
# RP_RACECARD_REGION_PAUSE_SEC=5
# RP_VERDICT_RACE_PAUSE_SEC=1.2
# RP_VERDICT_WORKERS=2
# RP_VERDICT_MAX_RACES=20

# ── Matchbook exchange (required for value odds + paper ledger) ───────────────
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=
# MATCHBOOK_LOGIN_BASE=https://api.matchbook.com/bpapi/rest
# MATCHBOOK_API_BASE=https://api.matchbook.com/edge/rest

# ── Affiliate partner links (Smart Portfolio slip copy + odds badges) ─────────
# HIBS_AFFILIATE_VENUE=matchbook
# HIBS_AFFILIATE_UTM_SOURCE=your_brand_app
# HIBS_AFFILIATE_TRACKING_ID=
# AFFILIATE_MATCHBOOK_BASE_URL=https://www.matchbook.com/

# ── Racing Post / rpscrape fallback (optional — richer RP comments) ───────────
# EMAIL=
# ACCESS_TOKEN=

# ── Production mode (ranker-only scoring; fail if model missing) ─────────────
# HIBS_RACING_PRODUCTION=1

# ── Harville place calibration (A/B: 0=off, 1=longshot trim from config) ─────
HIBS_HARVILLE_CORRECTION=1

# ── Docker only: path to host raceform.db mounted at /raceform/raceform.db ───
# RACEFORM_DB_PATH=/raceform/raceform.db

# ── Tipster IMAP (optional) ────────────────────────────────────────────────────
# TIPSTER_IMAP_HOST=imap.gmail.com
# TIPSTER_IMAP_PORT=993
# TIPSTER_IMAP_USER=you@gmail.com
# TIPSTER_IMAP_PASSWORD=your-app-password
# TIPSTER_IMAP_FOLDER=INBOX
# TIPSTER_IMAP_FROM=tipster@example.com
# TIPSTER_IMAP_UNSEEN_ONLY=1
# TIPSTER_IMAP_MARK_READ=0
# TIPSTER_IMAP_LIMIT=30
