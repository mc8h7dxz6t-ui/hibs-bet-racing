# Racing-only secrets — never share with hibs-bet football .env
HIBS_RACING_DATA_DIR=./data
HIBS_RACING_DB_PATH=./data/feature_store.sqlite

# Kaggle raceform.db (download once, point here for convenience)
RACEFORM_DB_PATH=~/Downloads/raceform.db

# Phase C (live) — leave empty until backtest passes
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# Production VPS: force ranker-only scoring (fail if model missing)
# HIBS_RACING_PRODUCTION=1

# Unified portfolio — nginx proxies /api/portfolio/summary to racing
# HIBS_BET_BASE_URL=http://127.0.0.1:5001
# HIBS_BET_TRACKER_URL=http://127.0.0.1:5001/api/tracker?days=90
# HIBS_BET_DB_PATH=~/Applications/data/prediction_audit.sqlite
# HIBS_PORTFOLIO_CORS=1

# Matchbook exchange — REST session token (free API access with account)
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=
# MATCHBOOK_API_BASE=https://api.matchbook.com/edge/rest

# Racing Post (rpscrape) — optional backup if RP rate-limits scrapes
# Login at racingpost.com → DevTools → Cookies → CognitoIdentityServiceProvider…accessToken
EMAIL=
ACCESS_TOKEN=

# The Racing API — free plan uses /racecards/free (today + tomorrow)
# Dashboard → My Account → copy Username + Password
RACING_API_USERNAME=
RACING_API_PASSWORD=
RACING_API_PLAN=free
RACING_API_BASE=https://api.theracingapi.com/v1

# Tipster email — optional IMAP auto-fetch (Gmail: use App Password, imap.gmail.com)
# TIPSTER_IMAP_HOST=imap.gmail.com
# TIPSTER_IMAP_PORT=993
# TIPSTER_IMAP_USER=you@gmail.com
# TIPSTER_IMAP_PASSWORD=your-app-password
# TIPSTER_IMAP_FOLDER=INBOX
# TIPSTER_IMAP_FROM=tipster@example.com
# TIPSTER_IMAP_UNSEEN_ONLY=1
# TIPSTER_IMAP_MARK_READ=0
# TIPSTER_IMAP_LIMIT=30
