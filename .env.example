# hibs-racing — copy to .env and fill secrets (never commit .env)
# Keep separate from hibs-bet football .env

# ── Paths ────────────────────────────────────────────────────────────────────
HIBS_RACING_DATA_DIR=./data
HIBS_RACING_DB_PATH=./data/feature_store.sqlite
# Use absolute path for cron/scripts (tilde ok in shell, expand for reliability)
RACEFORM_DB_PATH=/Users/you/Downloads/raceform.db

# ── Web server ─────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=5003
FLASK_DEBUG=0
FLASK_SECRET_KEY=change-me-to-random-hex

# ── Automation (scripts/daily_refresh.sh, weekly_retrain.sh) ─────────────────
HIBS_LOOKBACK_DAYS=7
HIBS_WEEKLY_LOOKBACK_DAYS=14
# Public read-only track record (/tracker, /api/tracker) — builds via daily_refresh --paper
HIBS_PUBLIC_TRACKER=1
HIBS_TRACKER_HISTORY_DAYS=60
# HIBS_TRACKER_CORS_ORIGIN=*

# ── The Racing API (required for Refresh 24h / refresh-cards) ────────────────
# https://www.theracingapi.com → My Account → Username + Password
RACING_API_USERNAME=
RACING_API_PASSWORD=
RACING_API_PLAN=free
RACING_API_BASE=https://api.theracingapi.com/v1

# ── Matchbook exchange (optional — win/place odds + steam gates) ─────────────
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=
# MATCHBOOK_API_BASE=https://api.matchbook.com/edge/rest

# ── Racing Post / rpscrape fallback (optional — richer RP comments) ───────────
# racingpost.com login → DevTools → Cookies → Cognito…accessToken
EMAIL=
ACCESS_TOKEN=

# ── Unified portfolio with hibs-bet football ─────────────────────────────────
HIBS_BET_BASE_URL=http://127.0.0.1:5001
HIBS_BET_TRACKER_URL=http://127.0.0.1:5001/api/tracker?days=90
HIBS_BET_DB_PATH=/Users/you/Applications/data/prediction_audit.sqlite
# HIBS_PORTFOLIO_CORS=1
# HIBS_PORTFOLIO_CORS_ORIGIN=*

# ── Production mode (ranker-only scoring; fail if model missing) ─────────────
# HIBS_RACING_PRODUCTION=1

# ── Execution routing (Matchbook default; Betfair Phase C optional) ───────────
# HIBS_EXECUTION_LIVE=0          # keep unset — dry-run only
# HIBS_BETFAIR_ENABLED=0         # override config; set 1 when Betfair access returns

# ── Betfair live (Phase C — optional; set execution.betfair_enabled in config) ─
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# ── Tipster IMAP (optional) ────────────────────────────────────────────────────
# TIPSTER_IMAP_HOST=imap.gmail.com
# TIPSTER_IMAP_PORT=993
# TIPSTER_IMAP_USER=you@gmail.com
# TIPSTER_IMAP_PASSWORD=your-app-password
# TIPSTER_IMAP_FOLDER=INBOX
# TIPSTER_IMAP_FROM=tipster@example.com
# TIPSTER_IMAP_UNSEEN_ONLY=1
# TIPSTER_IMAP_MARK_READ=0
# TIPSTER_IMAP_LIMIT=30
