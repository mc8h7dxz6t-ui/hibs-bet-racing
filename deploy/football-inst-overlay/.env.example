# =============================================================================
# QUICK START — copy to .env and fill private credentials (buyer / VPS bootstrap)
# =============================================================================
# cp .env.example .env
#
# Core API keys (football)
API_SPORTS_FOOTBALL_KEY=your_api_sports_football_key_here
FOOTBALL_DATA_ORG_KEY=your_football_data_org_key_here
ODDS_API_KEY=your_odds_api_key_here
#
# Racing (hibs-racing install — see deploy/racing.env.example)
# RACING_API_USERNAME=your_username
# RACING_API_PASSWORD=your_password
# RACEFORM_DB_PATH=data/raceform.db
# FEATURE_STORE_PATH=data/feature_store.sqlite
#
# Infrastructure paths (relative to install root — never /root/ or Mac home paths)
# HIBS_PREDICTION_LOG_DB=data/prediction_audit.sqlite
#
# Paper / safety switches (racing base license)
# EXECUTION_DISABLED=True
# HIBS_AFFILIATE_VENUE=MATCHBOOK
#
# VPS deploy from Mac (no GitLab variables required):
# DEPLOY_HOST=77.68.89.73
# DEPLOY_USER=root
#
# Verify paths on server after deploy:
# ssh root@77.68.89.73 'bash /opt/hibs-bet/scripts/verify_vps_relative_paths.sh'
# =============================================================================
#
# Copy this file to .env and add your own API keys.
#
# Production VPS (hibs-bet.co.uk): set HIBS_PRODUCTION=1 (deploy scripts set this).
# Local dev may use HIBS_DEV_FULL_DQ=1 and HIBS_FETCH_ALL_DOMESTIC=1 — never on VPS.
# Readiness: PYTHONPATH=src python3 -m hibs_predictor.main institutional-check
#
# --- Safer full data (2GB VPS, hibs-bet.co.uk) — balanced API use, live dashboard ---
# HIBS_FETCH_DAYS=7
# HIBS_MAX_DATA=1
# HIBS_PROGRESSIVE_LOAD=1            — fast HTML from cache; insights/results/assistant load after paint (default on)
# VPS production (apply-vps-safe-production.sh): HIBS_DEV_FULL_DQ=0, HIBS_PROGRESSIVE_LOAD=1, HIBS_API_SPORTS_HOURLY_LIMIT=400
# HIBS_DASHBOARD_LITE=0              — live scores on dashboard load
# HIBS_ALWAYS_DEEP_SCRAPE=0
# HIBS_SKIP_HEAVY_WHEN_API_STRONG=1  — skip FBref/Understat when APIs already strong
# HIBS_FIXTURE_FETCH_WORKERS=3
# HIBS_WARM_FIXTURE_CACHE=1
# HIBS_ENABLE_PLAYER_INSIGHT=1
# HIBS_USE_INJURY_LAMBDA_ADJUST=1
# Do not set HIBS_PREFER_FOOTBALL_DATA_FIXTURES=1 or HIBS_DISABLE_API_SPORTS=1 when API-Sports is active.
# Expired/missing API key: run sudo bash deploy/apply-vps-scrape-first.sh (Football-Data + scrapers).
# On server: sudo bash /opt/hibs-bet/deploy/apply-vps-safe-production.sh
#   (gunicorn --workers 2 --timeout 180; removes any 1GB lite block from .env)
#
# --- 1 GB VPS production — lighter load, avoids worker timeout/OOM ---
# HIBS_FETCH_DAYS=3
# HIBS_MAX_DATA=0
# HIBS_ALWAYS_DEEP_SCRAPE=0
# HIBS_SKIP_HEAVY_WHEN_API_STRONG=1
# HIBS_DASHBOARD_LITE=1              — skip assistant bundle on / ; fewer parallel league fetches; no live merge on index
# HIBS_FIXTURE_FETCH_WORKERS=3
# HIBS_WARM_FIXTURE_CACHE=1
# On server: sudo bash /opt/hibs-bet/deploy/apply-vps-production-tuning.sh
#
# Injuries → attack availability (structured_insight rationale; optional λ dampen):
# HIBS_SKIP_API_INJURIES=0           — set 1 to skip API-Sports injuries
# HIBS_USE_INJURY_LAMBDA_ADJUST=1    — cap ~8% xG reduction from attack_availability_home/away
# HIBS_INJURY_LAMBDA_MAX_CUT=0.08
#
# League top scorers in structured_insight only (not ML features):
# HIBS_ENABLE_PLAYER_INSIGHT=1
# HIBS_SKIP_API_PLAYER_STATS=0       — set 1 to skip players/topscorers API calls
#
# Confirmed lineups (Phase 2 — API-Football fixtures/lineups, pre-kickoff only):
# HIBS_ENABLE_LINEUP_FETCH=1         — default on when API-Sports key loaded; set 0 to disable
# HIBS_SKIP_API_LINEUPS=0            — set 1 to skip fixtures/lineups API calls
# HIBS_LINEUP_FETCH_MAX_HOURS=24     — only fetch within this many hours of kickoff
# HIBS_LINEUP_CONFIDENCE_PENALTY=1   — reduce displayed confidence when XI unconfirmed <2h to KO
# HIBS_LINEUP_CONFIDENCE_FLOOR=0.94  — max ~6% display cut (does not alter λ)
# HIBS_LINEUP_CONFIDENCE_WINDOW_MIN=120
#
# Dashboard display window: 5 or 7 days only (hero, Settings, players, insights copy).
# User choice: Settings → Fixture window, localStorage fetchDays, or ?days=5|7 on the dashboard.
# Server default when unset: 5. HIBS_FETCH_DAYS is normalized to 5 or 7 — other values fall back to 5.
# Use 5+ on VPS so domestic cups (e.g. Coupe de France) in the same week are included.
# HIBS_FETCH_DAYS=5
# HIBS_FETCH_DAYS=7
#
# Recent finished results on dashboard (FT / AET / PEN from API/cache — no live polling):
# HIBS_RESULTS_DAYS=3
# HIBS_RESULTS_FETCH_EVENTS=1         — default on; goal scorers via fixtures/events (set 0 to disable)
# HIBS_RESULTS_MAX_EVENT_FETCHES=12   — max new events calls per results refresh (24h per-fixture cache)
#
# Tournament / international focus (World Cup window Jun–Jul 2026):
# Auto-enables from 2026-06-11 (opening match) through 2026-07-18 when neither var below is set.
# Default fetch (worldcup auto window): WORLD_CUP, INTL_FRIENDLIES, NATIONS_LEAGUE, EUROS (one extra league fetch, cached).
# Dashboard defaults to International region; All / UK / European chips load domestic leagues (?domestic=1).
# HIBS_TOURNAMENT_FOCUS=worldcup   — force on (also: euros, international, or 1)
# HIBS_TOURNAMENT_FOCUS=0          — force off even inside auto date window (restore domestic immediately)
# HIBS_FOCUS_INTERNATIONAL=1       — shorthand for international focus
# HIBS_TOURNAMENT_INCLUDE_FRIENDLIES=1 — always include INTL_FRIENDLIES in international focus fetch
# HIBS_FRIENDLIES_FOCUS_START=2026-05-20 — friendlies auto-included from this date through HIBS_TOURNAMENT_FOCUS_END
# HIBS_FRIENDLIES_FETCH_DAYS=14 — internal API/enrich horizon for INTL_FRIENDLIES during the friendlies block (max 21).
# Does not change dashboard display window (still 5/7 from HIBS_FETCH_DAYS + user Settings); friendlies beyond
# that horizon are fetched for max-data/DQ only and clipped from the main fixture list.
# Pre–World Cup friendlies max-data (until WC auto-focus opens on HIBS_TOURNAMENT_FOCUS_START):
# HIBS_FRIENDLIES_MAX_DATA=1 — optional max enrich for friendlies (off by default; 85%+ still targeted)
# HIBS_ENABLE_FOTMOB_FRIENDLIES=1 — FotMob national-team xG (Nations/WC/Euros fallback tables) for INTL_FRIENDLIES
# HIBS_FRIENDLIES_STATISTICS_XG_RESERVE=8 — extra fixtures/statistics xG budget slice for friendlies max-data profile
# HIBS_TOURNAMENT_FOCUS_START=2026-06-11
# HIBS_TOURNAMENT_FOCUS_END=2026-07-18
# Post-WC gap (after auto window ends, before domestic resume): default stays Nordics / friendlies / cups.
# HIBS_POST_WC_DOMESTIC_EUROPEAN=1 — opt-in UK + European league fetch in the Jul–Aug gap (legacy behaviour).
# HIBS_DOMESTIC_RESUME_DATE=2026-08-01 — when SPL/EPL/European calendars return (alias: HIBS_DOMESTIC_OFFSEASON_END).
# HIBS_DOMESTIC_OFFSEASON_START=2026-05-20 — UK/EU domestic trim begins (Nordics + intl still fetch).
#
# Friendlies prediction tuning (does not lower abstain/DQ floors):
# HIBS_FRIENDLIES_VALUE_DQ_PCT=88 — min data % before friendlies value flags show
# HIBS_FRIENDLIES_VALUE_MARGIN_EXTRA=0.025 — extra edge required vs book for friendlies value
# HIBS_FRIENDLIES_MARKET_BLEND_EXTRA=0.04 — nudge 1X2 probs toward market on friendlies
#
# Live scores (dashboard): snapshot near kick-off on page load; poll supports fotmob_* and numeric ids.
# HIBS_LIVE_SNAPSHOT_ON_LOAD=1
# HIBS_LIVE_ATTACH_STATS_ON_LOAD=0
# HIBS_LIVE_POLL_SEC=60
# HIBS_LIVE_POLL_SEC_INPLAY=30
# HIBS_LIVE_KICKOFF_BEFORE_H=0.25
# HIBS_LIVE_KICKOFF_AFTER_H=3
#
# Data quality — second pass toward 90% (deep enrich). After clearing caches, thin rows need rescue.
# HIBS_TARGET_DQ_PCT=90
# HIBS_DEEP_ENRICH=1
# HIBS_DEEP_ENRICH_TODAY_ONLY=1          — production: today only (VPS safe script sets this)
# HIBS_DEEP_ENRICH_RESCUE_LOW=1          — run deep pass even when first pass is below 75% (fixes sub-30% cliffs)
# HIBS_DEEP_ENRICH_WINDOW_DAYS=5         — deep enrich kickoffs within N days when today-only is off
# Developer only: full-window 90% DQ across the dashboard (more API calls — never on VPS)
# HIBS_DEV_FULL_DQ=1
# Production VPS: leave unset or HIBS_DEV_FULL_DQ=0 (apply-vps-safe-production.sh sets 0)
# HIBS_DEEP_ENRICH_MAX_RETRIES=3
# HIBS_ENRICH_CACHE_HOURS_FUTURE=2
# HIBS_FETCH_ALL_DOMESTIC=1          — summer: fetch UK/EU leagues, not intl-only trim
# Clearing fixture cache also resets .rate_limit_state.json counters (fixes all-DQ ~30% / no form).
#
# API-Sports (api-football) free accounts often block current-season data or show "suspended" until you fix billing
# on https://dashboard.api-football.com — that is not "usage" from this app alone. Practical free path:
#   • Get a free token from https://www.football-data.org/ (FOOTBALL_DATA_ORG_KEY) — limited competitions but no API-Sports.
#   • HIBS_PREFER_FOOTBALL_DATA_FIXTURES=1  → try Football-Data first for fixture lists.
#   • HIBS_SKIP_API_SPORTS_FIXTURES=1       → never call API-Sports for fixture lists (enrichment still uses it if loaded).
#   • HIBS_DISABLE_API_SPORTS=1            → do not load API-Sports at all (Football-Data + scrapers only; sparser enrich).
#
# Thin-data rescue (default on): FotMob calendar form + league-table stats when API recent/standings empty.
# HIBS_THIN_DATA_SCRAPE=1
# HIBS_FOTMOB_RECENT=1
#
# Low-source scrape automation (cron + hands-off): FDO/FotMob/ESPN when API-Sports off.
# HIBS_LOW_SOURCE_AUTO_ENRICH=1       — enrich thin fixtures in headless cycle (default on)
# HIBS_LOW_SOURCE_BACKFILL_BUNDLE=1   — merge scrape rows into empty all_fixtures disk bundle
# HIBS_LOW_SOURCE_ENRICH_MAX=25       — max enrich per cron cycle
# HIBS_LOW_SOURCE_SCRAPE_LEAGUES=     — optional comma override (default: active competition focus)
# HIBS_LOW_SOURCE_SCRAPE_FORCE=1      — bypass scrape disk cache in warm_low_source_scrape.py
# HIBS_ODDS_THIN_RESCUE=1          — backup Odds API keys + line-shop partial 1X2 fill when primary odds thin
# HIBS_ODDS_BACKUP_SPORT_KEYS=     — optional comma extra Odds API sport keys for historic/thin windows
#
# Gate profile institutional compare (offline):
# HIBS_GATE_GRID_EXHAUSTIVE=1      — scripts/compare_gate_profiles.py --exhaustive
# HIBS_GATE_GRID_MAX=96            — cap grid profiles in exhaustive search
#
# Logging (local daily use — does not change predictions, enrich, or DQ scores):
# HIBS_APP_LOG_ENABLED=1
# HIBS_APP_LOG_FILE=logs/hibs-bet.log
# HIBS_APP_LOG_LEVEL=INFO
# HIBS_APP_LOG_HTTP=1
# HIBS_APP_LOG_TEE_STDIO=1
# HIBS_PREDICTION_LOG_ENABLED=1   — engine monitor: log picks on dashboard load; POST /api/monitor/sync-results after FT
# HIBS_PRED_LOG_SYNC_AUTO=1       — auto-settle FT results after each bundle build (throttled, default on)
# HIBS_PRED_LOG_SYNC_AUTO_MIN_SEC=1800
# HIBS_AUDIT_SETTLE_SCRAPE_FALLBACK=1 — FT via FDO/FotMob when API-Sports off; closing tagged honestly
# HIBS_SETTLE_BACKUP_ESPN=1       — ESPN scoreboard backup when FotMob lags (cups/internationals)
# HIBS_SETTLE_BACKUP_SOFASCORE=0  — optional SofaScore team-events backup (often 403 on VPS)
# HIBS_ENABLE_FPL_EPL=1           — Fantasy Premier League JSON for EPL xG/form/table (default on with MAX_DATA)
# HIBS_CLV_LOG_ENABLED=1
#
# When APIs are blocked or thin, supplemental HTTP layers in (see scrapers/source_registry.py + HIBS_ENABLE_* below).
# Respect robots.txt, rate limits, and site terms; scrapers enrich data — they are not a full fixture calendar.
#
# Odds from many books (incl. some exchange-backed lines where the aggregator exposes them): wire ODDS_API_KEY
# (The Odds API). Betfair / other exchanges: prefer their official APIs or licensed feeds — scraping exchange
# pages usually violates those sites' terms and breaks often; not implemented here by design.

FOOTBALL_DATA_ORG_KEY=your_football_data_org_key_here
# Free tier is 10 req/min — local guard defaults to 8/min (HIBS_FOOTBALL_DATA_PER_MIN_LIMIT).
# HIBS_FOOTBALL_DATA_TEAM_MATCHES=0   — off by default (per-team /teams/{id}/matches hammers quota)
# HIBS_FOOTBALL_DATA_STANDINGS_CACHE_HOURS=24
# HIBS_FOOTBALL_DATA_HEALTH_PROBE_MIN=30  — /api/health FDO probe cache (minutes)
# HIBS_SKIP_FOOTBALL_DATA=1             — disable all Football-Data.org calls
SPORTSMONK_KEY=your_sportsmonk_key_here
# API-Football (api-sports.io): use any one of the following. Without a valid key the client is omitted or
# responses are empty; the app emits at most one missing/invalid-key log line per process for that case.
API_SPORTS_FOOTBALL_KEY=your_api_sports_football_key_here
# Aliases also accepted: API_SPORTS_KEY, APISPORTS_KEY · FOOTBALL_DATA_KEY
ODDS_API_KEY=your_odds_api_key_here
# With a real ODDS_API_KEY (non-placeholder), enrichment uses The Odds API by default; set HIBS_SKIP_ODDS_API=1 to opt out.
# The Odds API: aggregates many bookmakers; use instead of scraping Betfair/Smarkets pages.
STATS_API_KEY=your_stats_api_key_here

# Paid / full pipeline (maximize API + scraper inputs; watch Odds API / Rapid / API-Sports quotas):
# HIBS_MAX_DATA=1
# Leave HIBS_SKIP_ODDS_API unset (or 0) when ODDS_API_KEY is set. STATS_API_KEY unlocks Rapid stats xG when MAX_DATA=1.
# HIBS_ENABLE_SOFASCORE_XG=1 — rolling xG from SofaScore last matches (auto-on when HIBS_MAX_DATA=1). May need: pip install curl_cffi
# HIBS_ENABLE_FOTMOB_XG=1 — league-table team xG from FotMob /api/data/leagues (UEFA + domestic cups default-on; all mapped leagues when HIBS_MAX_DATA=1 or this flag)
# HIBS_FETCH_FIXTURE_STATISTICS_XG=1 — API-Football fixtures/statistics Expected Goals when fixture xG empty (VPS safe profile; max HIBS_FETCH_FIXTURE_STATISTICS_XG_MAX per refresh, 12h cache). Helps INTL_FRIENDLIES reach 88–90% DQ (measured xG tier) without changing the DQ formula.
# HIBS_FOTMOB_INTL_RECENT_DAYS=120 — FotMob form lookback for national friendlies (default 120 vs 75)
# HIBS_ENABLE_SOFASCORE_XG=1 — SofaScore team xG averages when API reachable (403 skipped; also on with HIBS_MAX_DATA=1)
# HIBS_MEASURED_XG_LAMBDA_BOOST=0 — optional 0.01–0.03 calibrated-λ nudge when xG is measured (default off)
# HIBS_ENABLE_FBREF_SCHEDULE_XG=1 — FBref schedule xG for Scottish + EFL + BE/NL/PT/DK/GR/AT + NO/FI (default on).
# HIBS_ENABLE_STATSBOMB_LIGHT=1 — StatsBomb open goals proxy → xG estimate (auto-on when HIBS_MAX_DATA=1).
# HIBS_ENABLE_STATSBOMB_OPEN_MATCHES=1 — same team proxy in supplemental (auto-on when HIBS_MAX_DATA=1).
# Deep scrape always when supplemental is on (default): heavy FBref/Understat + scraped xG even if APIs look strong.
# HIBS_ALWAYS_DEEP_SCRAPE=1
# HIBS_SKIP_HEAVY_WHEN_API_STRONG=0
# Do not set HIBS_DISABLE_API_SPORTS. Leave HIBS_SKIP_API_INJURIES unset for API-Sports injuries.
#
# Scraped xG for upcoming fixtures (Understat, FBref SPFL for Scottish leagues, API last-10 avg):
# HIBS_SCRAPE_XG=1
# HIBS_ENABLE_SCOTTISH_FBREF_XG=1
# HIBS_ENABLE_UNDERSTAT_LIGHT=1
# HIBS_USE_SUPPLEMENTAL_XG_PRIOR=1
# HIBS_SUPPLEMENTAL_XG_BLEND=0.15

# Structured match card (pick / rationale / confidence / scoreline):
# HIBS_INSIGHT_MIN_DATA_PCT=62   — below this, show book odds only (no model pick)
# HIBS_ODDS_ONLY_DQ_MAX=78       — for leagues in HIBS_ODDS_ONLY_LEAGUES, odds-only if coverage below this
# HIBS_ODDS_ONLY_LEAGUES=BELGIUM_FIRST,DENMARK_SL,GREECE_SL,AUSTRIA_BL,EREDIVISIE,PRIMEIRA
#   Norway (NORWAY_ELITESERIEN) and Finland are NOT in the default list — model picks when DQ ≥ threshold.
# HIBS_PREFER_SCRAPED_STANDINGS=1 — SoccerStats for Norway/Finland when API tables are thin.
# ODDS_API_KEY — The Odds API (not THE_ODDS_API_KEY). SPL uses sport key soccer_spl; NO/FI use soccer_norway_eliteserien / soccer_finland_veikkausliiga.
# HIBS_INSIGHT_PICK_MARGIN=0.08  — minimum 1X2 spread for outright win picks (conservative)

# Optional: stricter prediction inputs (per-match data score 0–100 in UI).
# HIBS_MIN_DATA_QUALITY_PCT=80
#   When set, widens the value edge bar if coverage is below this (fewer false “value” flags on thin data).
# HIBS_VALUE_REQUIRE_DATA_PCT=78
#   When set, suppresses all value_bets / has_value_bet if fixture data_quality.score_pct is below this.
# HIBS_UI_FULL_DATA_MIN_PCT=85
#
# Value edge: model probability must exceed book implied by at least this margin (default 0.05 = 5pp).
# Also scaled up when recent-match samples are thin. If every fixture shows zero value, try lowering to 0.03
# before disabling enrichment; raising HIBS_VALUE_REQUIRE_DATA_PCT or HIBS_MIN_DATA_QUALITY_PCT has the same effect.
# HIBS_VALUE_EDGE_MARGIN=0.05
# HIBS_VALUE_MARKETS=1x2,btts,ou
#   Comma list; omit 1x2 to disable 1X2 value flags. btts / ou control side markets.
# HIBS_VALUE_LEAGUES=
#   Optional comma allowlist (e.g. EPL,SCOTLAND); empty = all leagues in window.
# Trial profile (after hone — VPS: deploy/apply-vps-trial-production.sh):
# HIBS_VALUE_LEAGUES=EPL,SCOTLAND,UCL,EUROPA_LEAGUE,UECL,LA_LIGA,SERIE_A,BUNDESLIGA,LIGUE_1,EREDIVISIE,PRIMEIRA
# HIBS_SHARPEN_GATES=1
# HIBS_SHARPEN_MIN_BET_CONFIDENCE=50
# HIBS_SHARPEN_MIN_EDGE=0.07
# HIBS_SHARPEN_UPSET_RISK_CUTOFF=0.12
# HIBS_SHARPEN_UPSET_EDGE_BUMP=0.014
# HIBS_AWAY_TIGHTEN=1
# HIBS_UNDER_TIGHTEN=0   — enable only when audit has 80+ legs with side-market odds
# HIBS_VALUE_CUP_DQ_PCT=82
#   Block value on cup/playoff rounds (competition_meta) when data_quality is below this.
# HIBS_ODDS_CROSS_REJECT_PCT=10
#   Reject value bets when cross-book implied spread exceeds this (steam / disagreement).
# Portfolio Kelly (capital exhaustion across value bets in the same kickoff window):
# HIBS_PORTFOLIO_KICKOFF_WINDOW_MIN=60   — group value bets with kickoffs within this many minutes
# HIBS_PORTFOLIO_STAKE_CAP_PCT=10        — max combined suggested stake % per window (after sqrt(N) split)

# SQLite audit trail of predictions + post-match results (default DB: data/prediction_audit.sqlite).
# Default ON (set HIBS_PREDICTION_LOG_ENABLED=0 to disable). Auto-runs after each fixture bundle build.
# HIBS_PREDICTION_LOG_ENABLED=1
# HIBS_PREDICTION_LOG_ALWAYS=1        — log every fixture with a prediction on bundle finalize (default on)
# HIBS_PREDICTION_LOG_MIN_INTERVAL_SEC=21600  — min seconds between snapshots per fixture (0 = every pass)
# HIBS_PREDICTION_LOG_AUTO_MAX=500
# HIBS_PREDICTION_LOG_DB=
# Forward B2B evidence window (excludes pre-deploy historic odds hole from since-deploy metrics).
# Set on first VPS production deploy; auto-set by scripts/buyer_bootstrap_vps.sh if unset.
# HIBS_EVIDENCE_DEPLOY_DATE=2026-06-10
# When 1, F8/F9 pass/fail use trial domestic+cups CLV (excludes WORLD_CUP/INTL_FRIENDLIES rows).
# HIBS_F9_TRIAL_LEAGUES_ONLY=1
#
# Single-tenant white-label (not multi-tenant SaaS) — see docs/B2B_WHITELABEL_SCOPE.md
# HIBS_WHITELABEL_TAGLINE=Your Brand — Football Intelligence
# HIBS_WHITELABEL_TAGLINE_SHORT=Your Brand
# HIBS_WHITELABEL_LOGO=partner_logo.png
# HIBS_WHITELABEL_PARTNER=Acme Media Ltd
# HIBS_PREDICTION_LOG_RETAIN_DAYS=365
# With prediction log on: store opening 1X2 + best-bet odds in enrich_summary_json for CLV (default on).
# HIBS_CLV_LOG_ENABLED=1
# Audit odds capture (P0 — value replay / CLV need 1X2 in prediction_json):
# HIBS_AUDIT_ODDS_RETRY=1         — one Odds API + API-Football bundle fetch before snapshot insert
# HIBS_AUDIT_REQUIRE_ODDS=1       — daily cron skips fixtures still missing 1X2 after retry (Brier rows from dashboard may still log)
#   pred-log-sync joins closing 1X2 from API-Football odds; /api/health and /status show clv_by_league.
# Measure calibration over time:
#   1) HIBS_PREDICTION_LOG_ENABLED=1 — run dashboard/predictions so snapshots accumulate.
#   2) After matches finish: python -m hibs_predictor.main pred-log-sync
#   Daily headless (Mac): bash scripts/install_cron.sh — 06:35 + 23:05 log+sync; Sun calibration-fit
#   VPS: sudo bash deploy/cron-hibs-calibration.sh --install
#   Manual: bash scripts/run_daily_audit_pipeline.sh
# Config honing (1X2 Brier + value gate A/B, no engine changes):
#   bash scripts/run_config_hone_suite.sh
#   PYTHONPATH=src python3 scripts/hone_production_config.py
# HIBS_DAILY_AUDIT_FORCE_REFRESH=0   — keep 0 to protect API quota + dashboard DQ (cron default)
# HIBS_DAILY_SYNC_MAX=800
# HIBS_DAILY_SYNC_MIN_HOURS=0
#      (joins FT scores + API Expected Goals into result_xg_home/away when statistics exist)
#   3) Report Brier / per-league CLV: python -m hibs_predictor.main pred-log-report
#   4) Fit shrink cache (weekly cron): python -m hibs_predictor.main calibration-fit  → .cache/calibration_v1.json
# VPS cron: deploy/cron-hibs-calibration.sh (--print or --install)
# Historic accuracy tweaks (when log enabled + enough rows): league calibration_shrink on 1X2 before value.
# HIBS_CALIB_MIN_LEAGUE_ROWS=25
# HIBS_CALIB_BASELINE_BRIER=0.66
# HIBS_CALIB_BRIER_SENSITIVITY=2.5
# HIBS_CALIBRATION_CACHE=.cache/calibration_v1.json
# HIBS_CALIB_FIT_DAYS=90
# HIBS_CALIB_FIT_MIN_ROWS=20
# HIBS_CALIB_TRIAL_LEAGUES_ONLY=1   — fit calibration on trial leagues (excl. WC/friendlies)
# HIBS_CALIB_CLV_WEIGHT=1           — CLV-weighted isotonic (enable after price_aware_research.json favours it)
# HIBS_GATE_LEAGUE_MARGIN_DELTA_JSON={"WORLD_CUP":0.018}  — from gate research margin presets
# HIBS_PROXY_XG_LEAGUE_SHRINK=0.15
# HIBS_H2H_BLEND_WEIGHT=0.05
# HIBS_VALUE_MIN_BET_CONFIDENCE=42
# HIBS_BET_CONF_VENUE_FORM=1
#   When 1 (default), bet_confidence form depth uses min(overall recent n, home-at-home / away-on-road n).
# Optional: GET /api/audit/summary?token=... (same value); route returns 404 if unset or wrong token.
# HIBS_AUDIT_API_TOKEN=
# Rolling model monitor window (Insights + GET /api/monitor/summary when logged in).
# HIBS_MONITOR_DAYS=28
# HIBS_PRED_LOG_SYNC_LOG=/var/log/hibs-bet/daily-audit-am.log
#
# Historic calibration backfill (CLI: python -m hibs_predictor.main historic-snapshot --from ... --to ...):
# HIBS_HISTORIC_SNAPSHOT_LEAGUES=EPL,SCOTLAND,CHAMPIONSHIP,LA_LIGA  — comma override; empty = default UK+top5
# HIBS_HISTORIC_MAX_FIXTURES=400   — cap per run (API + enrich budget)
# HIBS_HISTORIC_INCLUDE_OPTIONAL_LEAGUES=0  — set 1 to add LEAGUE_ONE, LEAGUE_TWO, UCL, EUROPA_LEAGUE, UECL
# Reuses HIBS_ENRICH_CHUNK_SIZE=8 and HIBS_ENRICH_CHUNK_PAUSE_SEC=65 for Football-Data.org rate limits.

# Rolling window for scrapes + open-data helpers (default ~6 months back + 14 days ahead).
# HIBS_STATS_LOOKBACK_DAYS=183
# HIBS_STATS_FUTURE_DAYS=14
# HIBS_DATA_POLICY_AS_OF=2026-05-14T12:00:00+00:00
# Scraping & open data (see src/hibs_predictor/scrapers/source_registry.py for full catalog).
# Wired today: FBref, Understat, SofaScore, SoccerStats, StatsBomb open (opt-in). Experimental: WhoScored (Playwright probe only).
# Planned backlog (not implemented): Transfermarkt, FootyStats, SoccerStats, DataMB — check each site's robots + terms before adding parsers.
# Heavy scrapers (FBref + full Understat): default ON. Set HIBS_ENABLE_HEAVY_SCRAPERS=0 only if they are detrimental (403/blocks/rate limits).
# HIBS_FBREF_BLOCKED=1 — skip all FBref HTML on VPS/datacenter IPs that get HTTP 403 (squad + schedule xG).
# curl_cffi (pip install curl_cffi) may help on residential IPs; datacenter VPS usually still 403 — rely on Understat/FotMob/API xG.
# HIBS_ENABLE_API_SQUAD_DEPTH=1 — API-Football players/squads roster (24h team cache; default on). Transfermarkt HTML not used.
# HIBS_SKIP_API_SQUAD_DEPTH=1 — skip squad depth API calls.
# HIBS_ENABLE_HEAVY_SCRAPERS=1
# HIBS_MIN_LEAGUE_CHIP_FIXTURES=1  # default in app is 1: show league chip if ≥1 fixture in window (wider value-hunt scope)
# Skip heavy only when APIs already cover odds, xG, form, stats, and table positions (default off).
# HIBS_SKIP_HEAVY_WHEN_API_STRONG=0
# Set to 1 to reduce HTTP on API-strong fixtures; leave HIBS_ALWAYS_DEEP_SCRAPE=1 to override skip.
# HIBS_ENABLE_UNDERSTAT_LIGHT=0
# HIBS_ENABLE_STATSBOMB_OPEN_MATCHES=0
# Optional: blend Understat xG into Poisson λ before 1X2 (needs understat_light on fixture + prior flag).
# HIBS_USE_SUPPLEMENTAL_XG_PRIOR=0
# HIBS_SUPPLEMENTAL_XG_BLEND=0.1
#
# Dev-only: enables synthetic training rows (main train --use-sample) and legacy numeric fallbacks when fixture enrichment throws.
# HIBS_ALLOW_DUMMY=1

# Staging (side-by-side with production on :8000): copy deploy/staging.env.example → .env.staging,
# use deploy/hibs-bet-staging.service (gunicorn :8001). Keeps a separate cache dir from production.
# HIBS_MAX_DATA=1
# HIBS_CACHE_DIR=.cache-staging
# PORT=5002
#
# On-disk JSON cache (default directory: .cache/). Dashboard Refresh and POST /api/cache/clear clear stale data after deploys or key changes.
# HIBS_CACHE_DIR=.cache
# HIBS_CACHE_TTL_HOURS=1          — default TTL for dashboard fixture list caches (per-league + all_fixtures bundle)
# HIBS_CACHE_PRUNE=1               — prune expired JSON on DataAggregator startup and periodically during fixture fetch (set 0 to disable)
#
# Session login (recommended on VPS; default off for local dev):
# HIBS_AUTH_ENABLED=0              — no login required (local default)
# HIBS_AUTH_ENABLED=1              — require shared password for dashboard, APIs, settings, cache clear, etc.
# HIBS_AUTH_PASSWORD=              — shared site password on VPS (plain text or werkzeug hash pbkdf2:… / scrypt:…)
# HIBS_HIBS_PASSWORD=              — alias for HIBS_AUTH_PASSWORD (either one is enough)
# HIBS_SECRET_KEY=                 — required when auth enabled; generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# HIBS_AUTH_PUBLIC_HEALTH=1        — optional: leave GET /api/health public when auth enabled (uptime monitors)
# HIBS_PUBLIC_TRACKER=1            — public read-only /tracker + CSV export (no login) when auth enabled
# HIBS_CALIB_BASELINE_BRIER=0.66   — proof metric: scale-cohort Brier must beat this
# HIBS_PROOF_CLV_BEAT_PCT=60       — proof metric: value-pick CLV beat-close % target
# HIBS_SCALE_READY_CLV_PCT=60       — same threshold for scale_ready gate
# Sign-in is password-only (no username field). HIBS_AUTH_USERNAME is optional for API/clients using check_credentials.
#
# Dashboard launch overlay: CSS tips while fixtures load; optional muted loop video when file present.
# HIBS_LAUNCH_MEDIA=0              — default off (CSS-only overlay with crest + rotating tips)
# HIBS_LAUNCH_MEDIA=1              — also try static/launch-wait.mp4 (fail-soft if missing; see static/README.md)
#
# Poisson 1X2 low-score correlation (Dixon–Coles). Set 0 to disable.
# HIBS_DIXON_COLES_RHO=-0.10
# Scale fixed ρ toward 0 on extreme λ mismatch/totals until per-league MLE (default on)
# HIBS_DIXON_COLES_RHO_MATCH_STYLE=1
#
# Enrich choke-point tuning (API 429 / form gaps):
# HIBS_ENRICH_FRESH_MINUTES=15     — skip redundant full enrich when enriched_at is newer (bundle rows + measure_dq)
# HIBS_ENRICH_API_SEM=4            — max concurrent team-history API calls per process (default 2 when HIBS_MAX_DATA=1)
# HIBS_TEAM_RECENT_MEM_TTL_SEC=300 — in-memory dedupe of team last-10 within a bundle build
# HIBS_FIXTURE_FETCH_WORKERS=6     — parallel league fixture fetch (default 4 when HIBS_MAX_DATA=1)
# HIBS_MIN_ENRICH_LEAGUES=EPL,SCOTLAND  — optional enrich allowlist for measure_dq / audits
# HIBS_MIN_ENRICH_AUTO=1           — when allowlist unset, measure_dq only leagues with kickoff today (UTC)
#
# Unified cross-sport portfolio bar (top of every page):
# Local dev (racing on :5003):
# HIBS_PORTFOLIO_API_URL=http://127.0.0.1:5003/api/portfolio/summary
# HIBS_RACING_BASE_URL=http://127.0.0.1:5003
# Production (hibs-racing linked at /racing on hibs-bet.co.uk):
# HIBS_RACING_BASE_URL=https://hibs-bet.co.uk/racing
# HIBS_PORTFOLIO_API_URL=/api/racing/portfolio/summary
# Inst++ racing evidence probes (VPS — faster than public nginx path):
# HIBS_RACING_EVIDENCE_LOCAL=1       — probe http://127.0.0.1:5003 when /opt/hibs-racing exists
# HIBS_RACING_INST_AGGREGATOR=1       — merge Inst++ health from SQLite (default on)
# HIBS_RACING_INST_HEALTH_URL=http://127.0.0.1:8000/api/inst-pp/racing/health
# HIBS_RACING_EVIDENCE_TIMEOUT_CARDS=90
# HIBS_RACING_EVIDENCE_TIMEOUT_HEALTH=30
# HIBS_HEALTH_RACING_PROBE=1
# HIBS_HEALTH_INPLAY_PROBE=1

# Cross-platform product bar (unified nginx: /racing, /harvested-execution, /line-trader)
# HIBS_FOOTBALL_BASE_URL=https://hibs-bet.co.uk
# HIBS_RACING_BASE_URL=/racing
# HIBS_TRADING_STATUS_URL=/harvested-execution
# HIBS_LINE_TRADER_URL=/line-trader
# HIBS_FVE_INTEGRATION=1
# FVE_LINES_TOKEN=                    # optional shared secret for /api/fve/lines
# FVE_API_URL=http://127.0.0.1:8010 # FVE FastAPI on same host
# FVE_API_URL=http://77.68.89.75:8010 # dedicated 1GB FVE VPS (see deploy/bootstrap-fve-dedicated-1gb.sh)
# HIBS_FVE_PUBLIC_API_URL=https://hibs-bet.co.uk/fve-api
# HIBS_FVE_PUBLIC_WS_URL=wss://hibs-bet.co.uk/fve-api
# HIBS_FVE_FORCE_PAUSED=0           # optional hibs-side override (default: read FVE /health)
# HIBS_LINE_TRADER_URL=/line-trader
# HIBS_FVE_STATUS_TTL_SEC=12        # cached /api/fve/status probe
# HIBS_FVE_DECAY_TIMEOUT_SECS=120     # gray stale FVE lines in line shop UI
# HIBS_FVE_ARB_DELTA_BPS=50         # highlight value gap (book vs true line)
# Same-host FVE: sudo bash deploy/apply-vps-fve-line-trader.sh
# Remote FVE (1GB box): bootstrap on FVE host, then on main:
#   sudo FVE_REMOTE_HOST=77.68.89.75 bash deploy/apply-vps-fve-remote-host.sh

# Harvested Execution dashboard (same site — product switcher + /harvested-execution):
# Local dev (standalone dashboard on :9110 or in-app after login):
# HIBS_TRADING_STATUS_URL=http://127.0.0.1:9110/
# TRADING_METRICS_URL=http://127.0.0.1:9108
# Production (football app serves dashboard; metrics stay localhost on VPS):
# HIBS_TRADING_STATUS_URL=https://hibs-bet.co.uk/harvested-execution
# TRADING_METRICS_URL=http://127.0.0.1:9108

# --- Harvested Execution (Alpaca) — see docs/TRADING_ALPACA_SETUP.md, docs/TRADING_PAPER_START.md ---
#
# TRADING_PROFILE=conservative   (documentation label — not read by code; keeps tuning intent explicit)
#   Institutional++ from this platform = ops rigor + low trade rate, not HFT latency.
#   Do NOT loosen toward "template" (0.60/0.85 gates, qty 10/5) until shadow scorecard + paper evidence say so.
#
#   conservative (recommended starter — matches deploy/paper.env.example):
#     Phase caps (code): paper $1k/order $10k gross | shadow $0 submit | micro $100/$500
#     STRATEGY_OFI_GATE1  ±0.65 | GATE2 ±0.88 | QTY 5/2 | MIN_TICKS 8 | SYMBOLS AAPL,TSLA
#     MARKET_STREAM_FEED=iex | ASSUMED_SPREAD_BPS=10
#   template (more signals — only after review):
#     STRATEGY_OFI_GATE1  ±0.60 | GATE2 ±0.85 | QTY 10/5 | MIN_TICKS 5
#
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# Crypto market data (default coinbase = public WSS, no Alpaca key consumed):
# CRYPTO_MARKET_DATA_SOURCE=coinbase   # institutional dual-feed default with one Alpaca key
# CRYPTO_MARKET_DATA_SOURCE=alpaca       # requires distinct ALPACA_CRYPTO_API_KEY
# ALPACA_CRYPTO_API_KEY=
# ALPACA_CRYPTO_API_SECRET=
# TRADING_CRYPTO_MARKET_STREAM=0       # force crypto feed off
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_DATA_BASE_URL=https://data.alpaca.markets
# TRADING_HMAC_SECRET=

# Shadow soak (30-day evidence, no broker submits) — port 9108
# TRADING_DEPLOYMENT_PHASE=shadow
# METRICS_PORT=9108
# TRADING_METRICS_URL=http://127.0.0.1:9108
# TRADING_SHADOW_SOAK_DB=data/trading_shadow_soak.db

# Paper trading (broker submits to Alpaca paper) — port 9109, separate DB
# TRADING_DEPLOYMENT_PHASE=paper
# METRICS_PORT=9109
# TRADING_METRICS_URL=http://127.0.0.1:9109
# TRADING_PAPER_DB=data/trading_paper.db
# TRADING_STRATEGY_AUDIT=data/strategy_scan_paper.jsonl
# TRADING_SPREAD_AUDIT=data/spread_slippage_paper.jsonl
# STRATEGY_SYMBOLS=AAPL
# TRADING_ENABLE_CRYPTO=1
# STRATEGY_CRYPTO_SYMBOLS=BTC/USD,ETH/USD
# MARKET_STREAM_FEED=iex
# ASSUMED_SPREAD_BPS=10
# STRATEGY_GATE_MODE=GATE_1
# Equity lane OFI (STRATEGY_OFI_*)
# STRATEGY_OFI_GATE1_BUY_THRESHOLD=0.65
# STRATEGY_OFI_GATE1_SELL_THRESHOLD=-0.65
# STRATEGY_OFI_GATE2_BUY_THRESHOLD=0.88
# STRATEGY_OFI_GATE2_SELL_THRESHOLD=-0.88
# STRATEGY_OFI_GATE1_QTY=5
# STRATEGY_OFI_GATE2_QTY=2
# STRATEGY_OFI_MIN_TICKS=8
# STRATEGY_OFI_WINDOW_TICKS=50
# Crypto lane OFI overrides (STRATEGY_CRYPTO_OFI_* — independent of equity when set)
# STRATEGY_CRYPTO_OFI_GATE1_BUY_THRESHOLD=0.58
# STRATEGY_CRYPTO_OFI_GATE1_SELL_THRESHOLD=-0.58
# STRATEGY_CRYPTO_OFI_GATE2_BUY_THRESHOLD=0.78
# STRATEGY_CRYPTO_OFI_GATE2_SELL_THRESHOLD=-0.78
# STRATEGY_CRYPTO_OFI_GATE1_QTY=0.01
# STRATEGY_CRYPTO_OFI_GATE2_QTY=0.005
# STRATEGY_CRYPTO_OFI_MIN_TICKS=5
# STRATEGY_CRYPTO_OFI_WINDOW_TICKS=120
# Profile A shadow calibration template: deploy/shadow-calibration.env.example

