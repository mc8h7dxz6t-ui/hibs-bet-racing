# Optional nginx snippet — proxy FVE API/WS on :8010 (hibs gunicorn stays :8000).
# Include from hibs-bet.co.uk server block:
#
#   location /fve-api/ {
#       proxy_pass http://127.0.0.1:8010/;
#       proxy_http_version 1.1;
#       proxy_set_header Upgrade $http_upgrade;
#       proxy_set_header Connection "upgrade";
#       proxy_set_header Host $host;
#       proxy_read_timeout 3600s;
#   }
#
# Then set:
#   HIBS_FVE_PUBLIC_WS_URL=wss://hibs-bet.co.uk/fve-api
#   HIBS_FVE_PUBLIC_API_URL=https://hibs-bet.co.uk/fve-api
