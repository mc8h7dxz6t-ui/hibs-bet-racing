# Harvested Execution — MICRO phase (small real-capital after shadow scorecard GO).
# See docs/TRADING_PROMOTION_SCORECARD.md
#
# Use Alpaca LIVE keys only after shadow→micro promotion is green.
# Phase caps enforced in code: $100/order, $500 gross.

TRADING_DEPLOYMENT_PHASE=micro
TRADING_PROFILE=conservative
# ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

METRICS_PORT=9110
TRADING_METRICS_URL=http://127.0.0.1:9110
TRADING_SHADOW_METRICS_URL=http://127.0.0.1:9108

TRADING_MICRO_DB=data/trading_micro.db
TRADING_MICRO_STRATEGY_AUDIT=data/strategy_scan_micro.jsonl
TRADING_MICRO_SPREAD_AUDIT=data/spread_slippage_micro.jsonl

STRATEGY_SYMBOLS=AAPL,TSLA
MARKET_STREAM_FEED=iex
ASSUMED_SPREAD_BPS=10

STRATEGY_OFI_GATE1_BUY_THRESHOLD=0.65
STRATEGY_OFI_GATE1_SELL_THRESHOLD=-0.65
STRATEGY_OFI_GATE2_BUY_THRESHOLD=0.88
STRATEGY_OFI_GATE2_SELL_THRESHOLD=-0.88
